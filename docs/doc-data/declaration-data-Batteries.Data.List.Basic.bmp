"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">őĪ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">őĪ</span>)</span></span></div></div>","info":{"doc":"A version of `List.sublists` that has faster runtime performance but worse kernel performance ","docLink":"./Batteries/Data/List/Basic.html#List.sublistsFast","kind":"def","line":329,"name":"List.sublistsFast","sourceLink":"https://github.com/leanprover-community/batteries/blob/3881bc95874e5843b76886ea136f4722f1fa83cf/Batteries/Data/List/Basic.lean#L329-L333"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Batteries/Data/List/Basic.html#List.sublists\"><span class=\"name\">List</span>.<span class=\"name\">sublists</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">őĪ</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">l</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">őĪ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">őĪ</span>)</span></span></div></div>","info":{"doc":"`sublists l` is the list of all (non-contiguous) sublists of `l`; cf. `sublists'`\nfor a different ordering.\n```\nsublists [1, 2, 3] = [[], [1], [2], [1, 2], [3], [1, 3], [2, 3], [1, 2, 3]]\n```\n","docLink":"./Batteries/Data/List/Basic.html#List.sublists","kind":"def","line":319,"name":"List.sublists","sourceLink":"https://github.com/leanprover-community/batteries/blob/3881bc95874e5843b76886ea136f4722f1fa83cf/Batteries/Data/List/Basic.lean#L319-L327"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Batteries/Data/List/Basic.html#List.sublists'\"><span class=\"name\">List</span>.<span class=\"name\">sublists'</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">őĪ</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">l</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">őĪ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">őĪ</span>)</span></span></div></div>","info":{"doc":"`sublists' l` is the list of all (non-contiguous) sublists of `l`.\nIt differs from `sublists` only in the order of appearance of the sublists;\n`sublists'` uses the first element of the list as the MSB,\n`sublists` uses the first element of the list as the LSB.\n```\nsublists' [1, 2, 3] = [[], [3], [2], [2, 3], [1], [1, 3], [1, 2], [1, 2, 3]]\n```\n","docLink":"./Batteries/Data/List/Basic.html#List.sublists'","kind":"def","line":306,"name":"List.sublists'","sourceLink":"https://github.com/leanprover-community/batteries/blob/3881bc95874e5843b76886ea136f4722f1fa83cf/Batteries/Data/List/Basic.lean#L306-L317"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Batteries/Data/List/Basic.html#List.tails_eq_tailsTR\"><span class=\"name\">List</span>.<span class=\"name\">tails_eq_tailsTR</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\">@<a href=\"./Batteries/Data/List/Basic.html#List.tai