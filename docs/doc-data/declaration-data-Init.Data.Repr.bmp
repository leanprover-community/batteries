ink":"https://github.com/leanprover/lean4/blob/fcb2f44cd3db2bae817540c1df036f7e14a29b48/src/Init/Data/Repr.lean#L363-L364","name":"Char.repr","line":363,"kind":"def","docLink":"./Init/Data/Repr.html#Char.repr","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Repr.html#Char.repr\"><span class=\"name\">Char</span>.<span class=\"name\">repr</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/fcb2f44cd3db2bae817540c1df036f7e14a29b48/src/Init/Data/Repr.lean#L360-L361","name":"instReprChar","line":360,"kind":"instance","docLink":"./Init/Data/Repr.html#instReprChar","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Repr.html#instReprChar\"><span class=\"name\">instReprChar</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Repr.html#Repr\">Repr</a> <a href=\"./Init/Prelude.html#Char\">Char</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/fcb2f44cd3db2bae817540c1df036f7e14a29b48/src/Init/Data/Repr.lean#L349-L358","name":"Char.quote","line":349,"kind":"def","docLink":"./Init/Data/Repr.html#Char.quote","doc":"Quotes the character to its representation as a character literal, surrounded by single quotes and\nescaped as necessary.\n\nExamples:\n * `'L'.quote = \"'L'\"`\n * `'\"'.quote = \"'\\\\\\\"'\"`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Repr.html#Char.quote\"