nk":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L52-L54"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.instBEqReducibilityHints\"><span class=\"name\">Lean</span>.<span class=\"name\">instBEqReducibilityHints</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#BEq\">BEq</a> <a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Declaration.html#Lean.instBEqReducibilityHints","kind":"instance","line":50,"name":"Lean.instBEqReducibilityHints","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L50-L50"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.instBEqReducibilityHints.beq\"><span class=\"name\">Lean</span>.<span class=\"name\">instBEqReducibilityHints</span>.<span class=\"name\">beq</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a> → <a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Declaration.html#Lean.instBEqReducibilityHints.beq","kind":"def","line":50,"name":"Lean.instBEqReducibilityHints.beq","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L50-L50"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.instInhabitedReducibilityHints\"><span class=\"name\">Lean</span>.<span class=\"name\">instInhabitedReducibilityHints</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Declaration.html#Lean.instInhabitedReducibilityHints","kind":"instance","line":50,"name":"Lean.instInhabitedReducibilityHints","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L50-L50"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.ReducibilityHints.regular\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityHints</span>.<span class=\"name\">regular</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#UInt32\">UInt32</a> → <a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Declaration.html#Lean.ReducibilityHints.regular","kind":"ctor","line":49,"name":"Lean.ReducibilityHints.regular","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L49-L49"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.ReducibilityHints.abbrev\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityHints</span>.<span class=\"name\">abbrev</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a></div></div>","info":{"doc":"","docLink":"./Lean/Declaration.html#Lean.ReducibilityHints.abbrev","kind":"ctor","line":48,"name":"Lean.ReducibilityHints.abbrev","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L48-L48"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.ReducibilityHints.opaque\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityHints</span>.<span class=\"name\">opaque</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Declaration.html#Lean.ReducibilityHints\">ReducibilityHints</a></div></div>","info":{"doc":"","docLink":"./Lean/Declaration.html#Lean.ReducibilityHints.opaque","kind":"ctor","line":47,"name":"Lean.ReducibilityHints.opaque","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L47-L47"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Declaration.html#Lean.ReducibilityHints\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityHints</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Reducibility hints guide the kernel's *lazy delta reduction* strategy. When the kernel encounters a\ndefinitional equality constraint\n\n           (f ...) =?= (g ...)\n\nwhere `f` and `g` are definitions, it must decide which side to unfold. The rules (implemented in\n`lazy_delta_reduction_step` in `src/kernel/type_checker.cpp`) are:\n\n* If `f` and `g` have the **same hint kind**:\n  - Both `.opaque` or both `.abbrev`: unfold both.\n  - Both `.regular`: unfold the one with the **greater** height first. If their heights are equal\n    (in particular, if `f` and `g` are the same definition), first try to compare their arguments\n    for definitional equality (short-circuiting the unfolding if they match), then unfold both.\n* If `f` and `g` have **different hint kinds**: unfold the one that is *not* `.opaque`, preferring to\n  unfold `.abbrev` over `.regular`.\n\nThe `.regular` constructor carries a `UInt32` *definitional height*, which is computed by the\nelaborator as one plus the maximum height of all `.regular` constants appearing in the definition's\nbody (see `getMaxHeight`). This means `.abbrev` and `.opaque` constants do not contribute to the\nheight. When creating declarations via meta-programming, the height can be specified manually.\n\nThe hints only affect performance — they control the order in which definitions are unfolded, but\nnever prevent the kernel from unfolding a definition during type checking.\n\nThe `ReducibilityHints` are not related to the `@[reducible]`/`@[irreducible]`/`@[semireducible]`\nattributes. Those attributes are used by the elaborator to control which definitions tactics like\n`simp`, `rfl`, and `dsimp` will unfold; they do not affect the kernel. Conversely,\n`ReducibilityHints` are set when a declaration is added to the kernel and cannot be changed\nafterwards. ","docLink":"./Lean/Declaration.html#Lean.ReducibilityHints","kind":"inductive","line":16,"name":"Lean.ReducibilityHints","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Declaration.lean#L16-L50"}}],"imports":["Init.Data.Ord.UInt","Init.Data.ToString.Macro","Lean.Expr"],"instances":[{"className":"Inhabited","name":"Lean.instInhabitedReducibilityHints","typeNames":["Lean.ReducibilityHints"]},{"className":"BEq","name":"Lean.instBEqReducibilityHints","typeNames":["Lean.ReducibilityHints"]},{"className":"Ord","name":"Lean.ReducibilityHints.instOrd","typeNames":["Lean.ReducibilityHints"]},{"className":"Inhabited","name":"Lean.instInhabitedConstantVal","typeNames":["Lean.ConstantVal"]},{"className":"BEq","name":"Lean.instBEqConstantVal","typeNames":["Lean.ConstantVal"]},{"className":"Inhabited","name":"Lean.instInhabitedAxiomVal","typeNames":["Lean.AxiomVal"]},{"className":"BEq","name":"Lean.instBEqAxiomVal","typeNames":["Lean.AxiomVal"]},{"className":"Inhabited","name":"Lean.instInhabitedDefinitionSafety","typeNames":["Lean.DefinitionSafety"]},{"className":"BEq","name":"Lean.instBEqDefinitionSafety","typeNames":["Lean.DefinitionSafety"]},{"className":"Repr","name":"Lean.instReprDefinitionSafety","typeNames":["Lean.DefinitionSafety"]},{"className":"Inhabited","name":"Lean.instInhabitedDefinitionVal","typeNames":["Lean.DefinitionVal"]},{"className":"BEq","name":"Lean.instBEqDefinitionVal","typeNames":["Lean.DefinitionVal"]},{"className":"Inhabited","name":"Lean.instInhabitedTheoremVal","typeNames":["Lean.TheoremVal"]},{"className":"BEq","name":"Lean.instBEqTheoremVal","typeNames":["Lean.TheoremVal"]},{"className":"Inhabited","name":"Lean.instInhabitedOpaqueVal","typeNames":["Lean.OpaqueVal"]},{"className":"BEq","name":"Lean.instBEqOpaqueVal","typeNames":["Lean.OpaqueVal"]},{"className":"Inhabited","name":"Lean.instInhabitedConstructor","typeNames":["Lean.Constructor"]},{"className":"BEq","name":"Lean.instBEqConstructor","typeNames":["Lean.Constructor"]},{"className":"Inhabited","name":"Lean.instInhabitedInductiveType","typeNames":["Lean.InductiveType"]},{"className":"BEq","name":"Lean.instBEqInductiveType","typeNames":["Lean.InductiveType"]},{"className":"Inhabited","name":"Lean.instInhabitedDeclaration","typeNames":["Lean.Declaration"]},{"className":"BEq","name":"Lean.instBEqDeclaration","typeNames":["Lean.Declaration"]},{"className":"Inhabited","name":"Lean.instInhabitedInductiveVal","typeNames":["Lean.InductiveVal"]},{"className":"Inhabited","name":"Lean.instInhabitedConstructorVal","typeNames":["Lean.ConstructorVal"]},{"className":"BEq","name":"Lean.instBEqConstructorVal","typeNames":["Lean.ConstructorVal"]},{"className":"Inhabited","name":"Lean.instInhabitedRecursorRule","typeNames":["Lean.RecursorRule"]},{"className":"BEq","name":"Lean.instBEqRecursorRule","typeNames":["Lean.RecursorRule"]},{"className":"Inhabited","name":"Lean.instInhabitedRecursorVal","typeNames":["Lean.RecursorVal"]},{"className":"BEq","name":"Lean.instBEqRecursorVal","typeNames":["Lean.RecursorVal"]},{"className":"Inhabited","name":"Lean.instInhabitedQuotKind","typeNames":["Lean.QuotKind"]},{"className":"Inhabited","name":"Lean.instInhabitedQuotVal","typeNames":["Lean.QuotVal"]},{"className":"Inhabited","name":"Lean.instInhabitedConstantInfo","typeNames":["Lean.ConstantInfo"]}],"name":"Lean.Declaration"}