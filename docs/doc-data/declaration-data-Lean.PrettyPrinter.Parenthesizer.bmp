2. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.maybeParenthesize\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">Parenthesizer</span>.<span class=\"name\">maybeParenthesize</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cat</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">canJuxtapose</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">mkParen</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a> → <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">prec</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L220-L224","name":"Lean.PrettyPrinter.Parenthesizer.instMonadQuotationParenthesizerM","line":220,"kind":"instance","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.instMonadQuotationParenthesizerM","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.instMonadQuotationParenthesizerM\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">Parenthesizer</span>.<span class=\"name\">instMonadQuotationParenthesizerM</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.MonadQuotation\">MonadQuotation</a> <a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L211-L216","name":"Lean.PrettyPrinter.Parenthesizer.visitArgs","line":211,"kind":"def","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.visitArgs","doc":"Execute `x` at the right-most child of the current node, if any, then advance to the left. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.visitArgs\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">Parenthesizer</span>.<span class=\"name\">visitArgs</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L208-L209","name":"Lean.PrettyPrinter.Parenthesizer.addPrecCheck","line":208,"kind":"def","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.addPrecCheck","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.addPrecCheck\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">Parenthesizer</span>.<span class=\"name\">addPrecCheck</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">prec</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L200-L204","name":"Lean.PrettyPrinter.Parenthesizer.instMonadTraverserParenthesizerM","line":200,"kind":"instance","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.instMonadTraverserParenthesizerM","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.instMonadTraverserParenthesizerM\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">Parenthesizer</span>.<span class=\"name\">instMonadTraverserParenthesizerM</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Syntax.html#Lean.Syntax.MonadTraverser\">Syntax.MonadTraverser</a> <a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L197-L198","name":"Lean.PrettyPrinter.Parenthesizer.throwBacktrack","line":197,"kind":"def","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.throwBacktrack","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer.throwBacktrack\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">Parenthesizer</span>.<span class=\"name\">throwBacktrack</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <span class=\"fn\">α</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L176-L190","name":"Lean.PrettyPrinter.combinatorParenthesizerAttribute","line":176,"kind":"opaque","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.combinatorParenthesizerAttribute","doc":"Registers a parenthesizer for a parser combinator.\n\n`@[combinator_parenthesizer c, expose]` registers a declaration of type `Lean.PrettyPrinter.Parenthesizer`\nfor the `Parser` declaration `c`. Note that, unlike with `@[parenthesizer]`, this is not a node kind\nsince combinators usually do not introduce their own node kinds. The tagged declaration may\noptionally accept parameters corresponding to (a prefix of) those of `c`, where `Parser` is\nreplaced with `Parenthesizer` in the parameter types.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.combinatorParenthesizerAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">combinatorParenthesizerAttribute</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/ParserCompiler/Attribute.html#Lean.ParserCompiler.CombinatorAttribute\">ParserCompiler.CombinatorAttribute</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L149-L174","name":"Lean.PrettyPrinter.categoryParenthesizerAttribute","line":149,"kind":"opaque","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.categoryParenthesizerAttribute","doc":"Registers a parenthesizer for a syntax category.\n\n`@[category_parenthesizer cat]` registers a declaration of type\n`Lean.PrettyPrinter.CategoryParenthesizer` for the syntax category `cat`, which is used when\nparenthesizing occurrences of `cat:prec` (`categoryParser cat prec`). Implementations should call\n`maybeParenthesize` with the precedence and `cat`. If no category parenthesizer is registered, the\ncategory will never be parenthesized, but still traversed for parenthesizing nested categories.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.categoryParenthesizerAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">categoryParenthesizerAttribute</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.CategoryParenthesizer\">CategoryParenthesizer</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L147-L147","name":"Lean.PrettyPrinter.CategoryParenthesizer","line":147,"kind":"def","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.CategoryParenthesizer","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.CategoryParenthesizer\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">CategoryParenthesizer</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L121-L145","name":"Lean.PrettyPrinter.parenthesizerAttribute","line":121,"kind":"opaque","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.parenthesizerAttribute","doc":"Registers a parenthesizer for a parser.\n\n`@[parenthesizer k]` registers a declaration of type `Lean.PrettyPrinter.Parenthesizer` to be used\nfor parenthesizing syntax of kind `k`.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.parenthesizerAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">parenthesizerAttribute</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.Parenthesizer\">Parenthesizer</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L119-L119","name":"Lean.PrettyPrinter.instOrElseParenthesizerM","line":119,"kind":"instance","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.instOrElseParenthesizerM","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.instOrElseParenthesizerM\"><span class=\"name\">Lean</span>.<span class=\"name\">PrettyPrinter</span>.<span class=\"name\">instOrElseParenthesizerM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#OrElse\">OrElse</a> <span class=\"fn\">(<a href=\"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM\">ParenthesizerM</a> <span class=\"fn\">α</span>)</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/PrettyPrinter/Parenthesizer.lean#L113-L117","name":"Lean.PrettyPrinter.ParenthesizerM.orElse","line":113,"kind":"def","docLink":"./Lean/PrettyPrinter/Parenthesizer.html#Lean.PrettyPrinter.ParenthesizerM.orElse","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\