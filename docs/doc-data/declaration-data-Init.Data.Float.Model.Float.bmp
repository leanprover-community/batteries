/Init/Data/Float/Model/Float.html#Float.Model.valid\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">valid</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Init/Data/Float/Model/Float.html#Float.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Float/Model/Format/Basic.html#Float.Model.Format.binary64\">Format.binary64</a>.<a href=\"./Init/Data/Float/Model/Format/Valid.html#Float.Model.Format.Valid\">Valid</a></span> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">self</span>.<a href=\"./Init/Data/Float/Model/Float.html#Float.Model.toBits\">toBits</a></span>.<a href=\"./Init/Prelude.html#UInt64.toBitVec\">toBitVec</a></span></span></div></div>","info":{"doc":"The underlying bit pattern is valid according to the IEEE `binary64` format. ","docLink":"./Init/Data/Float/Model/Float.html#Float.Model.valid","kind":"theorem","line":38,"name":"Float.Model.valid","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float.lean#L38-L38"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float.html#Float.Model.toBits\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">toBits</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Init/Data/Float/Model/Float.html#Float.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#UInt64\">UInt64</a></div></div>","info":{"doc":"The underlying bit pattern of the `Float.Model`. ","docLink":"./Init/Data/Float/Model/Float.html#Float.Model.toBits","kind":"def","line":36,"name":"Float.Model.toBits","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float.lean#L36-L36"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float.html#Float.Model.mk\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">(<span class=\"fn\">toBits</span> : <a href=\"./Init/Prelude.html#UInt64\">UInt64</a>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Float/Model/Format/Basic.html#Float.Model.Format.binary64\">Float.Model.Format.binary64</a>.<a href=\"./Init/Data/Float/Model/Format/Valid.html#Float.Model.Format.Valid\">Valid</a></span> <span class=\"fn\"><span class=\"fn\">toBits</span>.<a href=\"./Init/Prelude.html#UInt64.toBitVec\">toBitVec</a></span></span> → <a href=\"./Init/Data/Float/Model/Float.html#Float.Model\">Float.Model</a></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Model/Float.html#Float.Model.mk","kind":"ctor","line":18,"name":"Float.Model.mk","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float.lean#L18-L39"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float.html#Float.Model\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The logical model for the `Float` type.\n\nThis is defined as the type of `UInt64` with the additional restriction that bit patterns encoding\na `NaN` must be exactly a chosen canonical `NaN`.\n\nMost functions on `Float.Model` work by unpacking the `Float.Model` into the inductive type\n`UnpackedFloat`, performing the operation there, and then repacking the result into a `Float.Model`.\n\nIt is not a goal of this development to serve as the basis for a general-purpose floating-point\nlibrary or to have any direct lemmas written about it at all. Rather, users interested in a library\nabout floating-point numbers should develop such a library completely separately, and users\ninterested in proving properties of their programs involving `Float` should prove that the\noperations defined here are equivalent to the operations defined in the separate library and then\ntransfer lemmas from the library to the `Float` and `Float32` types.\n","docLink":"./Init/Data/Float/Model/Float.html#Float.Model","kind":"structure","line":18,"name":"Float.Model","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float.lean#L18-L39"}}],"imports":["Init.Data.Float.Model.Format.Valid","Init.Data.Float.Model.Unpacked.Operations","Init.Data.Float.Model.Unpacked.Pack.Lemmas","Init.Data.Order.Factories"],"instances":[{"className":"Decidable","name":"Float.instDecidableEqModel","typeNames":["Eq"]},{"className":"Add","name":"Float.Model.instAdd","typeNames":["Float.Model"]},{"className":"Sub","name":"Float.Model.instSub","typeNames":["Float.Model"]},{"className":"Mul","name":"Float.Model.instMul","typeNames":["Float.Model"]},{"className":"Div","name":"Float.Model.instDiv","typeNames":["Float.Model"]},{"className":"Neg","name":"Float.Model.instNeg","typeNames":["Float.Model"]},{"className":"LE","name":"Float.Model.instLE","typeNames":["Float.Model"]},{"className":"Decidable","name":"Float.Model.instDecidableLE","typeNames":["LE.le"]},{"className":"LT","name":"Float.Model.instLT","typeNames":["Float.Model"]},{"className":"Decidable","name":"Float.Model.instDecidableLT","typeNames":["LT.lt"]},{"className":"BEq","name":"Float.Model.instBEq","typeNames":["Float.Model"]},{"className":"Min","name":"Float.Model.instMin","typeNames":["Float.Model"]},{"className":"Max","name":"Float.Model.instMax","typeNames":["Float.Model"]},{"className":"Inhabited","name":"Float.Model.instInhabited","typeNames":["Float.Model"]}],"name":"Init.Data.Float.Model.Float"}