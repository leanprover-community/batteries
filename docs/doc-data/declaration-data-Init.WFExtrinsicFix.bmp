>PSigma</a> <span class=\"fn\">β</span></span>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">R</span> <span class=\"fn\">a'</span> <span class=\"fn\">p</span></span> → <span class=\"fn\"><span class=\"fn\">C₂</span> <span class=\"fn\"><span class=\"fn\">a'</span>.<a href=\"./Init/Core.html#PSigma.fst\">fst</a></span> <span class=\"fn\"><span class=\"fn\">a'</span>.<a href=\"./Init/Core.html#PSigma.snd\">snd</a></span></span></span></span>) =&gt;\n      <span class=\"fn\"><span class=\"fn\">F</span> <span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Init/Core.html#PSigma.fst\">fst</a></span> <span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Init/Core.html#PSigma.snd\">snd</a></span> <span class=\"fn\">fun (<span class=\"fn\">a'</span> : <span class=\"fn\">α</span>) (<span class=\"fn\">b'</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a'</span></span>) (<span class=\"fn\">hR</span> : <span class=\"fn\"><span class=\"fn\">R</span> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a'</span>, <span class=\"fn\">b'</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Init/Core.html#PSigma.fst\">fst</a></span>, <span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Init/Core.html#PSigma.snd\">snd</a></span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a></span>) =&gt; <span class=\"fn\"><span class=\"fn\">r</span> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a'</span>, <span class=\"fn\">b'</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a> <span class=\"fn\">hR</span></span></span></span>)</span>\n    <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a</span>, <span class=\"fn\">b</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a></span></div></div>","info":{"doc":"","docLink":"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix₂_eq_partialExtrinsicFix","kind":"theorem","line":385,"name":"WellFounded.partialExtrinsicFix₂_eq_partialExtrinsicFix","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/WFExtrinsicFix.lean#L385-L414"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix₂\"><span class=\"name\">WellFounded</span>.<span class=\"name\">partialExtrinsicFix₂</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Sort</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <a href=\"./foundational_types.html\">Sort</a> u_2</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C₂</span> : <span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span> → <a href=\"./foundational_types.html\">Sort</a> u_3</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">∀ (<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) (<span class=\"fn\">b</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span>), <span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <span class=\"fn\">(<span class=\"fn\">C₂</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span>)</span></span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">R</span> : <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) ×' <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span></span> → <span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) ×' <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span></span> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) → <span class=\"fn\">(<span class=\"fn\">b</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span>) → <span class=\"fn\"><span class=\"fn\">((<span class=\"fn\">a'</span> : <span class=\"fn\">α</span>) → <span class=\"fn\">(<span class=\"fn\">b'</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a'</span></span>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">R</span> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a'</span>, <span class=\"fn\">b'</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a</span>, <span class=\"fn\">b</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a></span> → <span class=\"fn\"><span class=\"fn\">C₂</span> <span class=\"fn\">a'</span> <span class=\"fn\">b'</span></span></span></span>)</span> → <span class=\"fn\"><span class=\"fn\">C₂</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">b</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">C₂</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"A 2-ary fixpoint combinator that can be used to construct recursive functions with an\n**extrinsic, partial** proof of termination.\n\nGiven a relation `R` and a fixpoint functional `F` which must be decreasing with respect\nto `R`, `partialExtrinsicFix₂ R F` is the recursive function obtained by having `F` call\nitself recursively.\n\nFor each pair of inputs `a` and `b`, `partialExtrinsicFix₂ R F a b` can be verified\ngiven a **partial** termination proof. The precise semantics are as follows.\n\nIf `Acc R ⟨a, b⟩ ` does not hold, `partialExtrinsicFix₂ R F a b` might run forever. In this\ncase, nothing interesting can be proved about the recursive function; it is opaque and behaves like\na recursive function with the `partial` modifier.\n\nIf `Acc R ⟨a, b⟩` *does* hold, `partialExtrinsicFix₂ R F a b` is equivalent to\n`F a b (fun a' b' _ => partialExtrinsicFix₂ R F a' b')`, both logically and regarding its\ntermination behavior.\n\nIn particular, if `R` is well-founded, `partialExtrinsicFix₂ R F a b` is equivalent to\na well-foundesd fixpoint.\n","docLink":"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix₂","kind":"def","line":347,"name":"WellFounded.partialExtrinsicFix₂","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/WFExtrinsicFix.lean#L347-L383"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix_eq_fix\"><span class=\"name\">WellFounded</span>.<span class=\"name\">partialExtrinsicFix_eq_fix</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Sort</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <a href=\"./foundational_types.html\">Sort</a> u_1</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">∀ (<span class=\"fn\">a</span> : <span class=\"fn\">α</span>), <span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <span class=\"fn\">(<span class=\"fn\">C</span> <span class=\"fn\">a</span>)</span></span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">R</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\">α</span> → <a href=\"./foundational_types.html\">Prop</a></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> : <span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) → <span class=\"fn\"><span class=\"fn\">((<span class=\"fn\">a'</span> : <span class=\"fn\">α</span>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">R</span> <span class=\"fn\">a'</span> <span class=\"fn\">a</span></span> → <span class=\"fn\"><span class=\"fn\">C</span> <span class=\"fn\">a'</span></span></span>)</span> → <span class=\"fn\"><span class=\"fn\">C</span> <span class=\"fn\">a</span></span></span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">wf</span> : <span class=\"fn\"><a href=\"./Init/WF.html#WellFounded\">WellFounded</a> <span class=\"fn\">R</span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">a</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix\">partialExtrinsicFix</a> <span class=\"fn\">R</span> <span class=\"fn\">F</span> <span class=\"fn\">a</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">wf</span>.<a href=\"./Init/WF.html#WellFounded.fix\">fix</a></span> <span class=\"fn\">F</span> <span class=\"fn\">a</span></span></div></div>","info":{"doc":"","docLink":"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix_eq_fix","kind":"theorem","line":337,"name":"WellFounded.partialExtrinsicFix_eq_fix","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/WFExtrinsicFix.lean#L337-L345"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix_eq_apply\"><span class=\"name\">WellFounded</span>.<span class=\"name\">partialExtrinsicFix_eq_apply</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Sort</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <a href=\"./foundational_types.html\">Sort</a> u_1</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">∀ (<span class=\"fn\">a</span> : <span class=\"fn\">α</span>), <span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <span class=\"fn\">(<span class=\"fn\">C</span> <span class=\"fn\">a</span>)</span></span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">R</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\">α</span> → <a href=\"./foundational_types.html\">Prop</a></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> : <span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) → <span class=\"fn\"><span class=\"fn\">((<span class=\"fn\">a'</span> : <span class=\"fn\">α</span>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">R</span> <span class=\"fn\">a'</span> <span class=\"fn\">a</span></span> → <span class=\"fn\"><span class=\"fn\">C</span> <span class=\"fn\">a'</span></span></span>)</span> → <span class=\"fn\"><span class=\"fn\">C</span> <span class=\"fn\">a</span></span></span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">a</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">wf</span> : <span class=\"fn\"><a href=\"./Init/WF.html#WellFounded\">WellFounded</a> <span class=\"fn\">R</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix\">partialExtrinsicFix</a> <span class=\"fn\">R</span> <span class=\"fn\">F</span> <span class=\"fn\">a</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">F</span> <span class=\"fn\">a</span> <span class=\"fn\">fun (<span class=\"fn\">a'</span> : <span class=\"fn\">α</span>) (<span class=\"fn\">x</span> : <span class=\"fn\"><span class=\"fn\">R</span> <span class=\"fn\">a'</span> <span class=\"fn\">a</span></span>) =&gt; <span class=\"fn\"><a href=\"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix\">partialExtrinsicFix</a> <span class=\"fn\">R</span> <span class=\"fn\">F</span> <span class=\"fn\">a'</span></span></span></span></div></div>","info":{"doc":"","docLink":"./Init/WFExtrinsicFix.html#WellFounded.partialExtrinsicFix_eq_apply","kind":"theorem","line":332,"name":"WellFounded.partialExtrinsicFix_eq_apply","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/WFExtrinsicFix.lean#L332-L335"}},{"header":"<div class=\"decl_header\"><spa