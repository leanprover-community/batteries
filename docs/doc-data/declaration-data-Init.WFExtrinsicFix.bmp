></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> :\n  <span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>) →\n    <span class=\"fn\">(<span class=\"fn\">b</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a</span></span>) →\n      <span class=\"fn\">(<span class=\"fn\">c</span> : <span class=\"fn\"><span class=\"fn\">γ</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span>) → <span class=\"fn\"><span class=\"fn\">((<span class=\"fn\">a'</span> : <span class=\"fn\">α</span>) → <span class=\"fn\">(<span class=\"fn\">b'</span> : <span class=\"fn\"><span class=\"fn\">β</span> <span class=\"fn\">a'</span></span>) → <span class=\"fn\">(<span class=\"fn\">c'</span> : <span class=\"fn\"><span class=\"fn\">γ</span> <span class=\"fn\">a'</span> <span class=\"fn\">b'</span></span>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">R</span> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a'</span>, <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">b'</span>, <span class=\"fn\">c'</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a><a href=\"./Init/Core.html#PSigma.mk\">⟩</a> <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">a</span>, <a href=\"./Init/Core.html#PSigma.mk\">⟨</a><span class=\"fn\">b</span>, <span class=\"fn\">c</span><a href=\"./Init/Core.html#PSigma.mk\">⟩</a><a href=\"./Init/Core.html#PSigma.mk\">⟩</a></span> → <span class=\"fn\"><span class=\"fn\">C₃</span> <span class=\"fn\">a'</span> <span class=\"fn\">b'</span> <span class=\"fn\">c'</span></span></span></span></span>)</span> → <span class=\"fn\"><span class=\"fn\">C₃</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span> <span class=\"fn\">c</span></span></span></span></span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">wf</span> : <span class=\"fn\"><a href=\"./Init/W