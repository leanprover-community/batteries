ypeNames":["Lean.NameMap"]},{"className":"Lean.FromJson","name":"Lean.instFromJsonUSize","typeNames":["USize"]},{"className":"Lean.ToJson","name":"Lean.instToJsonUSize","typeNames":["USize"]},{"className":"Lean.FromJson","name":"Lean.instFromJsonUInt64","typeNames":["UInt64"]},{"className":"Lean.ToJson","name":"Lean.instToJsonUInt64","typeNames":["UInt64"]},{"className":"Lean.ToJson","name":"Lean.instToJsonFloat","typeNames":["Float"]},{"className":"Lean.FromJson","name":"Lean.instFromJsonFloat","typeNames":["Float"]},{"className":"Lean.FromJson","name":"Lean.Json.instFromJsonStructured","typeNames":["Lean.Json.Structured"]},{"className":"Lean.ToJson","name":"Lean.Json.instToJsonStructured","typeNames":["Lean.Json.Structured"]}],"name":"Lean.Data.Json.FromToJson.Basic"}