urceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Main.lean#L58-L67"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.Params\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Params</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.Params","kind":"structure","line":58,"name":"Lean.Meta.Grind.Params","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Main.lean#L58-L67"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.getLiaExtensions\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">getLiaExtensions</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> <a href=\"./Lean/Meta/Tactic/Grind/Extension.html#Lean.Meta.Grind.ExtensionStateArray\">ExtensionStateArray</a></span></div></div>","info":{"doc":"Returns the extensions used by the `lia` tactic.\n\n`lia` keeps the structural part of the default `grind` attribute (cases types, `funCC`,\nand extensionality theorems), but instead of the full `@[grind]` E-matching lemma set it\nonly uses the dedicated `@[lia]` lemma set. This lets `cutsat` benefit from a small amount\nof instantiation (e.g. `Nat.max_def`) without pulling in everything tagged `@[grind]`.\n","docLink":"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.getLiaExtensions","kind":"def","line":47,"name":"Lean.Meta.Grind.getLiaExtensions","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Main.lean#L47-L56"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.getOnlyExtensionState\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">getOnlyExtensionState</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> <a href=\"./Lean/Meta/Tactic/Grind/Extension.html#Lean.Meta.Grind.ExtensionState\">ExtensionState</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.getOnlyExtensionState","kind":"def","line":38,"name":"Lean.Meta.Grind.getOnlyExtensionState","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Main.lean#L38-L45"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.getDefaultExtensionState\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">getDefaultExtensionState</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> <a href=\"./Lean/Meta/Tactic/Grind/Extension.html#Lean.Meta.Grind.ExtensionState\">ExtensionState</a></span></div></div>","info":{"doc":"Returns the `ExtensionState` for the default `grind` attribute.\n","docLink":"./Lean/Meta/Tactic/Grind/Main.html#Lean.Meta.Grind.getDefaultExtensionSta