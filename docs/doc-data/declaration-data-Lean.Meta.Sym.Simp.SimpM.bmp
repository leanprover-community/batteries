"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.MethodsRef\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">MethodsRef</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.MethodsRef","kind":"def","line":159,"name":"Lean.Meta.Sym.Simp.MethodsRef","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L159-L159"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedResult.default\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">instInhabitedResult</span>.<span class=\"name\">default</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedResult.default","kind":"def","line":156,"name":"Lean.Meta.Sym.Simp.instInhabitedResult.default","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L156-L156"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedResult\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">instInhabitedResult</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedResult","kind":"instance","line":156,"name":"Lean.Meta.Sym.Simp.instInhabitedResult","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L156-L156"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.step\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span>.<span class=\"name\">step</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e' </span><span class=\"fn\">proof</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">done</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.false\">false</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"Simplified to `e'` with proof `proof : e = e'`.\nIf `done = true`, skip recursive simplification of `e'`. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.step","kind":"ctor","line":152,"name":"Lean.Meta.Sym.Simp.Result.step","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L152-L155"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.rfl\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span>.<span class=\"name\">rfl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">done</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.false\">false</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"No change. If `done = true`, skip remaining simplification steps for this term. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.rfl","kind":"ctor","line":150,"name":"Lean.Meta.Sym.Simp.Result.rfl","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L150-L151"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The result of simplifying an expression `e`.\n\nThe `done` flag controls whether simplification should continue after this result:\n- `done = false` (default): Continue with subsequent simplification steps\n- `done = true`: Stop processing, return this result as final\n\n## Use cases for `done = true`\n\n### In `pre` simprocs\nSkip simplification of certain subterms entirely:\n```\ndef skipLambdas : Simproc := fun e =>\n  if e.isLambda then return .rfl (done := true)\n  else return .rfl\n```\n\n### In `post` simprocs\nPerform single-pass normalization without recursive simplification:\n```\ndef singlePassNormalize : Simproc := fun e =>\n  if let some (e', h) ← tryNormalize e then\n    return .step e' h (done := true)\n  else return .rfl\n```\nWith `done = true`, the result `e'` won't be recursively simplified.\n\n## Behavior\n\nThe `done` flag affects:\n1. **`andThen` composition**: If the first simproc returns `done = true`,\n   the second simproc is skipped.\n2. **Recursive simplification**: After `pre` or `post` returns `.step e' h`,\n   `simp` normally recurses on `e'`. With `done = true`, recursion is skipped.\n\nThe flag is orthogonal to caching: both `.rfl` and `.step` results are cached\nregardless of the `done` flag, and cached results are always treated as final.\n","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result","kind":"inductive","line":111,"name":"Lean.Meta.Sym.Simp.Result","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L111-L156"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxDischargeDepth\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span>.<span class=\"name\">maxDischargeDepth</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Maximum depth of reentrant simplifier calls through dischargers.\nPrevents infinite loops when conditional rewrite rules trigger recursive discharge attempts.\n","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxDischargeDepth","kind":"def","line":109,"name":"Lean.Meta.Sym.Simp.Config.maxDischargeDepth","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L109-L109"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxSteps\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span>.<span class=\"name\">maxSteps</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Maximum number of steps that can be performed by the simplifier. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxSteps","kind":"def","line":104,"name":"Lean.Meta.Sym.Simp.Config.maxSteps","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L104-L104"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">maxSteps </span><span class=\"fn\">maxDischargeDepth</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.mk","kind":"ctor","line":102,"name":"Lean.Meta.Sym.Simp.Config.mk","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L102-L102"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Configuration options for the structural simplifier. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config","kind":"structure","line":101,"name":"Lean.Meta.Sym.Simp.Config","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Lean/Meta/Sym/Simp/SimpM.lean#L101-L109"}}],"imports":["Lean.Meta.Sym.SymM","Lean.Meta.Sym.Pattern"],"instances":[{"className":"Inhabited","name":"Lean.Meta.Sym.Simp.instInhabitedResult","typeNames":["Lean.Meta.Sym.Simp.Result"]},{"className":"Nonempty","name":"Lean.Meta.Sym.Simp.instNonemptyMethodsRef","typeNames":["Lean.Meta.Sym.Simp.MethodsRef"]},{"className":"Inhabited","name":"Lean.Meta.Sym.Simp.instInhabitedSimpM","typeNames":["Lean.Meta.Sym.Simp.SimpM"]},{"className":"Inhabited","name":"Lean.Meta.Sym.Simp.instInhabitedMethods","typeNames":["Lean.Meta.Sym.Simp.Methods"]}],"name":"Lean.Meta.Sym.Simp.SimpM"}