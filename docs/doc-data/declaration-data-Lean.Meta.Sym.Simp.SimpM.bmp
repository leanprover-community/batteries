"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context.config\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Context</span>.<span class=\"name\">config</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a></div></div>","info":{"doc":"Simplifier configuration options. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context.config","kind":"def","line":202,"name":"Lean.Meta.Sym.Simp.Context.config","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L202-L202"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Context</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Lean.Meta.Sym.Simp.Config</a> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context\">Lean.Meta.Sym.Simp.Context</a></span></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context.mk","kind":"ctor","line":199,"name":"Lean.Meta.Sym.Simp.Context.mk","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L199-L206"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Context</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Read-only context for the simplifier. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Context","kind":"structure","line":199,"name":"Lean.Meta.Sym.Simp.Context","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L199-L206"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instNonemptyMethodsRef\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">instNonemptyMethodsRef</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.MethodsRef\">MethodsRef</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instNonemptyMethodsRef","kind":"instance","line":197,"name":"Lean.Meta.Sym.Simp.instNonemptyMethodsRef","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L197-L197"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.MethodsRef\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">MethodsRef</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.MethodsRef","kind":"def","line":196,"name":"Lean.Meta.Sym.Simp.MethodsRef","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L196-L196"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.withContextDependent\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span>.<span class=\"name\">withContextDependent</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a> → <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></span></div></div>","info":{"doc":"Marks a result as context-dependent. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.withContextDependent","kind":"def","line":190,"name":"Lean.Meta.Sym.Simp.Result.withContextDependent","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L190-L193"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.isContextDependent\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span>.<span class=\"name\">isContextDependent</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Returns `true` if this result depends on the local context (e.g., hypotheses). ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.isContextDependent","kind":"def","line":186,"name":"Lean.Meta.Sym.Simp.Result.isContextDependent","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L186-L188"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.mkRflResultCD\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">mkRflResultCD</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">contextDependent</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"Like `mkRflResult` with `done := false`. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.mkRflResultCD","kind":"def","line":182,"name":"Lean.Meta.Sym.Simp.mkRflResultCD","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L182-L184"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.mkRflResult\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">mkRflResult</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">done </span><span class=\"fn\">contextDependent</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.false\">false</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"Pre-computed `.rfl` results to avoid dynamic memory allocation.\nEach combination of `done` and `contextDependent` maps to a compile-time constant.\n","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.mkRflResult","kind":"def","line":171,"name":"Lean.Meta.Sym.Simp.mkRflResult","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L171-L180"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedResult\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">instInhabitedResult</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedResult","kind":"instance","line":169,"name":"Lean.Meta.Sym.Simp.instInhabitedResult","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L169-L169"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.step\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span>.<span class=\"name\">step</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e' </span><span class=\"fn\">proof</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">done </span><span class=\"fn\">contextDependent</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.false\">false</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"Simplified to `e'` with proof `proof : e = e'`.\nIf `done = true`, skip recursive simplification of `e'`. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.step","kind":"ctor","line":165,"name":"Lean.Meta.Sym.Simp.Result.step","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L165-L168"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.rfl\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span>.<span class=\"name\">rfl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">done </span><span class=\"fn\">contextDependent</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.false\">false</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\">Result</a></div></div>","info":{"doc":"No change. If `done = true`, skip remaining simplification steps for this term. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result.rfl","kind":"ctor","line":163,"name":"Lean.Meta.Sym.Simp.Result.rfl","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L163-L164"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Result</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The result of simplifying an expression `e`.\n\nThe `done` flag controls whether simplification should continue after this result:\n- `done = false` (default): Continue with subsequent simplification steps\n- `done = true`: Stop processing, return this result as final\n\n## Use cases for `done = true`\n\n### In `pre` simprocs\nSkip simplification of certain subterms entirely:\n```\ndef skipLambdas : Simproc := fun e =>\n  if e.isLambda then return .rfl (done := true)\n  else return .rfl\n```\n\n### In `post` simprocs\nPerform single-pass normalization without recursive simplification:\n```\ndef singlePassNormalize : Simproc := fun e =>\n  if let some (e', h) ← tryNormalize e then\n    return .step e' h (done := true)\n  else return .rfl\n```\nWith `done = true`, the result `e'` won't be recursively simplified.\n\n## Behavior\n\nThe `done` flag affects:\n1. **`andThen` composition**: If the first simproc returns `done = true`,\n   the second simproc is skipped.\n2. **Recursive simplification**: After `pre` or `post` returns `.step e' h`,\n   `simp` normally recurses on `e'`. With `done = true`, recursion is skipped.\n\nThe flag is orthogonal to caching: both `.rfl` and `.step` results are cached\nregardless of the `done` flag, and cached results are always treated as final.\n\n## Context-dependent results\n\nThe `contextDependent` flag tracks whether the result depends on the local context\n(e.g., hypotheses introduced when entering binders). Context-dependent results are\nstored in a transient cache that is cleared when entering binders, while\ncontext-independent results persist across binder entry and across `simp` invocations.\n\n**Propagation rule**: when combining sub-results (congruence, transitivity, etc.),\n`contextDependent` is the disjunction of all sub-results' flags. This includes\n`.rfl` results: if `simp` returned `.rfl (contextDependent := true)`, it means\n`simp` might produce a *different* result in another local context (e.g., a conditional\nrewrite could succeed), so all downstream results must be marked context-dependent.\n","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Result","kind":"inductive","line":111,"name":"Lean.Meta.Sym.Simp.Result","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L111-L169"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedConfig\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">instInhabitedConfig</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.instInhabitedConfig","kind":"instance","line":109,"name":"Lean.Meta.Sym.Simp.instInhabitedConfig","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L109-L109"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxDischargeDepth\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span>.<span class=\"name\">maxDischargeDepth</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Maximum depth of reentrant simplifier calls through dischargers.\nPrevents infinite loops when conditional rewrite rules trigger recursive discharge attempts.\n","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxDischargeDepth","kind":"def","line":108,"name":"Lean.Meta.Sym.Simp.Config.maxDischargeDepth","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L108-L108"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxSteps\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span>.<span class=\"name\">maxSteps</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Config</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Maximum number of steps that can be performed by the simplifier. ","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.maxSteps","kind":"def","line":103,"name":"Lean.Meta.Sym.Simp.Config.maxSteps","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L103-L103"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">Simp</span>.<span class=\"name\">Config</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config\">Lean.Meta.Sym.Simp.Config</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.Config.mk","kind":"ctor","line":100,"name":"Lean.Meta.Sym.Simp.Config.mk","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Simp/SimpM.lean#L100-L109"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"br