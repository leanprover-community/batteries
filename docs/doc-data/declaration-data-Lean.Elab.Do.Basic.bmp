n><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElems1","kind":"opaque","line":825,"name":"Lean.Elab.Do.elabDoElems1","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/Elab/Do/Basic.lean#L825-L835"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElem\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">elabDoElem</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.TSyntax\">TSyntax</a> <span class=\"fn\">`doElem</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cont</span> : <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElemCont\">DoElemCont</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">catchExPostpone</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.true\">true</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElem","kind":"opaque","line":797,"name":"Lean.Elab.Do.elabDoElem","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/Elab/Do/Basic.lean#L797-L823"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.doElemElabAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">doElemElabAttribute</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElab\">DoElab</a></span></div></div>","info":{"doc":"Registers a `do` element elaborator for the given syntax node kind.\n\nA `do` element elaborator should have type `DoElab` (which is\n`Lean.Syntax → DoElemCont → DoElabM Expr`), i.e. should take syntax of the given syntax node kind\nand a `DoElemCont` as parameters and produce an expression.\n\nWhen elaborating a `do` block `do e; rest`, the elaborator for `e` is invoked with the syntax of `e`\nand the `DoElemCont` representing `rest`.\n\nThe `elab_rules` and `elab` commands should usually be preferred over using this attribute\ndirectly.\n","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.doElemElabAttribute","kind":"opaque","line":749,"name":"Lean.Elab.Do.doElemElabAttribute","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/Elab/Do/Basic.lean#L749-L763"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">mkDoElemElabAttribute</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ref</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <span class=\"fn\">(<a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElab\">DoElab</a>)</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttribute","kind":"opaque","line":746,"name":"Lean.Elab.Do.mkDoElemElabAttribute","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/Elab/Do/Basic.lean#L746-L747"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">unsafe def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttributeUnsafe\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">mkDoElemElabAttributeUnsafe</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ref</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <span class=\"fn\">(<a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElab\">DoElab</a>)</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttributeUnsafe","kind":"def","line":743,"name":"Lean.Elab.Do.mkDoElemElabAttributeUnsafe","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/Elab/Do/Basic.lean#L743-L744"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.expandNestedActions\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">expandNestedActions</span></a></span><span class=\"impl_arg\"><sp