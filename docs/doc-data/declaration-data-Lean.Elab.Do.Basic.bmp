c.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoSeq","kind":"opaque","line":1006,"name":"Lean.Elab.Do.elabDoSeq","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L1006-L1018"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElems1\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">elabDoElems1</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">doElems</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Meta/Defs.html#Lean.Syntax.DoElem\">DoElem</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cont</span> : <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElemCont\">DoElemCont</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">catchExPostpone</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.true\">true</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElems1","kind":"opaque","line":993,"name":"Lean.Elab.Do.elabDoElems1","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L993-L1003"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElem\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">elabDoElem</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.DoElem\">DoElem</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cont</span> : <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElemCont\">DoElemCont</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">catchExPostpone</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.true\">true</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.elabDoElem","kind":"opaque","line":965,"name":"Lean.Elab.Do.elabDoElem","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L965-L991"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.doElemElabAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">doElemElabAttribute</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElab\">DoElab</a></span></div></div>","info":{"doc":"Registers a `do` element elaborator for the given syntax node kind.\n\nA `do` element elaborator should have type `DoElab` (which is\n`Lean.Syntax → DoElemCont → DoElabM Expr`), i.e. should take syntax of the given syntax node kind\nand a `DoElemCont` as parameters and produce an expression.\n\nWhen elaborating a `do` block `do e; rest`, the elaborator for `e` is invoked with the syntax of `e`\nand the `DoElemCont` representing `rest`.\n\nThe `elab_rules` and `elab` commands should usually be preferred over using this attribute\ndirectly.\n","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.doElemElabAttribute","kind":"opaque","line":917,"name":"Lean.Elab.Do.doElemElabAttribute","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L917-L931"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttribute\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">mkDoElemElabAttribute</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ref</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <span class=\"fn\">(<a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElab\">DoElab</a>)</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttribute","kind":"opaque","line":914,"name":"Lean.Elab.Do.mkDoElemElabAttribute","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L914-L915"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">unsafe def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttributeUnsafe\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">mkDoElemElabAttributeUnsafe</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ref</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <span class=\"fn\">(<a href=\"./Lean/KeyedDeclsAttribute.html#Lean.KeyedDeclsAttribute\">KeyedDeclsAttribute</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElab\">DoElab</a>)</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkDoElemElabAttributeUnsafe","kind":"def","line":911,"name":"Lean.Elab.Do.mkDoElemElabAttributeUnsafe","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L911-L912"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.expandNestedActions\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">expandNestedActions</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">kind</span> : <a href=\"./Init/Prelude.html#Lean.SyntaxNodeKinds\">SyntaxNodeKinds</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.TSyntax\">TSyntax</a> <span class=\"fn\">kind</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> (<span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Meta/Defs.html#Lean.Syntax.DoElem\">DoElem</a></span> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.TSyntax\">TSyntax</a> <span class=\"fn\">kind</span></span>)</span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.expandNestedActions","kind":"def","line":901,"name":"Lean.Elab.Do.expandNestedActions","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L901-L907"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkContext\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">mkContext</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">expectedType?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ops</span> : <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoOps\">DoOps</a> := <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoOps.default\">DoOps.default</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.Context\">Context</a></span></div></div>","info":{"doc":"Create the `Context` for `do` elaboration from the given expected type of a `do` block. ","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.mkContext","kind":"def","line":797,"name":"Lean.Elab.Do.mkContext","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L797-L803"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.enterFinally\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">enterFinally</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">resultType</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Prepare the context for elaborating the body of a `finally` block.\nThere is no support for `mut` vars, `break`, `continue` or `return` in a `finally` block.\n","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.enterFinally","kind":"def","line":761,"name":"Lean.Elab.Do.enterFinally","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L761-L767"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.withoutControl\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">withoutControl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Prepare the context for elaborating the body of a `do` block that does not support `mut` vars,\n`break`, `continue` or `return`.\n","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.withoutControl","kind":"def","line":750,"name":"Lean.Elab.Do.withoutControl","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L750-L759"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.enterLoopBody\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">enterLoopBody</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">breakCont </span><span class=\"fn\">continueCont</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">returnCont</span> : <a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.ReturnCont\">ReturnCont</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">body</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Prepare the context for elaborating the body of a loop.\nThis includes setting the return continuation, break continuation, continue continuation, as\nwell as the changed result type of the `do` block in the loop body.\n","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.enterLoopBody","kind":"def","line":741,"name":"Lean.Elab.Do.enterLoopBody","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L741-L748"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.withRefinedResultType\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">withRefinedResultType</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">doBlockResultType</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Refine the result type of the `do` block and its `return` continuation for the scope of `k`,\nas needed for a dependent `match` branch where a bare `return` targets the refined branch type.\n\nRelies on the `return` continuation result type coinciding with the `do` block result type, which\nholds for the tail-position dependent `match` this serves.\n","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.withRefinedResultType","kind":"def","line":729,"name":"Lean.Elab.Do.withRefinedResultType","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L729-L739"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.withDoBlockResultType\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">withDoBlockResultType</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">doBlockResultType</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.DoElabM\">DoElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Set the new `do` block result type for the scope of the continuation `k`. ","docLink":"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.withDoBlockResultType","kind":"def","line":724,"name":"Lean.Elab.Do.withDoBlockResultType","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Do/Basic.lean#L724-L727"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Do/Basic.html#Lean.Elab.Do.getContinueCont\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Do</span>.<span class=\"name\">getContinueCont</span></a></span><span class=\"decl_args\"