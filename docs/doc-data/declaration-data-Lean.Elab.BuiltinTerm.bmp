prover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/BuiltinTerm.lean#L187-L199"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.shouldElabEmptyByAsTry\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Term</span>.<span class=\"name\">shouldElabEmptyByAsTry</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Returns `true` if all conditions are met for empty `by` to be elaborated as `try?`:\nthe body is empty, the option is enabled, we are in an interactive (non-combinator) context,\nand the `try?` infrastructure (parser `Lean.Parser.Tactic.tryTrace`) is available — the latter\nmatters when working on the prelude, before `Init.Try` is imported. ","docLink":"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.shouldElabEmptyByAsTry","kind":"def","line":177,"name":"Lean.Elab.Term.shouldElabEmptyByAsTry","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/BuiltinTerm.lean#L177-L185"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.isEmptyByBlock\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Term</span>.<span class=\"name\">isEmptyByBlock</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Returns `true` if `stx` is a `by` expression with an empty tactic body\n(not a parse error producing `.missing`).\nThe structure is: `node byTactic [atom \"by\", node tacticSeq [node tacticSeq1Indented [node null []]]]` ","docLink":"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.isEmptyByBlock","kind":"def","line":166,"name":"Lean.Elab.Term.isEmptyByBlock","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/BuiltinTerm.lean#L166-L175"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.tactic.tryOnEmptyBy\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Term</span>.<span class=\"name\">tactic</span>.<span class=\"name\">tryOnEmptyBy</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.tactic.tryOnEmptyBy","kind":"opaque","line":160,"name":"Lean.Elab.Term.tactic.tryOnEmptyBy","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/BuiltinTerm.lean#L160-L164"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/BuiltinTerm.html#Lean.Elab.Term.elabWaitIfContainsMVar\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Term</span>.<span class=\"name\">elabWaitIfContainsMVar</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.E