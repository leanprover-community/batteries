html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Returns `true` if `e` is the internalized `Bool.true` expression.  ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isBoolTrueExpr","kind":"def","line":323,"name":"Lean.Meta.Sym.isBoolTrueExpr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L323-L324"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getBoolTrueExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">getBoolTrueExpr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Returns the internalized `Bool.true`.  ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getBoolTrueExpr","kind":"def","line":321,"name":"Lean.Meta.Sym.getBoolTrueExpr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L321-L322"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isFalseExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">isFalseExpr</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Bool\">Bool</