\">σ</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymExtension.getStateCore","kind":"opaque","line":532,"name":"Lean.Meta.Sym.SymExtension.getStateCore","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L532-L533"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.instInhabitedSymM\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">instInhabitedSymM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <span class=\"fn\">(<a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <span class=\"fn\">α</span>)</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.instInhabitedSymM","kind":"instance","line":524,"name":"Lean.Meta.Sym.instInhabitedSymM","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L524-L525"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isDefEqI\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">isDefEqI</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s </span><span class=\"fn\">t</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Similar to `Meta.isDefEqI`, but the result is cache using pointer equality. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isDefEqI","kind":"def","line":515,"name":"Lean.Meta.Sym.isDefEqI","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L515-L522"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.withNewIssueContext\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">withNewIssueContext</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Runs `x` with a fresh issue context. Issues reported during `x` are\nprepended to the issues that existed before the call.\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.withNewIssueContext","kind":"def","line":506,"name":"Lean.Meta.Sym.withNewIssueContext","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L506-L513"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getIssues\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">getIssues</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> <a href=\"./Lean/Message.html#Lean.MessageData\">MessageData</a>)</span></span></div></div>","info":{"doc":"Returns all accumulated issues without clearing them. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getIssues","kind":"def","line":502,"name":"Lean.Meta.Sym.getIssues","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L502-L504"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.doElemReportDbgIssue!__\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">doElemReportDbgIssue!__</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">ParserDescr</a></div></div>","info":{"doc":"Similar to `reportIssue!`, but only reports issue if `sym.debug` is set to `true`. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.doElemReportDbgIssue!__","kind":"def","line":499,"name":"Lean.Meta.Sym.doElemReportDbgIssue!__","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L499-L500"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.expandReportDbgIssueMacro\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">expandReportDbgIssueMacro</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.MacroM\">MacroM</a> <a href=\"./Init/Meta/Defs.html#Lean.Syntax.DoElem\">DoElem</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.expandReportDbgIssueMacro","kind":"def","line":494,"name":"Lean.Meta.Sym.expandReportDbgIssueMacro","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L494-L496"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.reportDbgIssue\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">reportDbgIssue</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">msg</span> : <a href=\"./Lean/Message.html#Lean.MessageData\">MessageData</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Reports an issue if both `verbose` and `sym.debug` are enabled. Does nothing otherwise. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.reportDbgIssue","kind":"def","line":488,"name":"Lean.Meta.Sym.reportDbgIssue","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L488-L492"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.doElemReportIssue!__\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">doElemReportIssue!__</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">ParserDescr</a></div></div>","info":{"doc":"Reports an issue if `verbose` mode is enabled. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.doElemReportIssue!__","kind":"def","line":485,"name":"Lean.Meta.Sym.doElemReportIssue!__","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L485-L486"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.reportIssueIfVerbose\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">reportIssueIfVerbose</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">msg</span> : <a href=\"./Lean/Message.html#Lean.MessageData\">MessageData</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Reports an issue if `verbose` mode is enabled. Does nothing if `verbose` is `false`. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.reportIssueIfVerbose","kind":"def","line":475,"name":"Lean.Meta.Sym.reportIssueIfVerbose","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L475-L478"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.reportIssue\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">reportIssue</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">msg</span> : <a href=\"./Lean/Message.html#Lean.MessageData\">MessageData</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Adds an issue message to the issue tracker. ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.reportIssue","kind":"def","line":469,"name":"Lean.Meta.Sym.reportIssue","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L469-L473"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getConfig\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">getConfig</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.Config\">Config</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getConfig","kind":"def","line":466,"name":"Lean.Meta.Sym.getConfig","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L466-L467"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isDebugEnabled\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">isDebugEnabled</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Returns `true` if `sym.debug` is set ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isDebugEnabled","kind":"def","line":462,"name":"Lean.Meta.Sym.isDebugEnabled","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L462-L464"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.share\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">share</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Incremental variant of `shareCommon` for expressions constructed from already-shared subterms.\n\nUse this when an expression `e` was produced by a Lean API (e.g., `inferType`, `mkApp4`) that\ndoes not preserve maximal sharing, but the inputs to that API were already maximally shared.\n\nUnlike `shareCommon`, this function does not use a local `Std.HashMap ExprPtr Expr` to\ntrack visited nodes. This is more efficient when the number of new (unshared) nodes is small,\nwhich is the common case when wrapping API calls that build a few constructor nodes around\nshared inputs.\n\nExample:\n```\n-- `a` and `b` are already maximally shared\nlet result := mkApp2 f a b  -- result is not maximally shared\nlet result ← shareCommonInc result -- efficiently restore sharing\n```\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.share","kind":"def","line":458,"name":"Lean.Meta.Sym.share","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L458-L460"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.shareCommonInc\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">shareCommonInc</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Incremental variant of `shareCommon` for expressions constructed from already-shared subterms.\n\nUse this when an expression `e` was produced by a Lean API (e.g., `inferType`, `mkApp4`) that\ndoes not preserve maximal sharing, but the inputs to that API were already maximally shared.\n\nUnlike `shareCommon`, this function does not use a local `Std.HashMap ExprPtr Expr` to\ntrack visited nodes. This is more efficient when the number of new (unshared) nodes is small,\nwhich is the common case when wrapping API calls that build a few constructor nodes around\nshared inputs.\n\nExample:\n```\n-- `a` and `b` are already maximally shared\nlet result := mkApp2 f a b  -- result is not maximally shared\nlet result ← shareCommonInc result -- efficiently restore sharing\n```\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.shareCommonInc","kind":"def","line":431,"name":"Lean.Meta.Sym.shareCommonInc","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L431-L456"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.shareCommon\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">shareCommon</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Applies hash-consing to `e`. Recall that all expressions in a `grind` goal have\nbeen hash-consed. We perform this step before we internalize expressions.\n\nDepending on the current configuration, this function also maintains the `SymM`\ninvariants that reducible constants have been unfolded and kernel projections folded.\nThe checks are node-local and are only performed on terms that have not been\nhash-consed before, so already-shared subterms cost nothing. When a violation is\nfound, the term is repaired using `unfoldReducible`/`foldProjs` and re-processed.\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.shareCommon","kind":"def","line":416,"name":"Lean.Meta.Sym.shareCommon","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L416-L429"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.shareCommonWithoutChecks\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">shareCommonWithoutChecks</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cache</span> : <a href=\"./Lean/Meta/Sym/AlphaShareCommon.html#Lean.Meta.Sym.AlphaShareCommon.Cache\">AlphaShareCommon.Cache</a> := <a href=\"./Init/Core.html#EmptyCollection.emptyCollection\">∅</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Applies hash-consing to `e`. Recall that all expressions in a `grind` goal have\nbeen hash-consed. We perform this step before we internalize expressions.\n\nThis function does not try to `unfoldReducible` and `foldProjs` like `shareCommon`.\n`cache` may contain the results accumulated by a run of `shareCommon` that was\ninterrupted by a check violation; see `repairAndShare`.\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.shareCommonWithoutChecks","kind":"def","line":385,"name":"Lean.Meta.Sym.shareCommonWithoutChecks","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L385-L396"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.withoutShareCommonChecks\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">withoutShareCommonChecks</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> → <a href=\"./foundational_types.html\">Type</a> u_1</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#MonadWithReaderOf\">MonadWithReaderOf</a> <a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.Context\">Context</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.withoutShareCommonChecks","kind":"def","line":358,"name":"Lean.Meta.Sym.withoutShareCommonChecks","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L358-L360"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.withoutFoldProjsCheck\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">withoutFoldProjsCheck</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> → <a href=\"./foundational_types.html\">Type</a> u_1</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#MonadWithReaderOf\">MonadWithReaderOf</a> <a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.Context\">Context</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Runs `x` with the `shareCommon` kernel-projection check disabled.\nUse this to wrap code that temporarily violates the `SymM` folded-projections\ninvariant, e.g., a head reducer that exposes kernel projections in intermediate\nterms and restores the invariant in its final result.\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.withoutFoldProjsCheck","kind":"def","line":348,"name":"Lean.Meta.Sym.withoutFoldProjsCheck","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L348-L356"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.runShareCommonM\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">runShareCommonM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><a href=\"./Lean/Meta/Sym/AlphaShareCommon.html#Lean.Meta.Sym.AlphaShareCommonM\">AlphaShareCommonM</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ctx</span> : <a href=\"./Lean/Meta/Sym/AlphaShareCommon.html#Lean.Meta.Sym.AlphaShareCommon.Context\">AlphaShareCommon.Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Except\">Except</a> <a href=\"./Lean/Meta/Sym/AlphaShareCommon.html#Lean.Meta.Sym.AlphaShareCommon.Cache\">AlphaShareCommon.Cache</a> <span class=\"fn\">α</span>)</span></span></div></div>","info":{"doc":"Runs an `AlphaShareCommonM` action over the `SymM` hash-consing state.\nOn a check violation, returns the cache accumulated before the failure as `.error`;\nthe terms hash-consed before the failure are kept in the state, since they\nindividually satisfy the invariants.\n","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.runShareCommonM","kind":"def","line":336,"name":"Lean.Meta.Sym.runShareCommonM","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L336-L346"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getIntExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">getIntExpr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Returns the internalized `Int`.  ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getIntExpr","kind":"def","line":333,"name":"Lean.Meta.Sym.getIntExpr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L333-L334"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getOrderingEqExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">getOrderingEqExpr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Returns the internalized `Ordering.eq`.  ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getOrderingEqExpr","kind":"def","line":331,"name":"Lean.Meta.Sym.getOrderingEqExpr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L331-L332"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getNatZeroExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">getNatZeroExpr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.SymM\">SymM</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"Returns the internalized `0 : Nat` numeral.  ","docLink":"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.getNatZeroExpr","kind":"def","line":329,"name":"Lean.Meta.Sym.getNatZeroExpr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Sym/SymM.lean#L329-L330"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/SymM.html#Lean.Meta.Sym.isBoolFalseExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Sym</span>.<span class=\"name\">isBoolFalseExpr</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=