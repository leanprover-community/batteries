47f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/BasicAux.lean#L31-L31","name":"Lean.Lsp.Position.line","line":31,"kind":"def","docLink":"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position.line","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position.line\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Position</span>.<span class=\"name\">line</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position\">Position</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/BasicAux.lean#L30-L30","name":"Lean.Lsp.Position.mk","line":30,"kind":"ctor","docLink":"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position.mk","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Position</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">line </span><span class=\"fn\">character</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position\">Position</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/BasicAux.lean#L26-L33","name":"Lean.Lsp.Position","line":26,"kind":"structure","docLink":"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position","doc":"We adopt the convention that zero-based UTF-16 positions as sent by LSP clients\nare represented by `Lsp.Position` while internally we mostly use `String.Pos` UTF-8\noffsets. For diagnostics, one-based `Lean.Position`s are used internally.\n`character` is accepted liberally: actual character := min(line length, character) "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Position\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Position</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/BasicAux.lean#L24-L24","name":"Lean.Lsp.DocumentUri","line":24,"kind":"def","docLink":"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.DocumentUri","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.DocumentUri\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">DocumentUri</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>"}]}