n\">init</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\"><span class=\"fn\">m</span> (<span class=\"fn\">α</span> <a href=\"./Init/Core.html#Sum\">⊕</a> <span class=\"fn\">β</span>)</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">measure</span> : <span class=\"fn\"><a href=\"./Std/Internal/Do/Triple/SpecLemmas.html#Std.Internal.Do.RepeatVariant\">RepeatVariant</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">inv</span> : <span class=\"fn\"><a href=\"./Std/Internal/Do/Triple/SpecLemmas.html#Std.Internal.Do.RepeatInvariant\">RepeatInvariant</a> <span class=\"fn\">α</span> <span class=\"fn\">β</span> <span class=\"fn\">Pred</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">einv</span> : <span class=\"fn\">EPred</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> :\n  <span class=\"fn\">∀ (<span class=\"fn\">a</span> : <span class=\"fn\">α</span>),\n    <a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">⦃</a> <span class=\"fn\"><span class=\"fn\">inv</span> <span class=\"fn\">(<a href=\"./Init/Core.html#Sum.inl\">Sum.inl</a> <span class=\"fn\">a</span>)</span></span> <a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">⦄</a> <span class=\"fn\"><span class=\"fn\">f</span> <span class=\"fn\">a</span></span> <a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">⦃</a> <span class=\"fn\">fun (<span class=\"fn\">r</span> : <span class=\"fn\">α</span> <a href=\"./Init/Core.html#Sum\">⊕</a> <span class=\"fn\">β</span>) =&gt;\n      <span class=\"fn\">match <span class=\"fn\">r</span> with\n      | <span class=\"fn\"><a href=\"./Init/Core.html#Sum.inl\">Sum.inl</a> <span class=\"fn\">a'</span></span> =&gt; <span class=\"fn\"><a href=\"./Std/Internal/Do/Order/Basic.html#Lean.Order.meet\">Lean.Order.meet</a> <span class=\"fn\">(<a href=\"./Std/Internal/Do/Order/Basic.html#Lean.Order.CompleteLattice.ofProp\">Lean.Order.CompleteLattice.ofProp</a> (<span class=\"fn\"><span class=\"fn\">measure</span> <span class=\"fn\">a'</span></span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\"><span class=\"fn\">measure</span> <span class=\"fn\">a</span></span>))</span> <span class=\"fn\">(<span class=\"fn\">inv</span> <span class=\"fn\">(<a href=\"./Init/Core.html#Sum.inl\">Sum.inl</a> <span class=\"fn\">a'</span>)</span>)</span></span>\n      | <span class=\"fn\"><a href=\"./Init/Core.html#Sum.inr\">Sum.inr</a> <span class=\"fn\">b</span></span> =&gt; <span class=\"fn\"><span class=\"fn\">inv</span> <span class=\"fn\">(<a href=\"./Init/Core.html#Sum.inr\">Sum.inr</a> <span class=\"fn\">b</span>)</span></span></span></span><a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">;</a>       <span class=\"fn\">einv</span> <a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">⦄</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">⦃</a> <span class=\"fn\"><span class=\"fn\">inv</span> <span class=\"fn\">(<a href=\"./Init/Core.html#Sum.inl\">Sum.inl</a> <span class=\"fn\">init</span>)</span></span> <a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">⦄</a> <span class=\"fn\"><a href=\"./Init/While.html#repeatM\">_root_.repeatM</a> <span class=\"fn\">f</span> <span class=\"fn\">init</span></span> <a href=\"./Std/Internal/Do/Triple/Basi