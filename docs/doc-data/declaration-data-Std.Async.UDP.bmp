n></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Enables or disables multicast loopback for the UDP socket.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.setMulticastLoop","kind":"def","line":151,"name":"Std.Async.UDP.Socket.setMulticastLoop","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L151-L156"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.setBroadcast\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">setBroadcast</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">enable</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Enables or disables broadcasting for the UDP socket.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.setBroadcast","kind":"def","line":144,"name":"Std.Async.UDP.Socket.setBroadcast","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L144-L149"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.getPeerName\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">getPeerName</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <a href=\"./Std/Net/Addr.html#Std.Net.SocketAddress\">Net.SocketAddress</a></span></div></div>","info":{"doc":"Gets the remote address of the UDP socket. On unconnected handles, it throws the `.invalidArgument`.\nerror.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.getPeerName","kind":"def","line":136,"name":"Std.Async.UDP.Socket.getPeerName","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L136-L142"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.getSockName\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">getSockName</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <a href=\"./Std/Net/Addr.html#Std.Net.SocketAddress\">Net.SocketAddress</a></span></div></div>","info":{"doc":"Gets the local address of the UDP socket.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.getSockName","kind":"def","line":129,"name":"Std.Async.UDP.Socket.getSockName","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L129-L134"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.recvSelector\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">recvSelector</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">size</span> : <a href=\"./Init/Prelude.html#UInt64\">UInt64</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Async/Select.html#Std.Async.Selector\">Selector</a> (<a href=\"./Init/Prelude.html#ByteArray\">ByteArray</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Std/Net/Addr.html#Std.Net.SocketAddress\">Net.SocketAddress</a></span>)</span></div></div>","info":{"doc":"Creates a `Selector` that resolves once `s` has data available, up to at most `size` bytes,\nand provides that data. If the socket has not been previously bound with `bind`, it is\nautomatically bound to `0.0.0.0` (all interfaces) with a random port.\nCalling this function does starts the data wait, only when it's used with `Selectable.one` or `combine`.\nIt must not be called in parallel with `recv`.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.recvSelector","kind":"def","line":88,"name":"Std.Async.UDP.Socket.recvSelector","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L88-L127"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.recv\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">recv</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">size</span> : <a href=\"./Init/Prelude.html#UInt64\">UInt64</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Async/Basic.html#Std.Async.Async\">Async</a> (<a href=\"./Init/Prelude.html#ByteArray\">ByteArray</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Std/Net/Addr.html#Std.Net.SocketAddress\">Net.SocketAddress</a></span>)</span></div></div>","info":{"doc":"Receives data from an UDP socket. `size` is for the maximum bytes to receive.\nThe promise resolves when some data is available or an error occurs. If the socket\nhas not been previously bound with `bind`, it is automatically bound to `0.0.0.0`\n(all interfaces) with a random port.\nFurthermore calling this function in parallel with `recvSelector` is not supported.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.recv","kind":"def","line":77,"name":"Std.Async.UDP.Socket.recv","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L77-L86"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.send\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">send</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">data</span> : <a href=\"./Init/Prelude.html#ByteArray\">ByteArray</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">addr</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Std/Net/Addr.html#Std.Net.SocketAddress\">Net.SocketAddress</a></span> := <a href=\"./Init/Prelude.html#Option.none\">none</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Async/Basic.html#Std.Async.Async\">Async</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Sends data through an UDP socket. The `addr` parameter specifies the destination address. If `addr`\nis `none`, the data is sent to the default peer address set by `connect`.\n","docLink":"./Std/Async/UDP.html#Std.Async.UDP.Socket.send","kind":"def","line":69,"name":"Std.Async.UDP.Socket.send","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Async/UDP.lean#L69-L75"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket.sendAll\"><span class=\"name\">Std</span>.<span class=\"name\">Async</span>.<span class=\"name\">UDP</span>.<span class=\"name\">Socket</span>.<span class=\"name\">sendAll</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Std/Async/UDP.html#Std.Async.UDP.Socket\">Socket</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">data</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Prelude.html#ByteArray\">ByteArray</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">addr</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a