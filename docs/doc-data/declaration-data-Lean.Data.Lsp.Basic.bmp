/div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L134-L135","name":"Lean.Lsp.instAppendTextEditBatch","line":134,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instAppendTextEditBatch","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instAppendTextEditBatch\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instAppendTextEditBatch</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Append\">Append</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEditBatch\">TextEditBatch</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L132-L132","name":"Lean.Lsp.instEmptyCollectionTextEditBatch","line":132,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instEmptyCollectionTextEditBatch","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instEmptyCollectionTextEditBatch\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instEmptyCollectionTextEditBatch</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Core.html#EmptyCollection\">EmptyCollection</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEditBatch\">TextEditBatch</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L129-L130","name":"Lean.Lsp.instToJsonTextEditBatch","line":129,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonTextEditBatch","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonTextEditBatch\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instToJsonTextEditBatch</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.ToJson\">ToJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEditBatch\">TextEditBatch</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L126-L127","name":"Lean.Lsp.instFromJsonTextEditBatch","line":126,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonTextEditBatch","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonTextEditBatch\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instFromJsonTextEditBatch</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.FromJson\">FromJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEditBatch\">TextEditBatch</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L123-L124","name":"Lean.Lsp.TextEditBatch","line":123,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEditBatch","doc":"An array of `TextEdit`s to be performed in sequence. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEditBatch\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEditBatch</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L121-L121","name":"Lean.Lsp.instFromJsonTextEdit","line":121,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonTextEdit","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonTextEdit\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instFromJsonTextEdit</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.FromJson\">FromJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L121-L121","name":"Lean.Lsp.instToJsonTextEdit","line":121,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonTextEdit","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonTextEdit\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instToJsonTextEdit</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.ToJson\">ToJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L120-L120","name":"Lean.Lsp.TextEdit.annotationId?","line":120,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.annotationId?","doc":"Identifier for annotated edit.\n\n`WorkspaceEdit` has a `changeAnnotations` field that maps these identifiers to a `ChangeAnnotation`.\nBy annotating an edit you can add a description of what the edit will do and also control whether the\nuser is presented with a prompt before applying the edit.\n[reference](https://microsoft.github.io/language-server-protocol/specifications/lsp/3.17/specification/#textEdit).\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.annotationId?\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEdit</span>.<span class=\"name\">annotationId?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#String\">String</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L112-L112","name":"Lean.Lsp.TextEdit.leanExtSnippet?","line":112,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.leanExtSnippet?","doc":"If this field is present and the editor supports it,\n`newText` is ignored\nand an interactive snippet edit is performed instead.\n\nThe use of snippets in `TextEdit`s\nis a Lean-specific extension to the LSP standard,\nso `newText` should still be set to a correct value\nas fallback in case the editor does not support this feature.\nEven editors that support snippets may not always use them;\nfor instance, if the file is not already open,\nVS Code will perform a normal text edit in the background instead. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.leanExtSnippet?\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEdit</span>.<span class=\"name\">leanExtSnippet?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\">SnippetString</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L97-L97","name":"Lean.Lsp.TextEdit.newText","line":97,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.newText","doc":"The string to be inserted. For delete operations use an empty string. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.newText\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEdit</span>.<span class=\"name\">newText</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L95-L95","name":"Lean.Lsp.TextEdit.range","line":95,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.range","doc":"The range of the text document to be manipulated.\nTo insert text into a document create a range where `start = end`. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.range\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEdit</span>.<span class=\"name\">range</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Range\">Range</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L92-L92","name":"Lean.Lsp.TextEdit.mk","line":92,"kind":"ctor","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.mk","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEdit</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">range</span> : <a href=\"./Lean/Data/Lsp/BasicAux.html#Lean.Lsp.Range\">Range</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">newText</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">leanExtSnippet?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\">SnippetString</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">annotationId?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#String\">String</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\">TextEdit</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L89-L121","name":"Lean.Lsp.TextEdit","line":89,"kind":"structure","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit","doc":"A textual edit applicable to a text document.\n\n[reference](https://microsoft.github.io/language-server-protocol/specifications/lsp/3.17/specification/#textEdit) "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.TextEdit\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">TextEdit</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L87-L87","name":"Lean.Lsp.instFromJsonSnippetString","line":87,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonSnippetString","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonSnippetString\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instFromJsonSnippetString</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.FromJson\">FromJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\">SnippetString</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L87-L87","name":"Lean.Lsp.instToJsonSnippetString","line":87,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonSnippetString","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonSnippetString\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instToJsonSnippetString</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.ToJson\">ToJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\">SnippetString</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L86-L86","name":"Lean.Lsp.SnippetString.value","line":86,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString.value","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString.value\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">SnippetString</span>.<span class=\"name\">value</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\">SnippetString</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L85-L85","name":"Lean.Lsp.SnippetString.mk","line":85,"kind":"ctor","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString.mk","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">SnippetString</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">value</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\">SnippetString</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L57-L87","name":"Lean.Lsp.SnippetString","line":57,"kind":"structure","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString","doc":"A snippet is a string that gets inserted into a document,\nand can afterwards be edited by the user in a structured way.\n\nSnippets contain instructions that\nspecify how this structured editing should proceed.\nThey are expressed in a domain-specific language\nbased on one from TextMate,\nincluding the following constructs:\n- Designated positions for subsequent user input,\n  called \"tab stops\" after their most frequently-used keybinding.\n  They are denoted with `$1`, `$2`, and so forth.\n  `$0` denotes where the cursor should be positioned after all edits are completed,\n  defaulting to the end of the string.\n  Snippet tab stops are unrelated to tab stops used for indentation.\n- Tab stops with default values, called _placeholders_, written `${1:default}`.\n  The default may itself contain a tab stop or a further placeholder\n  and multiple options to select from may be provided\n  by surrounding them with `|`s and separating them with `,`,\n  as in `${1|if $2 then $3 else $4,if let $2 := $3 then $4 else $5|}`.\n- One of a set of predefined variables that are replaced with their values.\n  This includes the current line number (`$TM_LINE_NUMBER`)\n  or the text that was selected when the snippet was invoked (`$TM_SELECTED_TEXT`).\n- Formatting instructions to modify variables using regular expressions\n  or a set of predefined filters.\n\nThe full syntax and semantics of snippets,\nincluding the available variables and the rules for escaping control characters,\nare described in the [LSP specification](https://microsoft.github.io/language-server-protocol/specifications/lsp/3.17/specification/#snippet_syntax). "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.SnippetString\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">SnippetString</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L55-L55","name":"Lean.Lsp.instFromJsonCommand","line":55,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonCommand","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instFromJsonCommand\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instFromJsonCommand</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.FromJson\">FromJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command\">Command</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L55-L55","name":"Lean.Lsp.instToJsonCommand","line":55,"kind":"instance","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonCommand","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.instToJsonCommand\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">instToJsonCommand</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Json/FromToJson/Basic.html#Lean.ToJson\">ToJson</a> <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command\">Command</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L54-L54","name":"Lean.Lsp.Command.arguments?","line":54,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.arguments?","doc":"Arguments that the command handler should be invoked with. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.arguments?\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Command</span>.<span class=\"name\">arguments?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command\">Command</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Data/Json/Basic.html#Lean.Json\">Json</a>)</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L52-L52","name":"Lean.Lsp.Command.command","line":52,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.command","doc":"The identifier of the actual command handler. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.command\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Command</span>.<span class=\"name\">command</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command\">Command</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L50-L50","name":"Lean.Lsp.Command.title","line":50,"kind":"def","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.title","doc":"Title of the command, like `save`. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.title\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Command</span>.<span class=\"name\">title</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command\">Command</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L48-L48","name":"Lean.Lsp.Command.mk","line":48,"kind":"ctor","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.mk","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Lsp</span>.<span class=\"name\">Command</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">title </span><span class=\"fn\">command</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">arguments?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Data/Json/Basic.html#Lean.Json\">Json</a>)</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command\">Command</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Data/Lsp/Basic.lean#L41-L55","name":"Lean.Lsp.Command","line":41,"kind":"structure","docLink":"./Lean/Data/Lsp/Basic.html#Lean.Lsp.Command","doc":"Represents a reference to a client editor command.\n\nNOTE: No specific commands are specified by LSP, hence\npossible commands need to be announced as capabilities.\n\n[reference](https://microsoft.github.io/language-server-protocol/specifications/lsp/3.17/specification/#command)\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\"