{"name":"Lean.Meta.Tactic.Grind.Arith.ProofUtil","instances":[],"imports":["Init.Grind.Offset","Init.Grind.Lemmas","Lean.Meta.Tactic.Grind.Types"],"declarations":[{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/93d4ae6635c0c755c9f7368f9b99483d4557b7a6/src/Lean/Meta/Tactic/Grind/Arith/ProofUtil.lean#L140-L164","name":"Lean.Meta.Grind.Arith.Offset.mkPropagateEqFalseProof","line":140,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkPropagateEqFalseProof","doc":"Given a path `u --(kuv)--> v` justified by proof `huv`,\nconstruct a proof of `e = False` where `e` is a term corresponding to the edgen `v --(k') --> u`\ns.t. `k+k' < 0`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkPropagateEqFalseProof\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">Offset</span>.<span class=\"name\">mkPropagateEqFalseProof</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(u v : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(k : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(huv : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(k' : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/93d4ae6635c0c755c9f7368f9b99483d4557b7a6/src/Lean/Meta/Tactic/Grind/Arith/ProofUtil.lean#L113-L138","name":"Lean.Meta.Grind.Arith.Offset.mkPropagateEqTrueProof","line":113,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkPropagateEqTrueProof","doc":"Given a path `u --(kuv)--> v` justified by proof `huv`,\nconstruct a proof of `e = True` where `e` is a term corresponding to the edgen `u --(k') --> v`\ns.t. `k ≤ k'`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkPropagateEqTrueProof\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">Offset</span>.<span class=\"name\">mkPropagateEqTrueProof</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(u v : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(k : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(huv : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(k' : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/93d4ae6635c0c755c9f7368f9b99483d4557b7a6/src/Lean/Meta/Tactic/Grind/Arith/ProofUtil.lean#L92-L111","name":"Lean.Meta.Grind.Arith.Offset.mkUnsatProof","line":92,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkUnsatProof","doc":"Returns a proof of `False` using a negative cycle composed of\n- `u --(kuv)--> v` with proof `huv`\n- `v --(kvu)--> u` with proof `hvu`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkUnsatProof\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">Offset</span>.<span class=\"name\">mkUnsatProof</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(u v : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(kuv : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(huv : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(kvu : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(hvu : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/93d4ae6635c0c755c9f7368f9b99483d4557b7a6/src/Lean/Meta/Tactic/Grind/Arith/ProofUtil.lean#L80-L90","name":"Lean.Meta.Grind.Arith.Offset.mkOfNegEqFalse","line":80,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkOfNegEqFalse","doc":""},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkOfNegEqFalse\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">Offset</span>.<span class=\"name\">mkOfNegEqFalse</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(nodes : <span class=\"fn\"><a href=\"./Lean/Data/PersistentArray.html#Lean.PArray\">PArray</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(c : <span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/Util.html#Lean.Meta.Grind.Arith.Offset.Cnstr\">Cnstr</a> <a href=\"./Lean/Meta/Tactic/Grind/Arith/Types.html#Lean.Meta.Grind.Arith.Offset.NodeId\">NodeId</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(h : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/93d4ae6635c0c755c9f7368f9b99483d4557b7a6/src/Lean/Meta/Tactic/Grind/Arith/ProofUtil.lean#L27-L77","name":"Lean.Meta.Grind.Arith.Offset.mkTrans","line":27,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkTrans","doc":"Assume `pi₁` is `{ w := u, k := k₁, proof := p₁ }` and `pi₂` is `{ w := w, k := k₂, proof := p₂ }`\n`p₁` is the proof for edge `u -(k₁) → w` and `p₂` the proof for edge `w -(k₂)-> v`.\nThen, this function returns a proof for edge `u -(k₁+k₂) -> v`.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.mkTrans\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">Offset</span>.<span class=\"name\">mkTrans</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(nodes : <span class=\"fn\"><a href=\"./Lean/Data/PersistentArray.html#Lean.PArray\">PArray</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(pi₁ pi₂ : <a href=\"./Lean/Meta/Tactic/Grind/Arith/Types.html#Lean.Meta.Grind.Arith.Offset.ProofInfo\">ProofInfo</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(v : <a href=\"./Lean/Meta/Tactic/Grind/Arith/Types.html#Lean.Meta.Grind.Arith.Offset.NodeId\">NodeId</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/Types.html#Lean.Meta.Grind.Arith.Offset.ProofInfo\">ProofInfo</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/93d4ae6635c0c755c9f7368f9b99483d4557b7a6/src/Lean/Meta/Tactic/Grind/Arith/ProofUtil.lean#L19-L20","name":"Lean.Meta.Grind.Arith.Offset.rfl_true","line":19,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.rfl_true","doc":"Returns a proof for `true = true` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/ProofUtil.html#Lean.Meta.Grind.Arith.Offset.rfl_true\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">Offset</span>.<span class=\"name\">rfl_true</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></div></div>"}]}