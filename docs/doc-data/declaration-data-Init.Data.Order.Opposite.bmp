bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L187-L191"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Std.OppositeOrderInstances.instDecidableLEOpposite\"><span class=\"name\">Std</span>.<span class=\"name\">OppositeOrderInstances</span>.<span class=\"name\">instDecidableLEOpposite</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">i</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LE\">LE</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">id</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#DecidableLE\">DecidableLE</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#DecidableLE\">DecidableLE</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#Std.OppositeOrderInstances.instDecidableLEOpposite","kind":"def","line":181,"name":"Std.OppositeOrderInstances.instDecidableLEOpposite","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L181-L185"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Max.min_oppositeMin\"><span class=\"name\">Max</span>.<span class=\"name\">min_oppositeMin</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">max</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Max\">Max</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">a </span><span class=\"fn\">b</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Min.min\">min</a> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Max.max\">Max.max</a> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#Max.min_oppositeMin","kind":"theorem","line":175,"name":"Max.min_oppositeMin","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L175-L177"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Max.oppositeMin_def\"><span class=\"name\">Max</span>.<span class=\"name\">oppositeMin_def</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">min</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Max\">Max</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">min</span>.<a href=\"./Init/Data/Order/Opposite.html#Max.oppositeMin\">oppositeMin</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Init/Prelude.html#Min.mk\">{</a> <span class=\"fn\">min</span> := <a href=\"./Init/Prelude.html#Max.max\">max</a> <a href=\"./Init/Prelude.html#Min.mk\">}</a></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#Max.oppositeMin_def","kind":"theorem","line":171,"name":"Max.oppositeMin_def","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L171-L173"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Max.oppositeMin\"><span class=\"name\">Max</span>.<span class=\"name\">oppositeMin</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">max</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Max\">Max</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Min\">Min</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Creates a {name}`Min` instance from a {name}`Max` instance.\n\nThe result is a {lean}`Min α` instance that uses {lean}`max.max` as its {name}`min` operation.\n\nIf {name}`max` obeys laws, then {lean}`max.oppositeMin` obeys the corresponding laws for {name}`Min`.\nTo automatically derive these laws, use {lit}`open scoped Std.OppositeOrderInstances`.\n\nFor example, one can use the derived instances to prove properties about the opposite {name}`Min`\ninstance:\n\n```lean\nopen scoped Std.OppositeOrderInstances in\nexample [LE α] [DecidableLE α] [Max α] [Std.LawfulOrderLeftLeaningMax α] {a b : α} :\n    letI : LE α := LE.opposite inferInstance\n    letI : Min α := (inferInstance : Max α).oppositeMin\n    min a b = if a ≤ b then a else b :=\n  letI : LE α := LE.opposite inferInstance\n  letI : Min α := (inferInstance : Max α).oppositeMin\n  Std.min_eq_if\n```\n\nWithout the `open scoped` command, Lean would not find the {lit}`LawfulOrderLeftLeaningMin α`\ninstance for the opposite order that is required by {name}`min_eq_if`.\n","docLink":"./Init/Data/Order/Opposite.html#Max.oppositeMin","kind":"def","line":142,"name":"Max.oppositeMin","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L142-L169"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Min.max_oppositeMax\"><span class=\"name\">Min</span>.<span class=\"name\">max_oppositeMax</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">min</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Min\">Min</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">a </span><span class=\"fn\">b</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Max.max\">max</a> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Min.min\">Min.min</a> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#Min.max_oppositeMax","kind":"theorem","line":138,"name":"Min.max_oppositeMax","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L138-L140"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Min.oppositeMax_def\"><span class=\"name\">Min</span>.<span class=\"name\">oppositeMax_def</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">min</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Min\">Min</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">min</span>.<a href=\"./Init/Data/Order/Opposite.html#Min.oppositeMax\">oppositeMax</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Init/Prelude.html#Max.mk\">{</a> <span class=\"fn\">max</span> := <a href=\"./Init/Prelude.html#Min.min\">Min.min</a> <a href=\"./Init/Prelude.html#Max.mk\">}</a></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#Min.oppositeMax_def","kind":"theorem","line":134,"name":"Min.oppositeMax_def","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L134-L136"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#Min.oppositeMax\"><span class=\"name\">Min</span>.<span class=\"name\">oppositeMax</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">min</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Min\">Min</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Max\">Max</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Creates a {name}`Max` instance from a {name}`Min` instance.\n\nThe result is a {lean}`Max α` instance that uses {lean}`min.min` as its {name}`max` operation.\n\nIf {name}`min` obeys laws, then {lean}`min.oppositeMax` obeys the corresponding laws for {name}`Max`.\nTo automatically derive these laws, use {lit}`open scoped Std.OppositeOrderInstances`.\n\nFor example, one can use the derived instances to prove properties about the opposite {name}`Max`\ninstance:\n\n```lean\nopen scoped Std.OppositeOrderInstances in\nexample [LE α] [DecidableLE α] [Min α] [Std.LawfulOrderLeftLeaningMin α] {a b : α} :\n    letI : LE α := LE.opposite inferInstance\n    letI : Max α := (inferInstance : Min α).oppositeMax\n    max a b = if b ≤ a then a else b :=\n  letI : LE α := LE.opposite inferInstance\n  letI : Max α := (inferInstance : Min α).oppositeMax\n  Std.max_eq_if\n```\n\nWithout the `open scoped` command, Lean would not find the {lit}`LawfulOrderLeftLeaningMax α`\ninstance for the opposite order that is required by {name}`max_eq_if`.\n","docLink":"./Init/Data/Order/Opposite.html#Min.oppositeMax","kind":"def","line":105,"name":"Min.oppositeMax","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L105-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#LT.lt_opposite_iff\"><span class=\"name\">LT</span>.<span class=\"name\">lt_opposite_iff</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">lt</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LT\">LT</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">a </span><span class=\"fn\">b</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">b</span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">a</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#LT.lt_opposite_iff","kind":"theorem","line":101,"name":"LT.lt_opposite_iff","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L101-L103"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#LT.opposite_def\"><span class=\"name\">LT</span>.<span class=\"name\">opposite_def</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">lt</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LT\">LT</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">lt</span>.<a href=\"./Init/Data/Order/Opposite.html#LT.opposite\">opposite</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Init/Prelude.html#LT.mk\">{</a> <span class=\"fn\">lt</span> := <span class=\"fn\">fun (<span class=\"fn\">a</span> <span class=\"fn\">b</span> : <span class=\"fn\">α</span>) =&gt; <span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">a</span></span> <a href=\"./Init/Prelude.html#LT.mk\">}</a></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#LT.opposite_def","kind":"theorem","line":97,"name":"LT.opposite_def","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L97-L99"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#LT.opposite\"><span class=\"name\">LT</span>.<span class=\"name\">opposite</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">lt</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LT\">LT</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#LT\">LT</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Inverts an {name}`LT` instance.\n\nThe result is an {lean}`LT α` instance where {lit}`a < b` holds when {name}`lt` would have\n{lit}`b < a` hold.\n\nIf {name}`lt` obeys laws, then {lean}`lt.opposite` obeys the opposite laws.\nTo automatically derive these laws, use {lit}`open scoped Std.OppositeOrderInstances`.\n\nFor example, one can use the derived instances to prove properties about the opposite {name}`LT`\ninstance:\n\n```lean\nopen scoped Std.OppositeOrderInstances in\nexample [LE α] [LT α] [Std.LawfulOrderLT α] [Std.IsLinearOrder α] {x y : α} :\n    letI : LE α := LE.opposite inferInstance\n    letI : LT α := LT.opposite inferInstance\n    ¬ y ≤ x ↔ x < y :=\n  letI : LE α := LE.opposite inferInstance\n  letI : LT α := LT.opposite inferInstance\n  Std.not_le\n```\n\nWithout the `open scoped` command, Lean would not find the {lit}`LawfulOrderLT α`\nand {lit}`IsLinearOrder α` instances for the opposite order that are required by {name}`not_le`.\n","docLink":"./Init/Data/Order/Opposite.html#LT.opposite","kind":"def","line":67,"name":"LT.opposite","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L67-L95"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#LE.le_opposite_iff\"><span class=\"name\">LE</span>.<span class=\"name\">le_opposite_iff</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">le</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LE\">LE</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">a </span><span class=\"fn\">b</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">b</span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#LE.le_opposite_iff","kind":"theorem","line":63,"name":"LE.le_opposite_iff","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L63-L65"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#LE.opposite_def\"><span class=\"name\">LE</span>.<span class=\"name\">opposite_def</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">le</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LE\">LE</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">le</span>.<a href=\"./Init/Data/Order/Opposite.html#LE.opposite\">opposite</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Init/Prelude.html#LE.mk\">{</a> <span class=\"fn\">le</span> := <span class=\"fn\">fun (<span class=\"fn\">a</span> <span class=\"fn\">b</span> : <span class=\"fn\">α</span>) =&gt; <span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span></span> <a href=\"./Init/Prelude.html#LE.mk\">}</a></div></div>","info":{"doc":"","docLink":"./Init/Data/Order/Opposite.html#LE.opposite_def","kind":"theorem","line":59,"name":"LE.opposite_def","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L59-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Order/Opposite.html#LE.opposite\"><span class=\"name\">LE</span>.<span class=\"name\">opposite</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">le</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#LE\">LE</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#LE\">LE</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Inverts an {name}`LE` instance.\n\nThe result is an {lean}`LE α` instance where {lit}`a ≤ b` holds when {name}`le` would have\n{lit}`b ≤ a` hold.\n\nIf {name}`le` obeys laws, then {lean}`le.opposite` obeys the opposite laws. For example, if\n{name}`le` encodes a linear order, then {lean}`le.opposite` also encodes a linear order.\nTo automatically derive these laws, use {lit}`open Std.OppositeOrderInstances`.\n\nFor example, {name}`LE.opposite` can be used to derive maximum operations from minimum operations,\nsince finding the minimum in the opposite order is the same as finding the maximum in the original order:\n\n```lean +warning\ndef min' [LE α] [DecidableLE α] (a b : α) : α :=\n  if a ≤ b then a else b\n\nopen scoped Std.OppositeOrderInstances in\ndef max' [LE α] [DecidableLE α] (a b : α) : α :=\n  letI : LE α := (inferInstanceAs (LE α)).opposite\n  -- `DecidableLE` for the opposite order is derived automatically via `OppositeOrderInstances`\n  min' a b\n```\n\nWithout the `open scoped` command, Lean would not find the required {lit}`DecidableLE α`\ninstance for the opposite order.\n","docLink":"./Init/Data/Order/Opposite.html#LE.opposite","kind":"def","line":28,"name":"LE.opposite","sourceLink":"https://github.com/leanprover/lean4/blob/00659f8e6071d7e46131ed643bf8003b99b044e9/src/Init/Data/Order/Opposite.lean#L28-L57"}}],"imports":["Init.Data.Order.Classes","Init.Data.Order.ClassesExtra","Init.Data.Order.FactoriesExtra","Init.Data.Order.Lemmas"],"instances":[],"name":"Init.Data.Order.Opposite"}