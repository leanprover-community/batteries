tp.URI.instInhabitedQuery\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">instInhabitedQuery</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Query\">Query</a></span></div></div>","info":{"doc":"","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.instInhabitedQuery","kind":"instance","line":397,"name":"Std.Http.URI.instInhabitedQuery","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L397-L397"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.instReprQuery\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">instReprQuery</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Repr.html#Repr\">Repr</a> <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Query\">Query</a></span></div></div>","info":{"doc":"","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.instReprQuery","kind":"instance","line":397,"name":"Std.Http.URI.instReprQuery","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L397-L397"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Query\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Query</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Query string represented as an array of key-value pairs. Both keys and values are stored as\n`EncodedQueryParam` for proper application/x-www-form-urlencoded encoding. Values are optional to\nsupport parameters without values (e.g., \"?flag\"). Order is preserved based on insertion order.\n\nReference: https://www.rfc-editor.org/rfc/rfc3986.html#section-3.4\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Query","kind":"def","line":388,"name":"Std.Http.URI.Query","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L388-L397"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.toDecodedSegments\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">toDecodedSegments</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Prelude.html#String\">String</a></span></div></div>","info":{"doc":"Returns the path segments as decoded strings.\nSegments that cannot be decoded as UTF-8 are returned as their raw encoded form.\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.toDecodedSegments","kind":"def","line":378,"name":"Std.Http.URI.Path.toDecodedSegments","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L378-L384"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.normalize\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">normalize</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Removes dot segments from the path according to RFC 3986 Section 5.2.4. This handles \".\"\n(current directory) and \"..\" (parent directory) segments.\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.normalize","kind":"def","line":357,"name":"Std.Http.URI.Path.normalize","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L357-L376"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.appendEncoded\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">appendEncoded</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">segment</span> : <a href=\"./Std/Http/Data/URI/Encoding.html#Std.Http.URI.EncodedSegment\">EncodedSegment</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Appends an already-encoded segment to the path.\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.appendEncoded","kind":"def","line":351,"name":"Std.Http.URI.Path.appendEncoded","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L351-L355"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.append\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">append</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">segment</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Appends a single segment to the path. The segment will be percent-encoded.\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.append","kind":"def","line":345,"name":"Std.Http.URI.Path.append","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L345-L349"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.join\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">join</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p1 </span><span class=\"fn\">p2</span> : <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Joins two paths. If the second path is absolute, it is returned as-is. Otherwise, the second path's\nsegments are appended to the first path.\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.join","kind":"def","line":337,"name":"Std.Http.URI.Path.join","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L337-L343"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.parent\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">parent</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Returns the parent path by removing the last segment. If the path is empty, returns the path unchanged.\n","docLink":"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.parent","kind":"def","line":330,"name":"Std.Http.URI.Path.parent","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Basic.lean#L330-L335"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Basic.html#Std.Http.URI.Path.isEmpty\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">isEmpty</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span c