r/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.Entry.mk","kind":"ctor","line":91,"name":"Lean.Linter.Extra.UnnecessarySeqFocus.Entry.mk","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L91-L100"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.Entry\"><span class=\"name\">Lean</span>.<span class=\"name\">Linter</span>.<span class=\"name\">Extra</span>.<span class=\"name\">UnnecessarySeqFocus</span>.<span class=\"name\">Entry</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The information we record for each `<;>` node appearing in the syntax. ","docLink":"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.Entry","kind":"structure","line":91,"name":"Lean.Linter.Extra.UnnecessarySeqFocus.Entry","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L91-L100"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.isMultigoalKind\"><span class=\"name\">Lean</span>.<span class=\"name\">Linter</span>.<span class=\"name\">Extra</span>.<span class=\"name\">UnnecessarySeqFocus</span>.<span class=\"name\">isMultigoalKind</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <a href=\"./Init/Prelude.html#Lean.SyntaxNodeKind\">SyntaxNodeKind</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#BaseIO\">BaseIO</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Whether `k` is a multigoal tactic kind, per `multigoalKindsRef`. ","docLink":"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.isMultigoalKind","kind":"def","line":87,"name":"Lean.Linter.Extra.UnnecessarySeqFocus.isMultigoalKind","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L87-L89"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.addBuiltinMultigoalKinds\"><span class=\"name\">Lean</span>.<span class=\"name\">Linter</span>.<span class=\"name\">Extra</span>.<span class=\"name\">UnnecessarySeqFocus</span>.<span class=\"name\">addBuiltinMultigoalKinds</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ks</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Prelude.html#Lean.SyntaxNodeKind\">SyntaxNodeKind</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Register `ks` as multigoal tactic syntax kinds. ","docLink":"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.addBuiltinMultigoalKinds","kind":"def","line":65,"name":"Lean.Linter.Extra.UnnecessarySeqFocus.addBuiltinMultigoalKinds","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L65-L67"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.addBuiltinMultigoalKind\"><span class=\"name\">Lean</span>.<span class=\"name\">Linter</span>.<span class=\"name\">Extra</span>.<span class=\"name\">UnnecessarySeqFocus</span>.<span class=\"name\">addBuiltinMultigoalKind</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <a href=\"./Init/Prelude.html#Lean.SyntaxNodeKind\">SyntaxNodeKind</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO\">IO</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Register `k` as a multigoal tactic syntax kind. ","docLink":"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.addBuiltinMultigoalKind","kind":"def","line":61,"name":"Lean.Linter.Extra.UnnecessarySeqFocus.addBuiltinMultigoalKind","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L61-L63"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.multigoalKindsRef\"><span class=\"name\">Lean</span>.<span class=\"name\">Linter</span>.<span class=\"name\">Extra</span>.<span class=\"name\">UnnecessarySeqFocus</span>.<span class=\"name\">multigoalKindsRef</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#IO.Ref\">IO.Ref</a> <a href=\"./Lean/Data/NameMap/Basic.html#Lean.NameSet\">NameSet</a></span></div></div>","info":{"doc":"The set of tactic syntax kinds that act on multiple goals — meaning `tac` differs from\n`focus tac`. Used to suppress false positives where `tac1 <;> tac2` cannot be replaced by\n`(tac1; tac2)` because that would expose `tac2` to a different set of goals.\n\nOther modules can extend this set in their own `builtin_initialize` block by calling\n`addBuiltinMultigoalKinds`.\n","docLink":"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.UnnecessarySeqFocus.multigoalKindsRef","kind":"opaque","line":51,"name":"Lean.Linter.Extra.UnnecessarySeqFocus.multigoalKindsRef","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L51-L59"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.linter.extra.unnecessarySeqFocus\"><span class=\"name\">Lean</span>.<span class=\"name\">Linter</span>.<span class=\"name\">Extra</span>.<span class=\"name\">linter</span>.<span class=\"name\">extra</span>.<span class=\"name\">unnecessarySeqFocus</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Data/Options.html#Lean.Option\">Lean.Option</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Enables the 'unnecessary `<;>`' linter. This will warn whenever the `<;>` tactic combinator\nis used when `;` would work.\n\n```\nexample : True := by apply id <;> trivial\n```\nThe `<;>` is unnecessary here because `apply id` only makes one subgoal.\nPrefer `apply id; trivial` instead.\n\nIn some cases, the `<;>` is syntactically necessary because a single tactic is expected:\n```\nexample : True := by\n  cases () with apply id <;> apply id\n  | unit => trivial\n```\nIn this case, you should use parentheses, as in `(apply id; apply id)`:\n```\nexample : True := by\n  cases () with (apply id; apply id)\n  | unit => trivial\n```\n","docLink":"./Lean/Linter/Extra/UnnecessarySeqFocus.html#Lean.Linter.Extra.linter.extra.unnecessarySeqFocus","kind":"opaque","line":21,"name":"Lean.Linter.Extra.linter.extra.unnecessarySeqFocus","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnnecessarySeqFocus.lean#L21-L47"}}],"imports":["Lean.Elab.Command","Lean.Linter.Basic"],"instances":[],"name":"Lean.Linter.Extra.UnnecessarySeqFocus"}