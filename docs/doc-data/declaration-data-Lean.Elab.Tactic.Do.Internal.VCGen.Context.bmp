c/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.inlineHandledInvariants\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">State</span>.<span class=\"name\">inlineHandledInvariants</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State\">State</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Data/HashSet/Basic.html#Std.HashSet\">Std.HashSet</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a></span></div></div>","info":{"doc":"Set of invariant numbers that have been inline-elaborated by `Driver.emitVC` via\n`tryInlineInvariant`. The post-hoc invariant elaboration in `Frontend` consults\nthis to know which user-provided alts have already been consumed (so it doesn't\nwarn about them). ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.inlineHandledInvariants","kind":"def","line":206,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.State.inlineHandledInvariants","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L206-L206"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.fuel\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">State</span>.<span class=\"name\">fuel</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State\">State</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/Tactic/Do/VCGen/Basic.html#Lean.Elab.Tactic.Do.Fuel\">Fuel</a></div></div>","info":{"doc":"Remaining VC-generation steps. Initialized from `Context.config.stepLimit` (or\n`.unlimited` when no limit is set). Decremented at each successful program-shape\nstep (`tryLetHoist`, `trySplit`, `tryFvarZeta`, `applySpec`). When exhausted,\n`solve` short-circuits and emits the current goal as a VC.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.fuel","kind":"def","line":200,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.State.fuel","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L200-L200"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.simpState\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">State</span>.<span class=\"name\">simpState</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State\">State</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Simp/SimpM.html#Lean.Meta.Sym.Simp.State\">Meta.Sym.Simp.State</a></div></div>","info":{"doc":"Persistent cache for the `Sym.Simp` simplifier used to pre-simplify hypotheses\nbefore grind internalization. Threading this cache across VCGen iterations avoids\nre-simplifying shared subexpressions (e.g., `s + 1 + 1 + ...` chains).\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.simpState","kind":"def","line":193,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.State.simpState","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L193-L193"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.vcs\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">State</span>.<span class=\"name\">vcs</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State\">State</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Meta/Tactic/Grind/Types.html#Lean.Meta.Grind.Goal\">Meta.Grind.Goal</a></span></div></div>","info":{"doc":"The verification conditions that have been generated so far. Each entry\nshares the parent `Grind.Goal`'s state.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.vcs","kind":"def","line":187,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.State.vcs","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L187-L187"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.invariants\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">State</span>.<span class=\"name\">invariants</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State\">State</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Expr.html#Lean.MVarId\">MVarId</a></span></div></div>","info":{"doc":"Holes of type `Invariant` that have been generated so far.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.invariants","kind":"def","line":182,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.State.invariants","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L182-L182"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.State.frameDB\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">State</span>.<span class=\"name\">frameDB</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Inter