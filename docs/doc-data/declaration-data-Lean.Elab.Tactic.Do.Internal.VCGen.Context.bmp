ub.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L136-L136"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Scope.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Scope</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Tactic/Do/Attr.html#Lean.Elab.Tactic.Do.Internal.SpecAttr.SpecTheorems\">Lean.Elab.Tactic.Do.Internal.SpecAttr.SpecTheorems</a> →\n  <span class=\"fn\"><span class=\"fn\"><a href=\"./Lean/Expr.html#Lean.FVarIdMap\">Lean.FVarIdMap</a> <a href=\"./Lean/Elab/Tactic/Do/VCGen/Basic.html#Lean.Elab.Tactic.Do.JumpSiteInfo\">Lean.Elab.Tactic.Do.JumpSiteInfo</a></span> → <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Expr.html#Lean.FVarId\">Lean.FVarId</a></span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Scope\">Lean.Elab.Tactic.Do.Internal.VCGen.Scope</a></span></span></span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Scope.mk","kind":"ctor","line":134,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Scope.mk","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L134-L144"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Scope\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Scope</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Scope","kind":"structure","line":134,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Scope","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L134-L144"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.untilPat?\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">untilPat?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Meta/Sym/Pattern.html#Lean.Meta.Sym.Pattern\">Meta.Sym.Pattern</a></span></div></div>","info":{"doc":"The `until` pattern: when `some pat`, VC generation stops and emits the current goal as a VC\nonce the program in `wp⟦e⟧` matches `pat`, before applying a spec. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.untilPat?","kind":"def","line":132,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.untilPat?","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L132-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.invariantAlts\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">invariantAlts</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Data/HashMap/Basic.html#Std.HashMap\">Std.HashMap</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a> <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a></span></div></div>","info":{"doc":"Pre-parsed `invariants`/`invariants?` alternatives, indexed by 1-based invariant\nnumber. Bullet form maps positions to entries (`bullet n+1 → alt`); labelled form maps\nthe parsed `inv<n>` numbers (out-of-order labels are supported). Empty when no\n`invariants` clause is provided or in `invariants?` (suggest) mode (handled separately). ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.invariantAlts","kind":"def","line":129,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.invariantAlts","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L129-L129"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.internalize\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">internalize</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `internalize` config option: when `true` (default), `emitVC` and the\nmulti-subgoal fork in `Driver.work` call `Grind.processHypotheses`. The tactic-mode\nentry point disables this when there is no `with` clause. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.internalize","kind":"def","line":124,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.internalize","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L124-L124"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.debug\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">debug</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `debug` config option: when `true`, `tryApplyRule` retries failed\n`BackwardRule.apply` calls after `unfoldReducible` and reports an error when the\nretry succeeds, pinpointing missing normalization steps in `vcgen`. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.debug","kind":"def","line":120,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.debug","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L120-L120"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.errorOnMissingSpec\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">errorOnMissingSpec</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `errorOnMissingSpec` config option: when `true` (default), a program with no matching\nspec raises a hard error. When `false`, the goal is emitted as an unsolved VC for the user to\ndischarge — useful with `vcgen [-some_spec]` patterns where the user knows the spec is\nintentionally removed and wants to handle the residual goal by hand. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.errorOnMissingSpec","kind":"def","line":116,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.errorOnMissingSpec","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L116-L116"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.useJP\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">useJP</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `jp` config option: when `true`, `tryLetIntro` recognises `__do_jp` lets\nwhose body is a splitter and sets up shared-continuation handling instead of\nzeta-unfolding. When `false` (default, matching original `mvcgen`), every call\nsite of the JP zeta-unfolds, leading to exponential blow-up on nested splits. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.useJP","kind":"def","line":111,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.useJP","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L111-L111"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.trivial\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">trivial</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `trivial` config option: when `true` (default), `Driver.emitVC` runs\n`solveTrivialConjuncts` to collapse trivial `And.intro` chains; when `false`, the goal is\nemitted as-is. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.trivial","kind":"def","line":106,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.trivial","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L106-L106"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.hypSimpMethods\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\