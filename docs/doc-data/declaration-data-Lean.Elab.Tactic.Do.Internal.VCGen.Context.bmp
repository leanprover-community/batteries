tic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.untilPat?","kind":"def","line":118,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.untilPat?","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L118-L118"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.invariantAlts\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">invariantAlts</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Data/HashMap/Basic.html#Std.HashMap\">Std.HashMap</a> <a href=\"./Init/Prelude.html#Nat\">Nat</a> <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a></span></div></div>","info":{"doc":"Pre-parsed `invariants`/`invariants?` alternatives, indexed by 1-based invariant\nnumber. Bullet form maps positions to entries (`bullet n+1 → alt`); labelled form maps\nthe parsed `inv<n>` numbers (out-of-order labels are supported). Empty when no\n`invariants` clause is provided or in `invariants?` (suggest) mode (handled separately). ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.invariantAlts","kind":"def","line":115,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.invariantAlts","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L115-L115"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.internalize\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">internalize</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `internalize` config option: when `true` (default), `emitVC` and the\nmulti-subgoal fork in `Driver.work` call `Grind.processHypotheses`. The tactic-mode\nentry point disables this when there is no `with` clause. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.internalize","kind":"def","line":110,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.internalize","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L110-L110"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.debug\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">debug</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `debug` config option: when `true`, `tryApplyRule` retries failed\n`BackwardRule.apply` calls after `unfoldReducible` and reports an error when the\nretry succeeds, pinpointing missing normalization steps in `mvcgen'`. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.debug","kind":"def","line":106,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.debug","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L106-L106"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.errorOnMissingSpec\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">errorOnMissingSpec</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `errorOnMissingSpec` config option: when `true` (default), `Driver.work`\nraises a hard error when `solve` returns `.noSpecFoundForProgram`. When `false`,\nthe goal is emitted as an unsolved VC for the user to discharge — useful with\n`mvcgen' [-some_spec]` patterns where the user knows the spec is intentionally\nremoved and wants to handle the residual goal by hand. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.errorOnMissingSpec","kind":"def","line":102,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.errorOnMissingSpec","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L102-L102"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.useJP\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">useJP</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `jp` config option: when `true`, `tryLetIntro` recognises `__do_jp` lets\nwhose body is a splitter and sets up shared-continuation handling instead of\nzeta-unfolding. When `false` (default, matching original `mvcgen`), every call\nsite of the JP zeta-unfolds, leading to exponential blow-up on nested splits. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.useJP","kind":"def","line":96,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.useJP","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L96-L96"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.trivial\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</span>.<span class=\"name\">VCGen</span>.<span class=\"name\">Context</span>.<span class=\"name\">trivial</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context\">Context</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"The `trivial` config option: when `true` (default), `Driver.emitVC` runs\n`repeatAndRfl` to collapse trivial `And.intro` chains; when `false`, the goal is\nemitted as-is. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.trivial","kind":"def","line":91,"name":"Lean.Elab.Tactic.Do.Internal.VCGen.Context.trivial","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/Context.lean#L91-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/Context.html#Lean.Elab.Tactic.Do.Internal.VCGen.Context.hypSimpMethods\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">Internal</