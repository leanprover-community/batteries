nit\">PUnit</a> → <span class=\"fn\">Pred</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">epost</span> : <span class=\"fn\">EPred</span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">name</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">as</span> : <span class=\"fn\">Pred</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Std/Internal/Do/Order/Frame.html#Lean.Order.Frame\">Lean.Order.Frame</a> <span class=\"fn\">Pred</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Internal/Do/Triple/Basic.html#Std.Internal.Do.Triple\">Triple</a> <span class=\"fn\">(<a href=\"./Std/Internal/Do/Order/Basic.html#Lean.Order.meet\">Lean.Order.meet</a> <span class=\"fn\">as</span> <span class=\"fn\">(<a href=\"./Std/Internal/Do/Order/Frame.html#Lean.Order.himp\">Lean.Order.himp</a> <span class=\"fn\">as</span> <span class=\"fn\">(<span class=\"fn\">post</span> <a href=\"./Init/Prelude.html#PUnit.unit\">PUnit.unit</a>)</span>)</span>)</span> <span class=\"fn\">(<a href=\"./Std/Internal/Do/Triple/Gadget.html#Std.Internal.Do.assertGadget\">Do.assertGadget</a> <span class=\"fn\">name</span> <span class=\"fn\">as</span>)</span> <span class=\"fn\">post</span> <span class=\"fn\">epost</span></span></div></div>","info":{"doc":"Specification for `assertGadget`: the precondition requires both the assertion `as` and\nthe Heyting implication `as ⇨ post ⟨⟩`, ensuring the assertion holds and the postcondition\nfollows from it. ","docLink":"./Std/Internal/Do/Triple/Gadget.html#Std.Internal.Do.Spec.assertGadget","kind":"theorem","line":31,"name":"Std.Internal.Do.Spec.assertGadget","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Std/Internal/Do/Triple/Gadget.lean#L31-L38"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Do/Triple/Gadget.html#Std.Internal.Do.assertGadget\"><span class=\"name\">Std</span>.<span class=\"name\">Internal</span>.<span class=\"name\">Do</span>.<span class=\"name\">assertGadget</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./foundational_types.html\">Type</a> v</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Pred </span><span class=\"fn\">EPred</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Monad\">Monad</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Std/Internal/Do/Assertion.html#Std.Internal.Do.Assertion\">Assertion</a> <span class=\"fn\">Pred</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Std/Internal/Do/Assertion.html#Std.Internal.Do.Assertion\">Assertion</a> <span class=\"fn\">EPred</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Std/Internal/Do/WP/Basic.html#Std.Internal.Do.WPMonad\">WPMonad</a> <span class=\"fn\">m</span> <span class=\"fn\">Pred</span> <span class=\"fn\">EPred</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">name</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Lean.Name</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">as</span> : <span class=\"fn\">Pred</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#PUnit\">PUnit</a></span></div></div>","info":{"doc":"A no-op computation used as a verification gadget to inject assertions into the program.\n\nThe `name` parameter is used by VCGen to name the introduced hypothesis. The `as` parameter\nis the assertion to be checked. At runtime, `assertGadget` is simply `pure ⟨⟩`. ","docLink":"./Std/Internal/Do/Triple/Gadget.html#Std.Internal.Do.assertGadget","kind":"def","line":25,"name":"Std.Internal.Do.assertGadget","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Std/Internal/Do/Triple/Gadget.lean#L25-L29"}}],"imports":["Std.Internal.Do.Order.Frame","Std.Internal.Do.Triple.Basic"],"instances":[],"name":"Std.Internal.Do.Triple.Gadget"}