cArg.html#Lean.Elab.Structural.prettyParam\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Structural</span>.<span class=\"name\">prettyParam</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">xs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">i</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> <a href=\"./Lean/Message.html#Lean.MessageData\">MessageData</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/PreDefinition/Structural/FindRecArg.html#Lean.Elab.Structural.prettyParam","kind":"def","line":19,"name":"Lean.Elab.Structural.prettyParam","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/PreDefinition/Structural/FindRecArg.lean#L19-L22"}}],"imports":["Init.Omega","Lean.Elab.PreDefinition.Structural.Basic","Lean.Elab.PreDefinition.Structural.RecArgInfo","Lean.Elab.PreDefinition.TerminationMeasure"],"instances":[],"name":"Lean.Elab.PreDefinition.Structural.FindRecArg"}