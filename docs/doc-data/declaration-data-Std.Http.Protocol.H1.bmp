.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span></div></div>","info":{"doc":"Advances reader-side state machine by one logical transition.\n\nDispatches parsing work according to current reader state (start-line, headers,\nbody, completion, or failure handling).\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.processRead","kind":"opaque","line":1582,"name":"Std.Http.Protocol.H1.Machine.processRead","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L1582-L1608"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.processWrite\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">processWrite</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span></div></div>","info":{"doc":"Advances writer-side state machine by one logical transition.\n\nDepending on writer state, this may:\n- request an application answer,\n- serialize headers,\n- flush fixed/chunked body bytes,\n- finalize/close after completion.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.processWrite","kind":"opaque","line":1188,"name":"Std.Http.Protocol.H1.Machine.processWrite","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L1188-L1227"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.takeOutput\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">takeOutput</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Std/Http/Internal/ChunkedBuffer.html#Std.Http.Internal.ChunkedBuffer\">Internal.ChunkedBuffer</a></div></div>","info":{"doc":"Takes and clears accumulated output bytes, returning them as a buffer.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.takeOutput","kind":"def","line":1007,"name":"Std.Http.Protocol.H1.Machine.takeOutput","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L1007-L1013"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.takeEvents\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">takeEvents</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <span class=\"fn\">(<a href=\"./Std/Http/Protocol/H1/Event.html#Std.Http.Protocol.H1.Event\">Event</a> <span class=\"fn\">dir</span>)</span></span></div></div>","info":{"doc":"Takes and clears all accumulated events, returning the drained array.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.takeEvents","kind":"def","line":1000,"name":"Std.Http.Protocol.H1.Machine.takeEvents","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L1000-L1005"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.sendData\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">sendData</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">data</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Std/Http/Data/Chunk.html#Std.Http.Chunk\">Chunk</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span></div></div>","info":{"doc":"Enqueues body chunks into the writer buffer for encoding and sending.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.sendData","kind":"def","line":988,"name":"Std.Http.Protocol.H1.Machine.sendData","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L988-L998"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.closeWithError\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">closeWithError</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction.receiving\">Direction.receiving</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">status</span> : <a href=\"./Std/Http/Data/Status.html#Std.Http.Status\">Status</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction.receiving\">Direction.receiving</a></span></div></div>","info":{"doc":"Sends an error response with `Connection: close` and shuts down input.\n\nIf the machine is waiting to send a message, sends `status` with a `Connection: close`\nheader and signals that the body is done (letting the step function encode and flush the\nresponse), then stops accepting further input. Otherwise, closes the writer directly and\nstops accepting further input.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.closeWithError","kind":"def","line":971,"name":"Std.Http.Protocol.H1.Machine.closeWithError","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L971-L986"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.canContinue\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">canContinue</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">status</span> : <a href=\"./Std/Http/Data/Status.html#Std.Http.Status\">Status</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span></div></div>","info":{"doc":"Resolves an `Expect: 100-continue` decision.\n\nWhen `status` is `100 Continue`, sends the interim response and advances to body\nreading. For any other status, sends the rejection response (typically 417), disables\nkeep-alive, and closes the reader — the body will not be received.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.canContinue","kind":"def","line":946,"name":"Std.Http.Protocol.H1.Machine.canContinue","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L946-L969"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.send\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Machine</span>.<span class=\"name\">send</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">machine</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">message</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Message.Head\">Message.Head</a> <span class=\"fn\"><span class=\"fn\">dir</span>.<a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction.swap\">swap</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine\">Machine</a> <span class=\"fn\">dir</span></span></div></div>","info":{"doc":"Send the head of a message to the machine.\n\nMust only be called when `machine.isWaitingMessage` is true. If called in any\nother state (e.g. called twice), the machine panics.\n\nInformational (1xx) responses are written directly to the output buffer; the writer\nstays in `waitingHeaders` so the application can send additional interim responses or\nthe final response. The reader state is not affected — use `canContinue` to resolve\nan `Expect: 100-continue` decision separately.\n","docLink":"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.send","kind":"def","line":896,"name":"Std.Http.Protocol.H1.Machine.send","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Protocol/H1.lean#L896-L944"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1.html#Std.Http.Protocol.H1.Machine.suppressOutgoingBody\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"