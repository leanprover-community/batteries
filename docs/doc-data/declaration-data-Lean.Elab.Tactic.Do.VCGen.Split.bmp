61/src/Lean/Elab/Tactic/Do/VCGen/Split.lean#L136-L169"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.withAbstract\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SplitInfo</span>.<span class=\"name\">withAbstract</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> → <a href=\"./foundational_types.html\">Type</a> u_1</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#MonadLiftT\">MonadLiftT</a> <a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Control/Basic.html#MonadControlT\">MonadControlT</a> <a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Monad\">Monad</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">info</span> : <a href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo\">SplitInfo</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">resTy</span> : <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><a href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo\">SplitInfo</a> → <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span> → <span class=\"fn\"><span class=\"fn\">n</span> <span class=\"fn\">α</span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">n</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Introduces fvars for all varying parts of a `SplitInfo` and provides the abstract\n`SplitInfo` and fvars to the continuation.\n\nFor `ite`/`dite`, introduces `c : Prop`, `dec : Decidable c`, `t : mα` (or `t : c → mα`),\n`e : mα` (or `e : ¬c → mα`).\nFor `matcher`, introduces discriminant fvars and alternative fvars, builds a non-dependent\nmotive `fun _ ... _ => mα`, and adjusts matcher universe levels.\n\nThe abstract `SplitInfo` satisfies `abstractInfo.expr = abstractProgram`.\n\nFor `matcher`, the abstract `MatcherApp` stores eta-expanded fvar alts so that\n`splitWith`/`matcherApp.transform` can `instantiateLambda` them directly (no patching needed).\nSince eta-expanded alts like `fun n => alt n` can cause expensive higher-order unification in\nbackward rule patterns, callers building backward rules should eta-reduce them first (e.g.\nvia `Expr.eta` on the alt arguments of `abstractInfo.expr`).\n","docLink":"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.withAbstract","kind":"def","line":60,"name":"Lean.Elab.Tactic.Do.SplitInfo.withAbstract","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/VCGen/Split.lean#L60-L134"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.expr\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SplitInfo</span>.<span class=\"name\">expr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo\">SplitInfo</a> → <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"The expression represented by a `SplitInfo`. ","docLink":"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.expr","kind":"def","line":54,"name":"Lean.Elab.Tactic.Do.SplitInfo.expr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/VCGen/Split.lean#L54-L58"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.altInfos\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SplitInfo</span>.<span class=\"name\">altInfos</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">info</span> : <a href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo\">SplitInfo</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> (<a href=\"./Init/Prelude.html#Nat\">Nat</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></div></div>","info":{"doc":"A list of pairs `(numParams, alt)` per match alternative, where `numParams` is the\nnumber of parameters of the alternative and `alt` is the alternative.\n","docLink":"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.altInfos","kind":"def","line":44,"name":"Lean.Elab.Tactic.Do.SplitInfo.altInfos","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/VCGen/Split.lean#L44-L52"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.resTy\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SplitInfo</span>.<span class=\"name\">resTy</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">info</span> : <a href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo\">SplitInfo</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.SplitInfo.resTy","kind":"def","line":30,"name":"Lean.Elab.Tactic.Do.SplitInfo.resTy","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/Tactic/Do/VCGen/Split.lean#L30-L42"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/VCGen/Split.html#Lean.Elab.Tactic.Do.instInhabitedSplitInfo\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">ins