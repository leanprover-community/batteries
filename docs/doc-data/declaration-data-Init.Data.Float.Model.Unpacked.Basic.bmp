"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.finite\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">UnpackedFloat</span>.<span class=\"name\">finite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">sign</span> : <a href=\"./Init/Data/Float/Model/Unpacked/Sign.html#Float.Model.UnpackedFloat.Sign\">Sign</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">mantissa</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">exponent</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">mantissa_pos</span> : <span class=\"fn\">0</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">mantissa</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat\">UnpackedFloat</a></div></div>","info":{"doc":"Finite floats consisting of a sign bit, a positive natural mantissa and an exponent. ","docLink":"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.finite","kind":"ctor","line":51,"name":"Float.Model.UnpackedFloat.finite","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Unpacked/Basic.lean#L51-L52"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.zero\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">UnpackedFloat</span>.<span class=\"name\">zero</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">sign</span> : <a href=\"./Init/Data/Float/Model/Unpacked/Sign.html#Float.Model.UnpackedFloat.Sign\">Sign</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat\">UnpackedFloat</a></div></div>","info":{"doc":"Signed zero. ","docLink":"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.zero","kind":"ctor","line":49,"name":"Float.Model.UnpackedFloat.zero","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Unpacked/Basic.lean#L49-L50"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.notANumber\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">UnpackedFloat</span>.<span class=\"name\">notANumber</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat\">UnpackedFloat</a></div></div>","info":{"doc":"Not a number. There is no payload attached to a NaN in this format. ","docLink":"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.notANumber","kind":"ctor","line":47,"name":"Float.Model.UnpackedFloat.notANumber","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Unpacked/Basic.lean#L47-L48"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.infinity\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">UnpackedFloat</span>.<span class=\"name\">infinity</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">sign</span> : <a href=\"./Init/Data/Float/Model/Unpacked/Sign.html#Float.Model.UnpackedFloat.Sign\">Sign</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat\">UnpackedFloat</a></div></div>","info":{"doc":"Signed infinity. ","docLink":"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat.infinity","kind":"ctor","line":45,"name":"Float.Model.UnpackedFloat.infinity","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Unpacked/Basic.lean#L45-L46"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat\"><span class=\"name\">Float</span>.<span class=\"name\">Model</span>.<span class=\"name\">UnpackedFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"An inductive type representing a floating-point number with constructors for signed infinity,\nnot-a-number without payload, signed zero, and finite floats with a sign, positive natural\nmantissa and integral exponent.\n\nFinite floats do not have a unique representation in this format: multiplying the\nmantissa by two and decreasing the exponent by one yields a finite float that represents the\nsame rational number.\n\nFor a given `Format`, we say that an unpacked float is in canonical form if the exponent\nis equal to the `targetExponent` according to that format. Some operations on `UnpackedFloat`,\nsuch as `compare`, assume that the input(s) are all in canonical form for the same format.\n\nNote that an unpacked float in canonical form for a given format may not actually be\nrepresentable in that format as the exponent is too large to fit. In this case, the `pack`\nfunction will overflow the float to infinity.\n\nThis type exists solely for the purpose of supporting `Float.Model` and `Float32.Model`. It is not\na goal of this development to serve as the basis for a general-purpose floating-point library or\nto have any direct lemmas written about it at all. Rather, users interested in a library about\nfloating-point numbers should develop such a library completely separately, and users interested in\nproving properties of their programs involving `Float` should prove that the operations defined\nhere are equivalent to the operations defined in the separate library and then transfer lemmas from\nthe library to the `Float` and `Float32` types.\n","docLink":"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat","kind":"inductive","line":19,"name":"Float.Model.UnpackedFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Unpacked/Basic.lean#L19-L53"}}],"imports":["Init.Data.Float.Model.Unpacked.Sign","Init.Data.Int.Repr"],"instances":[{"className":"Repr","name":"Float.Model.instReprUnpackedFloat","typeNames":["Float.Model.UnpackedFloat"]},{"className":"BEq","name":"Float.Model.instBEqUnpackedFloat","typeNames":["Float.Model.UnpackedFloat"]}],"name":"Init.Data.Float.Model.Unpacked.Basic"}