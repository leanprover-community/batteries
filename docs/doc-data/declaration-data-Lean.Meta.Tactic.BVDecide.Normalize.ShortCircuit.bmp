{"declarations":[{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/BVDecide/Normalize/ShortCircuit.html#Lean.Meta.Tactic.BVDecide.Normalize.shortCircuitPass\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">BVDecide</span>.<span class=\"name\">Normalize</span>.<span class=\"name\">shortCircuitPass</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Tactic/BVDecide/Normalize/Basic.html#Lean.Meta.Tactic.BVDecide.Normalize.Pass\">Pass</a></div></div>","info":{"doc":"Responsible for applying short-circuit optimizations for `*`, e.g.,\ntranslating `x1 * y == x2 * y` to `!(!x1 == x2 && !x1 * y == x2 * y)`.\n","docLink":"./Lean/Meta/Tactic/BVDecide/Normalize/ShortCircuit.html#Lean.Meta.Tactic.BVDecide.Normalize.shortCircuitPass","kind":"def","line":23,"name":"Lean.Meta.Tactic.BVDecide.Normalize.shortCircuitPass","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Tactic/BVDecide/Normalize/ShortCircuit.lean#L23-L55"}}],"imports":["Lean.Meta.Tactic.BVDecide.Normalize.Basic","Std.Tactic.BVDecide.Normalize.BitVec"],"instances":[],"name":"Lean.Meta.Tactic.BVDecide.Normalize.ShortCircuit"}