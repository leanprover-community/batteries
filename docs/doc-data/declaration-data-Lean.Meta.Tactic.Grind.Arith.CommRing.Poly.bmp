Init/Grind/Ring/Poly.html#Lean.Grind.CommRing.Mon\">Mon</a> → <a href=\"./Init/Grind/Ring/Poly.html#Lean.Grind.CommRing.Mon\">Mon</a> → <a href=\"./Init/Grind/Ring/Poly.html#Lean.Grind.CommRing.Mon\">Mon</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Lean/Meta/Tactic/Grind/Arith/CommRing/Poly.lean#L14-L22","name":"Lean.Grind.CommRing.Mon.sharesVar","line":14,"kind":"def","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/Poly.html#Lean.Grind.CommRing.Mon.sharesVar","doc":"`sharesVar m₁ m₂` returns `true` if `m₁` and `m₂` shares at least one variable. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Poly.html#Lean.Grind.CommRing.Mon.sharesVar\"><span class=\"name\">Lean</span>.<span class=\"name\">Grind</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">Mon</span>.<span class=\"name\">sharesVar</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Grind/Ring/Poly.html#Lean.Grind.CommRing.Mon\">Mon</a> → <a href=\"./Init/Grind/Ring/Poly.html#Lean.Grind.CommRing.Mon\">Mon</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>"}]}