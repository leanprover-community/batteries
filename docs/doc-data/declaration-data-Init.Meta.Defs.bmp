def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Meta/Defs.html#Lean.Syntax.mkNatLit\"><span class=\"name\">Lean</span>.<span class=\"name\">Syntax</span>.<span class=\"name\">mkNatLit</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">val</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">info</span> : <a href=\"./Init/Prelude.html#Lean.SourceInfo\">SourceInfo</a> := <a href=\"./Init/Prelude.html#Lean.SourceInfo.none\">SourceInfo.none</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.NumLit\">NumLit</a></div></div>","info":{"doc":"Creates literal syntax for a natural number.\n\nIf `info` is provided, then the literal's source information is copied from it.\n","docLink":"./Init/Meta/Defs.html#Lean.Syntax.mkNatLit","kind":"def","line":890,"name":"Lean.Syntax.mkNatLit","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Meta/Defs.lean#L890-L896"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Meta/Defs.html#Lean.Syntax.mkNumLit\"><span class=\"name\">Lean</span>.<span class=\"name\">Syntax</span>.<span class=\"name\">mkNumLit</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">val</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">info</span> : <a href=\"./Init/Prelude.html#Lean.SourceInfo\">SourceInfo</a> := <a href=\"./Init/Prelude.html#Lean.SourceInfo.none\">SourceInfo.none</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.NumLit\">NumLit</a></div></div>","info":{"doc":"Creates literal syntax for a number, which is provided as a string. The caller must ensure that the\nstring is a valid token for the `num` token parser.\n\nIf `info` is provided, then the literal's source information is copied from it.\n","docLink":"./Init/Meta/Defs.html#Lean.Syntax.mkNumLit","kind":"def","line":881,"name":"Lean.Syntax.mkNumLit","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Meta/Defs.lean#L881-L888"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Meta/Defs.html#Lean.Syntax.mkStrLit\"><span class=\"name\">Lean</span>.<span class=\"name\">Syntax</span>.<span class=\"name\">mkStrLit</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">val</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">info</span> : <a href=\"./Init/Prelude.html#Lean.SourceInfo\">SourceInfo</a> := <a href=\"./Init/Prelude.html#Lean.SourceInfo.none\">SourceInfo.none</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.StrLit\">StrLit</a></div></div>","info":{"doc":"Creates literal syntax for the given string.\n\nIf `info` is provided, then the literal's source information is copied from it.\n","docLink":"./Init/Meta/Defs.html#Lean.Syntax.mkStrLit","kind":"def","line":873,"name":"Lean.Syntax.mkStrLit","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Meta/Defs.lean#L873-L879"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Meta/Defs.html#Lean.Syntax.mkCharLit\"><span class=\"name\">Lean</span>.<span class=\"name\">Syntax</span>.<span class=\"name\">mkCharLit</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class