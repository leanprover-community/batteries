over/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Arith/Poly.lean#L91-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult.spol\"><span class=\"name\">Lean</span>.<span class=\"name\">Grind</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">SPolResult</span>.<span class=\"name\">spol</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult\">SPolResult</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Grind/Ring/CommSolver.html#Lean.Grind.CommRing.Poly\">Poly</a></div></div>","info":{"doc":"The computed S-polynomial. ","docLink":"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult.spol","kind":"def","line":89,"name":"Lean.Grind.CommRing.SPolResult.spol","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Arith/Poly.lean#L89-L89"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Grind</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">SPolResult</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Grind/Ring/CommSolver.html#Lean.Grind.CommRing.Poly\">Lean.Grind.CommRing.Poly</a> →\n  <span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <span class=\"fn\"><a href=\"./Init/Grind/Ring/CommSolver.html#Lean.Grind.CommRing.Mon\">Lean.Grind.CommRing.Mon</a> → <span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <span class=\"fn\"><a href=\"./Init/Grind/Ring/CommSolver.html#Lean.Grind.CommRing.Mon\">Lean.Grind.CommRing.Mon</a> → <a href=\"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult\">Lean.Grind.CommRing.SPolResult</a></span></span></span></span></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult.mk","kind":"ctor","line":83,"name":"Lean.Grind.CommRing.SPolResult.mk","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Arith/Poly.lean#L83-L97"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult\"><span class=\"name\">Lean</span>.<span class=\"name\">Grind</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">SPolResult</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Contains the S-polynomial resulting from superposing two polynomials `p₁` and `p₂`,\nalong with coefficients and monomials used in their construction.\n","docLink":"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.SPolResult","kind":"structure","line":83,"name":"Lean.Grind.CommRing.SPolResult","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Arith/Poly.lean#L83-L97"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Sym/Arith/Poly.html#Lean.Grind.CommRing.Mon.coprime\"><span class=\"name\">Lean</span>.<span class=\"name\">Grind</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">Mon</span>.<span class=\"name\">coprime</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./In