fulBackwardPattern\">String.Slice.Pattern.LawfulBackwardPattern</a> <span class=\"fn\">pat</span></span></span></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.LawfulBackwardPattern.mk","kind":"ctor","line":368,"name":"String.Slice.Pattern.LawfulBackwardPattern.mk","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/String/Pattern/Basic.lean#L368-L385"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.LawfulBackwardPattern\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">Pattern</span>.<span class=\"name\">LawfulBackwardPattern</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A lawful backward pattern is one where the three functions `BackwardPattern.skipSuffix?`,\n`BackwardPattern.skipSuffixOfNonempty?` and `BackwardPattern.endsWith` agree for any\ngiven input slice.\n\nNote that this is a relatively weak condition. It is non-uniform in the sense that the functions\ncan still return completely different results on different slices, even if they represent the same\nstring.\n\nThere is a stronger lawfulness typeclass `LawfulBackwardPatternModel` that asserts that the\n`BackwardPattern.skipSuffix?` function behaves like a function that skips the longest prefix\naccording to some notion of matching.\n","docLink":"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.LawfulBackwardPattern","kind":"class","line":368,"name":"String.Slice.Pattern.LawfulBackwardPattern","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/String/Pattern/Basic.lean#L368-L385"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern.endsWith\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">Pattern</span>.<span class=\"name\">BackwardPattern</span>.<span class=\"name\">endsWith</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Checks whether the slice ends with the pattern.\n  ","docLink":"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern.endsWith","kind":"def","line":366,"name":"String.Slice.Pattern.BackwardPattern.endsWith","sourceLink":"https://gi