_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1/Writer.html#Std.Http.Protocol.H1.Writer\">Writer</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Running total of bytes across all `userData` chunks, maintained incrementally\nto avoid an O(n) fold on every fixed-length write step.\n","docLink":"./Std/Http/Protocol/H1/Writer.html#Std.Http.Protocol.H1.Writer.userDataBytes","kind":"def","line":132,"name":"Std.Http.Protocol.H1.Writer.userDataBytes","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Std/Http/Protocol/H1/Writer.lean#L132-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Protocol/H1/Writer.html#Std.Http.Protocol.H1.Writer.omitBody\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">Protocol</span>.<span class=\"name\">H1</span>.<span class=\"name\">Writer</span>.<span class=\"name\">omitBody</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">dir</span> : <a href=\"./Std/Http/Protocol/H1/Message.html#Std.Http.Protocol.H1.Direction\">Direction</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Std/Http/Protocol/H1/Writer.html#Std.Http.Protocol.H1.Writer\">Writer</a> <span class=\"fn\">dir</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div