e5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L97-L98"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append.PlausibleStep\"><span class=\"name\">Std</span>.<span class=\"name\">Iterators</span>.<span class=\"name\">Types</span>.<span class=\"name\">Append</span>.<span class=\"name\">PlausibleStep</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β </span><span class=\"fn\">α₁ </span><span class=\"fn\">α₂</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterator\">Iterator</a> <span class=\"fn\">α₁</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterator\">Iterator</a> <span class=\"fn\">α₂</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span> → <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterStep\">IterStep</a> <span class=\"fn\">(<a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span>)</span> <span class=\"fn\">β</span></span> → <a href=\"./foundational_types.html\">Prop</a></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append.PlausibleStep","kind":"inductive","line":95,"name":"Std.Iterators.Types.Append.PlausibleStep","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L95-L110"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.IterM.Intermediate.appendSnd\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">Intermediate</span>.<span class=\"name\">appendSnd</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β </span><span class=\"fn\">α₂</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterator\">Iterator</a> <span class=\"fn\">α₂</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α₁</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">it₂</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span></div></div>","info":{"doc":"This combinator is only useful for advanced use cases.\n\nGiven an iterator `it₂`, `IterM.Intermediate.appendSnd α₁ it₂` returns an iterator that behaves\nexactly like `it₂` but has the same type as `it₁.append it₂` (after `it₁` has been exhausted).\nThis is useful for constructing intermediate states of the append iterator.\n\n**Marble diagram:**\n\n```text\nit₂                                  --a--b--⊥\nIterM.Intermediate.appendSnd α₁ it₂  --a--b--⊥\n```\n\n**Termination properties:**\n\n* `Finite` instance: only if `it₂` and iterators of type `α₁` are finite\n* `Productive` instance: only if `it₂` and iterators of type `α₁` are productive\n\nNote: If iterators of type `α₁` are not finite, then `appendSnd α₁ it₂` can be productive\nwhile `it₂` is not. The standard library does not provide a `Productive` instance for this case.\n\n**Performance:**\n\nThis combinator incurs an additional O(1) cost with each output of `it₂`.\n","docLink":"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.IterM.Intermediate.appendSnd","kind":"def","line":63,"name":"Std.IterM.Intermediate.appendSnd","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L63-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.IterM.append\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">append</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β </span><span class=\"fn\">α₁ </span><span class=\"fn\">α₂</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterator\">Iterator</a> <span class=\"fn\">α₁</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterator\">Iterator</a> <span class=\"fn\">α₂</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">it₁</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">it₂</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span></div></div>","info":{"doc":"Given two iterators `it₁` and `it₂`, `it₁.append it₂` is an iterator that first outputs all values\nof `it₁` in order and then all values of `it₂` in order.\n\n**Marble diagram:**\n\n```text\nit₁                 ---a----b---c--⊥\nit₂                                 --d--e--⊥\nit₁.append it₂      ---a----b---c-----d--e--⊥\n```\n\n**Termination properties:**\n\n* `Finite` instance: only if `it₁` and `it₂` are finite\n* `Productive` instance: only if `it₁` and `it₂` are productive\n\nNote: If `it₁` is not finite, then `it₁.append it₂` can be productive while `it₂` is not.\nThe standard library does not provide a `Productive` instance for this case.\n\n**Performance:**\n\nThis combinator incurs an additional O(1) cost with each output of `it₁` and `it₂`.\n","docLink":"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.IterM.append","kind":"def","line":34,"name":"Std.IterM.append","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L34-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append.snd\"><span class=\"name\">Std</span>.<span class=\"name\">Iterators</span>.<span class=\"name\">Types</span>.<span class=\"name\">Append</span>.<span class=\"name\">snd</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α₁ </span><span class=\"fn\">α₂</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span> → <span class=\"fn\"><a href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append\">Append</a> <span class=\"fn\">α₁</span> <span class=\"fn\">α₂</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append.snd","kind":"ctor","line":30,"name":"Std.Iterators.Types.Append.snd","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L30-L30"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append.fst\"><span class=\"name\">Std</span>.<span class=\"name\">Iterators</span>.<span class=\"name\">Types</span>.<span class=\"name\">Append</span>.<span class=\"name\">fst</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α₁ </span><span class=\"fn\">α₂</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span> → <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span> → <span class=\"fn\"><a href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append\">Append</a> <span class=\"fn\">α₁</span> <span class=\"fn\">α₂</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append.fst","kind":"ctor","line":29,"name":"Std.Iterators.Types.Append.fst","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L29-L29"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append\"><span class=\"name\">Std</span>.<span class=\"name\">Iterators</span>.<span class=\"name\">Types</span>.<span class=\"name\">Append</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α₁ </span><span class=\"fn\">α₂</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> w</div></div>","info":{"doc":"The internal state of the `IterM.append` iterator combinator.\n","docLink":"./Init/Data/Iterators/Combinators/Monadic/Append.html#Std.Iterators.Types.Append","kind":"inductive","line":25,"name":"Std.Iterators.Types.Append","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Iterators/Combinators/Monadic/Append.lean#L25-L30"}}],"imports":["Init.ByCases","Init.Classical","Init.Data.Iterators.Consumers.Monadic.Loop","Init.Data.Option.Lemmas","Init.Omega"],"instances":[{"className":"Std.Iterator","name":"Std.Iterators.Types.Append.instIterator","typeNames":["Std.Iterators.Types.Append"]},{"className":"Std.IteratorLoop","name":"Std.Iterators.Types.Append.instIteratorLoop","typeNames":["Std.Iterators.Types.Append"]},{"className":"Std.Iterators.Finite","name":"Std.Iterators.Types.Append.instFinite","typeNames":["Std.Iterators.Types.Append"]},{"className":"Std.Iterators.Productive","name":"Std.Iterators.Types.Append.instProductive","typeNames":["Std.Iterators.Types.Append"]}],"name":"Init.Data.Iterators.Combinators.Monadic.Append"}