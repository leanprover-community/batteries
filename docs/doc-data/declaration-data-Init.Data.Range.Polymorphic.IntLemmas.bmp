s=\"fn\"><span class=\"fn\">((<span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toList\">toList</a></span> <a href=\"./Init/Prelude.html#ite\">else</a> <a href=\"./Init/Prelude.html#List.nil\">[</a><a href=\"./Init/Prelude.html#List.nil\">]</a></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_rcc_eq_if","kind":"theorem","line":530,"name":"Int.toList_rcc_eq_if","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L530-L533"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toArray_toList_rcc\"><span class=\"name\">Int</span>.<span class=\"name\">toArray_toList_rcc</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toList\">toList</a></span>.<a href=\"./Init/Prelude.html#List.toArray\">toArray</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toArray\">toArray</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toArray_toList_rcc","kind":"theorem","line":525,"name":"Int.toArray_toList_rcc","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L525-L528"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_toArray_rcc\"><span class=\"name\">Int</span>.<span class=\"name\">toList_toArray_rcc</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toArray\">toArray</a></span>.<a href=\"./Init/Prelude.html#Array.toList\">toList</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toList\">toList</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_toArray_rcc","kind":"theorem","line":520,"name":"Int.toList_toArray_rcc","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L520-L523"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_rcc_eq_toList_rco\"><span class=\"name\">Int</span>.<span class=\"name\">toList_rcc_eq_toList_rco</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toList\">toList</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...<span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rco.toList\">toList</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_rcc_eq_toList_rco","kind":"theorem","line":516,"name":"Int.toList_rcc_eq_toList_rco","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L516-L518"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_rco_right\"><span class=\"name\">Int</span>.<span class=\"name\">induct_rco_right</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">motive</span> : <span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">base</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">b</span> → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> (<span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"Induction principle for proving properties of `Int`\\-based ranges of the form `a...b` by\nvarying the upper bound\\.\n\nIn the `base` case, one proves that for any `a : Int` and `b : Int` with\n`b ≤ a`, the statement holds for the empty range `a...b`\\.\n\nIn the `step` case, one proves that for any `a : Int` and `b : Int`, if the\nstatement holds for `a...b`, it also holds for the larger range `a...(b + 1)`\\.\n\nThe following is an example reproving `length_toList_rco`\\.\n\n```\nexample (a b : Int) : (a...b).toList.length = (b - a).toNat := by\n  induction a, b using Int.induct_rco_right\n  case base =>\n    simp only [Int.toList_rco_eq_nil, List.length_nil, Int.zero_eq_toNat_sub_iff, *]\n  case step a b hle ih =>\n    rw [Int.toList_rco_eq_append (by omega),\n      List.length_append, List.length_singleton, Int.add_sub_cancel, ih]\n    omega\n```\n","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_rco_right","kind":"theorem","line":480,"name":"Int.induct_rco_right","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L480-L514"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_rco_left\"><span class=\"name\">Int</span>.<span class=\"name\">induct_rco_left</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">motive</span> : <span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">base</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">b</span> → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">motive</span> (<span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>) <span class=\"fn\">b</span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"Induction principle for proving properties of `Int`\\-based ranges of the form `a...b` by\nvarying the lower bound\\.\n\nIn the `base` case, one proves that for any `a : Int` and `b : Int` with\n`b ≤ a`, the statement holds for the empty range `a...b`\\.\n\nIn the `step` case, one proves that for any `a : Int` and `b : Int`, the\nstatement holds for nonempty ranges `a...b` if it holds for the smaller range\n`(a + 1)...b`\\.\n\nThe following is an example reproving `length_toList_rco`\\.\n\n```\nexample (a b : Int) : (a...b).toList.length = (b - a).toNat := by\n  induction a, b using Int.induct_rco_left\n  case base =>\n    simp [Int.toList_rco_eq_nil, List.length_nil, Int.zero_eq_toNat_sub_iff, *]\n  case step =>\n    simp only [Int.toList_rco_eq_cons, List.length_cons, *]; omega\n```\n","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_rco_left","kind":"theorem","line":447,"name":"Int.induct_rco_left","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L447-L478"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.getD_toArray_rco_eq_fallback\"><span class=\"name\">Int</span>.<span class=\"name\">getD_toArray_rco_eq_fallback</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n </span><span class=\"fn\">fallback</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">i</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\">(<span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HSub.hSub\">-</a> <span class=\"fn\">m</span>).<a href=\"./Init/Data/Int/Basic.html#Int.toNat\">toNat</a></span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">i</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rco.toArray\">toArray</a></span>.<a href=\"./Init/Prelude.html#Array.getD\">getD</a></span> <span class=\"fn\">i</span> <span class=\"fn\">fallback</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">fallback</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.getD_toArray_rco_eq_fallback","kind":"theorem","line":439,"name":"Int.getD_toArray_rco_eq_fallback","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L439-L442"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.getD_toArray_rco_eq_add\"><span class=\"name\">Int</span>.<span class=\"name\">getD_toArray_rco_eq_add</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n </span><span class=\"fn\">fallback</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<sp