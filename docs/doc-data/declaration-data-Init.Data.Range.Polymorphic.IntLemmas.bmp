oc_eq_toList_rco\"><span class=\"name\">Int</span>.<span class=\"name\">toList_roc_eq_toList_rco</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>&lt;...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Roc.toList\">toList</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">((<span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)...<span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rco.toList\">toList</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_roc_eq_toList_rco","kind":"theorem","line":1279,"name":"Int.toList_roc_eq_toList_rco","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L1279-L1281"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_roc_eq_toList_roo\"><span class=\"name\">Int</span>.<span class=\"name\">toList_roc_eq_toList_roo</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>&lt;...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Roc.toList\">toList</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>&lt;...<span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Roo.toList\">toList</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.toList_roc_eq_toList_roo","kind":"theorem","line":1275,"name":"Int.toList_roc_eq_toList_roo","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L1275-L1277"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_roo_right\"><span class=\"name\">Int</span>.<span class=\"name\">induct_roo_right</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">motive</span> : <span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">base</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">b</span> → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> (<span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"Induction principle for proving properties of `Int`\\-based ranges of the form `a<...b` by\nvarying the upper bound\\.\n\nIn the `base` case, one proves that for any `a : Int` and `b : Int` with\n`b ≤ a + 1`, the statement holds for the empty range `a<...b`\\.\n\nIn the `step` case, one proves that for any `a : Int` and `b : Int`, if the\nstatement holds for `a<...b`, it also holds for the larger range `a<...(b + 1)`\\.\n\nThe following is an example reproving `length_toList_roo`\\.\n\n```\nexample (a b : Int) : (a<...b).toList.length = (b - a - 1).toNat := by\n  induction a, b using Int.induct_roo_right\n  case base =>\n    simp only [Int.toList_roo_eq_nil, List.length_nil, *]; omega\n  case step a b hle ih =>\n    rw [Int.toList_roo_eq_append (by omega),\n      List.length_append, List.length_singleton, Int.add_sub_cancel, ih]\n    omega\n```\n","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_roo_right","kind":"theorem","line":1239,"name":"Int.induct_roo_right","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L1239-L1273"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_roo_left\"><span class=\"name\">Int</span>.<span class=\"name\">induct_roo_left</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">motive</span> : <span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">base</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>), <span class=\"fn\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">b</span> → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">motive</span> (<span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>) <span class=\"fn\">b</span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"Induction principle for proving properties of `Int`\\-based ranges of the form `a<...b` by\nvarying the lower bound\\.\n\nIn the `base` case, one proves that for any `a : Int` and `b : Int` with\n`b ≤ a + 1`, the statement holds for the empty range `a<...b`\\.\n\nIn the `step` case, one proves that for any `a : Int` and `b : Int`, the\nstatement holds for nonempty ranges `a<...b` if it holds for the smaller range\n`(a + 1)<...b`\\.\n\nThe following is an example reproving `length_toList_roo`\\.\n\n```\nexample (a b : Int) : (a<...b).toList.length = (b - a - 1).toNat := by\n  induction a, b using Int.induct_roo_left\n  case base =>\n    simp only [Int.toList_roo_eq_nil, List.length_nil, Int.zero_eq_toNat_sub_iff, *]; omega\n  case step =>\n    simp only [Int.toList_roo_eq_cons, List.length_cons, *]; omega\n```\n","docLink":"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.induct_roo_left","kind":"theorem","line":1206,"name":"Int.induct_roo_left","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/IntLemmas.lean#L1206-L1237"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/IntLemmas.html#Int.getD_toArray_roo_eq_fallback\"><span class=\"name\">Int</span>.<span class=\"name\">getD_toArray_roo_eq_fallback</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><spa