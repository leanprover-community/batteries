ded. ","docLink":"./Init/Data/Iterators/Basic.html#Std.Iterators.Finite.wf","kind":"theorem","line":750,"name":"Std.Iterators.Finite.wf","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Init/Data/Iterators/Basic.lean#L750-L750"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Iterators.Finite.mk\"><span class=\"name\">Std</span>.<span class=\"name\">Iterators</span>.<span class=\"name\">Finite</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">∀ {<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w} {<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>} {<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w} [<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterator\">Std.Iterator</a> <span class=\"fn\">α</span> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>],\n  <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/WF.html#WellFounded\">WellFounded</a> <a href=\"./Init/Data/Iterators/Basic.html#Std.IterM.IsPlausibleSuccessorOf\">Std.IterM.IsPlausibleSuccessorOf</a></span> → <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iterators.Finite\">Std.Iterators.Finite</a> <span class=\"fn\">α</span> <span class=\"fn\">m</span></span></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.Iterators.Finite.mk","kind":"ctor","line":742,"name":"Std.Iterators.Finite.mk","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Init/Data/Iterators/Basic.lean#L742-L750"}},{"header":"<div class=\"decl_header\"><s