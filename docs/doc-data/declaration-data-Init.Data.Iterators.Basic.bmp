/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L188-L191"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.IterM.toIter\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">toIter</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α </span><span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">it</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <a href=\"./Init/Control/Id.html#Id\">Id</a> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iter\">Iter</a> <span class=\"fn\">β</span></span></div></div>","info":{"doc":"Converts a monadic iterator (`IterM Id β`) over `Id` into a pure iterator (`Iter β`).\n","docLink":"./Init/Data/Iterators/Basic.html#Std.IterM.toIter","kind":"def","line":181,"name":"Std.IterM.toIter","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L181-L186"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Iter.toIterM\"><span class=\"name\">Std</span>.<span class=\"name\">Iter</span>.<span class=\"name\">toIterM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α </span><span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">it</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iter\">Iter</a> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <a href=\"./Init/Control/Id.html#Id\">Id</a> <span class=\"fn\">β</span></span></div></div>","info":{"doc":"Converts a pure iterator (`Iter β`) into a monadic iterator (`IterM Id β`) in the\nidentity monad `Id`.\n","docLink":"./Init/Data/Iterators/Basic.html#Std.Iter.toIterM","kind":"def","line":173,"name":"Std.Iter.toIterM","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L173-L179"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Iter.internalState\"><span class=\"name\">Std</span>.<span class=\"name\">Iter</span>.<span class=\"name\">internalState</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α </span><span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iter\">Iter</a> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">α</span></div></div>","info":{"doc":"Internal implementation detail of the iterator. ","docLink":"./Init/Data/Iterators/Basic.html#Std.Iter.internalState","kind":"def","line":171,"name":"Std.Iter.internalState","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L171-L171"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Iter.mk\"><span class=\"name\">Std</span>.<span class=\"name\">Iter</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α </span><span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">internalState</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Iter\">Iter</a> <span class=\"fn\">β</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.Iter.mk","kind":"ctor","line":169,"name":"Std.Iter.mk","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L169-L169"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Iter\"><span class=\"name\">Std</span>.<span class=\"name\">Iter</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> w</div></div>","info":{"doc":"An iterator that sequentially emits values of type `β`. It may be finite\nor infinite.\n\nSee the root module `Std.Data.Iterators` for a more comprehensive overview over the iterator\nframework.\n\nSee `Std.Data.Iterators.Producers` for ways to iterate over common data structures.\nBy convention, the monadic iterator associated with an object can be obtained via dot notation.\nFor example, `List.iterM IO` creates an iterator over a list in the monad `IO`.\n\nSee `Init.Data.Iterators.Consumers` for ways to use an iterator. For example, `it.toList` will\nconvert a provably finite iterator `it` into a list and `it.allowNontermination.toList` will\ndo so even if finiteness cannot be proved. It is also always possible to manually iterate using\n`it.step`, relying on the termination measures `it.finitelyManySteps` and `it.finitelyManySkips`.\n\nSee `IterM` for iterators that operate in a monad.\n\nInternally, `Iter β` wraps an element of type `α` containing state information.\nThe type `α` determines the implementation of the iterator using a typeclass mechanism.\nThe concrete typeclass implementing the iterator is `Iterator α m β`.\n\nWhen using combinators, `α` can become very complicated. It is an implicit parameter\nof `α` so that the pretty printer will not print this large type by default. If a declaration\nreturns an iterator, the following will not work:\n\n```lean\ndef x : Iter Nat := [1, 2, 3].iter\n```\n\nInstead the declaration type needs to be completely omitted:\n\n```lean\ndef x := [1, 2, 3].iter\n\n-- if you want to ensure that `x` is an iterator emitting `Nat`\ndef x := ([1, 2, 3].iter : Iter Nat)\n```\n","docLink":"./Init/Data/Iterators/Basic.html#Std.Iter","kind":"structure","line":130,"name":"Std.Iter","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L130-L171"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.IterM.internalState\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">internalState</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">α</span></div></div>","info":{"doc":"Internal implementation detail of the iterator. ","docLink":"./Init/Data/Iterators/Basic.html#Std.IterM.internalState","kind":"def","line":128,"name":"Std.IterM.internalState","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L128-L128"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.IterM.mk'\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">mk'</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">internalState</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.IterM.mk'","kind":"ctor","line":126,"name":"Std.IterM.mk'","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L126-L126"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.IterM.ext_iff\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">ext_iff</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.IterM.internalState\">internalState</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.IterM.internalState\">internalState</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.IterM.ext_iff","kind":"theorem","line":124,"name":"Std.IterM.ext_iff","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L124-L124"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.IterM.ext\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span>.<span class=\"name\">ext</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.IterM\">IterM</a> <span class=\"fn\">m</span> <span class=\"fn\">β</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">internalState</span> : <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.IterM.internalState\">internalState</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.IterM.internalState\">internalState</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.IterM.ext","kind":"theorem","line":124,"name":"Std.IterM.ext","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L124-L124"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.IterM\"><span class=\"name\">Std</span>.<span class=\"name\">IterM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> w → <a href=\"./foundational_types.html\">Type</a> w'</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> w</div></div>","info":{"doc":"An iterator that sequentially emits values of type `β` in the monad `m`. It may be finite\nor infinite.\n\nSee the root module `Std.Data.Iterators` for a more comprehensive overview over the iterator\nframework.\n\nSee `Std.Data.Iterators.Producers` for ways to iterate over common data structures.\nBy convention, the monadic iterator associated with an object can be obtained via dot notation.\nFor example, `List.iterM IO` creates an iterator over a list in the monad `IO`.\n\nSee `Init.Data.Iterators.Consumers` for ways to use an iterator. For example, `it.toList` will\nconvert a provably finite iterator `it` into a list and `it.allowNontermination.toList` will\ndo so even if finiteness cannot be proved. It is also always possible to manually iterate using\n`it.step`, relying on the termination measures `it.finitelyManySteps` and `it.finitelyManySkips`.\n\nSee `Iter` for a more convenient interface in case that no monadic effects are needed (`m = Id`).\n\nInternally, `IterM m β` wraps an element of type `α` containing state information.\nThe type `α` determines the implementation of the iterator using a typeclass mechanism.\nThe concrete typeclass implementing the iterator is `Iterator α m β`.\n\nWhen using combinators, `α` can become very complicated. It is an implicit parameter\nof `α` so that the pretty printer will not print this large type by default. If a declaration\nreturns an iterator, the following will not work:\n\n```lean\ndef x : IterM IO Nat := [1, 2, 3].iterM IO\n```\n\nInstead the declaration type needs to be completely omitted:\n\n```lean\ndef x := [1, 2, 3].iterM IO\n\n-- if you want to ensure that `x` is an iterator in `IO` emitting `Nat`\ndef x := ([1, 2, 3].iterM IO : IterM IO Nat)\n```\n","docLink":"./Init/Data/Iterators/Basic.html#Std.IterM","kind":"structure","line":85,"name":"Std.IterM","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L85-L128"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate_inj\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span>.<span class=\"name\">deflate_inj</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate\">deflate</a> <span class=\"fn\">x</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate\">deflate</a> <span class=\"fn\">y</span></span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate_inj","kind":"theorem","line":73,"name":"Std.Shrink.deflate_inj","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L73-L79"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate_inj\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span>.<span class=\"name\">inflate_inj</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink\">Shrink</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate\">inflate</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate\">inflate</a></span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate_inj","kind":"theorem","line":65,"name":"Std.Shrink.inflate_inj","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L65-L71"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate_deflate\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span>.<span class=\"name\">inflate_deflate</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x</span> : <span class=\"fn\">α</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate\">deflate</a> <span class=\"fn\">x</span>)</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate\">inflate</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">x</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate_deflate","kind":"theorem","line":60,"name":"Std.Shrink.inflate_deflate","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L60-L63"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate_inflate\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span>.<span class=\"name\">deflate_inflate</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink\">Shrink</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate\">deflate</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate\">inflate</a></span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">x</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate_inflate","kind":"theorem","line":55,"name":"Std.Shrink.deflate_inflate","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L55-L58"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span>.<span class=\"name\">inflate</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink\">Shrink</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">α</span></div></div>","info":{"doc":"Converts elements of `Shrink α` into elements of `α`\\. ","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink.inflate","kind":"def","line":50,"name":"Std.Shrink.inflate","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L50-L53"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span>.<span class=\"name\">deflate</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Iterators/Basic.html#Std.Shrink\">Shrink</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Converts elements of `α` into elements of `Shrink α`\\. ","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink.deflate","kind":"def","line":45,"name":"Std.Shrink.deflate","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L45-L48"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Iterators/Basic.html#Std.Shrink\"><span class=\"name\">Std</span>.<span class=\"name\">Shrink</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u</div></div>","info":{"doc":"Currently, `Shrink α` is just a wrapper around `α`\\.\n\nIn the future, `Shrink` should allow shrinking `α` into a potentially smaller universe,\ngiven a proof that `α` is actually small, just like Mathlib's `Shrink`, except that\nthe latter's conversion functions are noncomputable\\. Until then, `Shrink α` is always in the\nsame universe as `α`\\.\n\nThis no\\-op type exists so that fewer breaking changes will be needed when the\nreal `Shrink` type is available and the iterators will be made more flexible with regard to\nuniverses\\.\n\nThe conversion functions `Shrink.deflate` and\n`Shrink.inflate` form an equivalence between\n`α` and `Shrink α`, but this equivalence is intentionally not definitional\\.\n","docLink":"./Init/Data/Iterators/Basic.html#Std.Shrink","kind":"def","line":27,"name":"Std.Shrink","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Iterators/Basic.lean#L27-L43"}}],"imports":["Init.Classical","Init.Ext"],"instances":[{"className":"WellFoundedRelation","name":"Std.IterM.TerminationMeasures.instWellFoundedRelationFinite","typeNames":["Std.IterM.TerminationMeasures.Finite"]},{"className":"WellFoundedRelation","name":"Std.IterM.TerminationMeasures.instWellFoundedRelationProductive","typeNames":["Std.IterM.TerminationMeasures.Productive"]},{"className":"Std.Iterators.Productive","name":"Std.Iterators.instProductiveOfFinte","typeNames":[]}],"name":"Init.Data.Iterators.Basic"}