-L57"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.Model.unpack\"><span class=\"name\">Float32</span>.<span class=\"name\">Model</span>.<span class=\"name\">unpack</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Unpacked/Basic.html#Float.Model.UnpackedFloat\">Float.Model.UnpackedFloat</a></div></div>","info":{"doc":"Unpack a `Float32.Model` into the corresponding `UnpackedFloat`. ","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model.unpack","kind":"def","line":46,"name":"Float32.Model.unpack","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L46-L48"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.instDecidableEqModel.decEq\"><span class=\"name\">Float32</span>.<span class=\"name\">instDecidableEqModel</span>.<span class=\"name\">decEq</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x✝ </span><span class=\"fn\">x✝¹</span> : <a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> (<span class=\"fn\">x✝</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">x✝¹</span>)</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Model/Float32.html#Float32.instDecidableEqModel.decEq","kind":"def","line":40,"name":"Float32.instDecidableEqModel.decEq","sourceLink":"http