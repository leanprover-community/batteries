iv>","info":{"doc":"The underlying bit pattern is valid according to the IEEE `binary32` format. ","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model.valid","kind":"theorem","line":39,"name":"Float32.Model.valid","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L39-L39"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.Model.toBits\"><span class=\"name\">Float32</span>.<span class=\"name\">Model</span>.<span class=\"name\">toBits</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#UInt32\">UInt32</a></div></div>","info":{"doc":"The underlying bit pattern of the `Float32.Model`. ","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model.toBits","kind":"def","line":37,"name":"Float32.Model.toBits","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L37-L37"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.Model.mk\"><span class=\"name\">Float32</span>.<span class=\"name\">Model</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">(<span class=\"fn\">toBits</span> : <a href=\"./Init/Prelude.html#UInt32\">UInt32</a>) → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Data/Float/Model/Format/Basic.html#Float.Model.Format.binary32\">Float.Model.Format.binary32</a>.<a href=\"./Init/Data/Float/Model/Format/Valid.html#Float.Model.Format.Valid\">Valid</a></span> <span class=\"fn\"><span class=\"fn\">toBits</span>.<a href=\"./Init/Prelude.html#UInt32.toBitVec\">toBitVec</a></span></span> → <a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Float32.Model</a></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model.mk","kind":"ctor","line":18,"name":"Float32.Model.mk","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L18-L40"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\"><span class=\"name\">Float32</span>.<span class=\"name\">Model</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The logical model for the `Float32` type.\n\nThis is defined as the type of `UInt32` with the additional restriction that bit patterns encoding\na `NaN` must be exactly a chosen canonical `NaN`.\n\nMost functions on `Float32.Model` work by unpacking the `Float32.Model` into the inductive type\n`UnpackedFloat`, performing the operation there, and then repacking the result into a\n`Float32.Model`.\n\nIt is not a goal of this development to serve as the basis for a general-purpose floating-point\nlibrary or to have any direct lemmas written about it at all. Rather, users interested in a library\nabout floating-point numbers should develop such a library completely separately, and users\ninterested in proving properties of their programs involving `Float32` should prove that the\noperations defined here are equivalent to the operations defined in the separate library and then\ntransfer lemmas from the library to the `Float` and `Float32` types.\n","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model","kind":"structure","line":18,"name":"Float32.Model","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L18-L40"}}],"imports":["Init.Data.Float.Model.Format.Valid","Init.Data.Float.Model.Unpacked.Operations","Init.Data.Float.Model.Unpacked.Pack.Lemmas","Init.Data.Order.Factories"],"instances":[{"className":"Decidable","name":"Float32.instDecidableEqModel","typeNames":["Eq"]},{"className":"Add","name":"Float32.Model.instAdd","typeNames":["Float32.Model"]},{"className":"Sub","name":"Float32.Model.instSub","typeNames":["Float32.Model"]},{"className":"Mul","name":"Float32.Model.instMul","typeNames":["Float32.Model"]},{"className":"Div","name":"Float32.Model.instDiv","typeNames":["Float32.Model"]},{"className":"Neg","name":"Float32.Model.instNeg","typeNames":["Float32.Model"]},{"className":"LE","name":"Float32.Model.instLE","typeNames":["Float32.Model"]},{"className":"Decidable","name":"Float32.Model.instDecidableLE","typeNames":["LE.le"]},{"className":"LT","name":"Float32.Model.instLT","typeNames":["Float32.Model"]},{"className":"Decidable","name":"Float32.Model.instDecidableLT","typeNames":["LT.lt"]},{"className":"BEq","name":"Float32.Model.instBEq","typeNames":["Float32.Model"]},{"className":"Min","name":"Float32.Model.instMin","typeNames":["Float32.Model"]},{"className":"Max","name":"Float32.Model.instMax","typeNames":["Float32.Model"]},{"className":"Inhabited","name":"Float32.Model.instInhabited","typeNames":["Float32.Model"]}],"name":"Init.Data.Float.Model.Float32"}