eader\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.Model.mul\"><span class=\"name\">Float32</span>.<span class=\"name\">Model</span>.<span class=\"name\">mul</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a></div></div>","info":{"doc":"Compute the product of two `Float32.Model`.\n","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model.mul","kind":"def","line":71,"name":"Float32.Model.mul","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L71-L75"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Model/Float32.html#Float32.Model.sub\"><span class=\"name\">Float32</span>.<span class=\"name\">Model</span>.<span class=\"name\">sub</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Float32.html#Float32.Model\">Model</a></div></div>","info":{"doc":"Compute the difference of two `Float32.Model`.\n","docLink":"./Init/Data/Float/Model/Float32.html#Float32.Model.sub","kind":"def","line":65,"name":"Float32.Model.sub","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Model/Float32.lean#L65-L69"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class