"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Computes the sine of a floating-point number in radians.\n\nThis function does not reduce in the kernel. It is implemented in compiled code by the C function\n`sin`.\n","docLink":"./Init/Data/Float/Float.html#Float.sin","kind":"opaque","line":316,"name":"Float.sin","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L316-L322"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instReprAtomFloat\"><span class=\"name\">instReprAtomFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Repr.html#ReprAtom\">ReprAtom</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instReprAtomFloat","kind":"instance","line":314,"name":"instReprAtomFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L314-L314"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instReprFloat\"><span class=\"name\">instReprFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Repr.html#Repr\">Repr</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instReprFloat","kind":"instance","line":311,"name":"instReprFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L311-L312"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.repr\"><span class=\"name\">Float</span>.<span class=\"name\">repr</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Data/Float/Float.html#Float\">Float</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">prec</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Format/Basic.html#Std.Format\">Std.Format</a></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#Float.repr","kind":"def","line":308,"name":"Float.repr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L308-L309"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instInhabitedFloat\"><span class=\"name\">instInhabitedFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instInhabitedFloat","kind":"instance","line":305,"name":"instInhabitedFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L305-L306"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#USize.toFloat\"><span class=\"name\">USize</span>.<span class=\"name\">toFloat</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#USize\">USize</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a></div></div>","info":{"doc":"Obtains a `Float` whose value is near the given `USize`.\n\nIt will be exactly the value of the given `USize` if such a `Float` exists. If no such `Float`\nexists, the returned value will either be the smallest `Float` that is larger than the given value,\nor the largest `Float` that is smaller than the given value.\n\nThis function has a logical model in terms of `Float.Model`, but is overridden at runtime with an\nefficient implementation.\n","docLink":"./Init/Data/Float/Float.html#USize.toFloat","kind":"def","line":292,"name":"USize.toFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L292-L303"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#UInt64.toFloat\"><span class=\"name\">UInt64</span>.<span class=\"name\">toFloat</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#UInt64\">UInt64</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a></div></div>","info":{"doc":"Obtains a `Float` whose value is near the given `UInt64`.\n\nIt will be exactly the value of the given `UInt64` if such a `Float` exists. If no such `Float`\nexists, the returned value will either be the smallest `Float` that is larger than the given value,\nor the largest `Float` that is smaller than the given value.\n\nThis function has a logical model in terms of `Float.Model`, but is overridden at runtime with an\nefficient implementation.\n","docLink":"./Init/Data/Float/Float.html#UInt64.toFloat","kind":"def","line":280,"name":"UInt64.toFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L280-L291"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#UInt32.toFloat\"><span class=\"name\">UInt32</span>.<span class=\"name\">toFloat</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#UInt32\">UInt32</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a></div></div>","info":{"doc":"Obtains the `Float` whose value is the same as the given `UInt32`. ","docLink":"./Init/Data/Float/Float.html#UInt32.toFloat","kind":"def","line":277,"name":"UInt32.toFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L277-L279"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#UInt16.toFloat\"><span class=\"name\">UInt16</span>.<span class=\"name\">toFloat</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#UInt16\">UInt16</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a></div></div>","info":{"doc":"Obtains the `Float` whose value is the same as the given `UInt16`. ","docLink":"./Init/Data/Float/Float.html#UInt16.toFloat","kind":"def","line":274,"name":"UInt16.toFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L274-L276"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#UInt8.toFloat\"><span class=\"name\">UInt8</span>.<span class=\"name\">toFloat</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#UInt8\">UInt8</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a></div></div>","info":{"doc":"Obtains the `Float` whose value is the same as the given `UInt8`. ","docLink":"./Init/Data/Float/Float.html#UInt8.toFloat","kind":"def","line":271,"name":"UInt8.toFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L271-L273"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instToStringFloat\"><span class=\"name\">instToStringFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/ToString/Basic.html#ToString\">ToString</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instToStringFloat","kind":"instance","line":268,"name":"instToStringFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L268-L269"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.frExp\"><span class=\"name\">Float</span>.<span class=\"name\">frExp</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a></span></div></div>","info":{"doc":"Splits the given float `x` into a significand/exponent pair `(s, i)` such that `x = s * 2^i` where\n`s ∈ (-1;-0.5] ∪ [0.5; 1)`. Returns an undefined value if `x` is not finite.\n\nThis function does not reduce in the kernel. It is implemented in compiled code by the C function\n`frexp`.\n","docLink":"./Init/Data/Float/Float.html#Float.frExp","kind":"opaque","line":259,"name":"Float.frExp","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L259-L266"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.isInf\"><span class=\"name\">Float</span>.<span class=\"name\">isInf</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Checks whether a floating-point number is a positive or negative infinite number, but not a finite\nnumber or `NaN`.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C operator `isinf`.\n","docLink":"./Init/Data/Float/Float.html#Float.isInf","kind":"def","line":250,"name":"Float.isInf","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L250-L257"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.isFinite\"><span class=\"name\">Float</span>.<span class=\"name\">isFinite</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Checks whether a floating-point number is finite, that is, whether it is normal, subnormal, or zero,\nbut not infinite or `NaN`.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C operator `isfinite`.\n","docLink":"./Init/Data/Float/Float.html#Float.isFinite","kind":"def","line":241,"name":"Float.isFinite","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L241-L248"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.isNaN\"><span class=\"name\">Float</span>.<span class=\"name\">isNaN</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Checks whether a floating point number is `NaN` (“not a number”) value.\n\n`NaN` values result from operations that might otherwise be errors, such as dividing zero by zero.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C operator `isnan`.\n","docLink":"./Init/Data/Float/Float.html#Float.isNaN","kind":"def","line":231,"name":"Float.isNaN","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L231-L239"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toUSize\"><span class=\"name\">Float</span>.<span class=\"name\">toUSize</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#USize\">USize</a></span></div></div>","info":{"doc":"Converts a floating-point number to a word-sized unsigned integer.\n\nIf the given `Float` is non-negative, truncates the value to a positive integer, rounding down and\nclamping to the range of `USize`. Returns `0` if the `Float` is negative or `NaN`, and returns the\nlargest `USize` value (i.e. `USize.size - 1`) if the float is larger than it.\n\nThis function has a logical model in terms of `Float.Model`.\n","docLink":"./Init/Data/Float/Float.html#Float.toUSize","kind":"def","line":219,"name":"Float.toUSize","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L219-L229"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toUInt64\"><span class=\"name\">Float</span>.<span class=\"name\">toUInt64</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#UInt64\">UInt64</a></span></div></div>","info":{"doc":"Converts a floating-point number to a 64-bit unsigned integer.\n\nIf the given `Float` is non-negative, truncates the value to a positive integer, rounding down and\nclamping to the range of `UInt64`. Returns `0` if the `Float` is negative or `NaN`, and returns the\nlargest `UInt64` value (i.e. `UInt64.size - 1`) if the float is larger than it.\n\nThis function has a logical model in terms of `Float.Model`.\n","docLink":"./Init/Data/Float/Float.html#Float.toUInt64","kind":"def","line":208,"name":"Float.toUInt64","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L208-L218"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toUInt32\"><span class=\"name\">Float</span>.<span class=\"name\">toUInt32</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#UInt32\">UInt32</a></span></div></div>","info":{"doc":"Converts a floating-point number to a 32-bit unsigned integer.\n\nIf the given `Float` is non-negative, truncates the value to a positive integer, rounding down and\nclamping to the range of `UInt32`. Returns `0` if the `Float` is negative or `NaN`, and returns the\nlargest `UInt32` value (i.e. `UInt32.size - 1`) if the float is larger than it.\n\nThis function has a logical model in terms of `Float.Model`.\n","docLink":"./Init/Data/Float/Float.html#Float.toUInt32","kind":"def","line":197,"name":"Float.toUInt32","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L197-L207"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toUInt16\"><span class=\"name\">Float</span>.<span class=\"name\">toUInt16</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#UInt16\">UInt16</a></span></div></div>","info":{"doc":"Converts a floating-point number to a 16-bit unsigned integer.\n\nIf the given `Float` is non-negative, truncates the value to a positive integer, rounding down and\nclamping to the range of `UInt16`. Returns `0` if the `Float` is negative or `NaN`, and returns the\nlargest `UInt16` value (i.e. `UInt16.size - 1`) if the float is larger than it.\n\nThis function has a logical model in terms of `Float.Model`.\n","docLink":"./Init/Data/Float/Float.html#Float.toUInt16","kind":"def","line":186,"name":"Float.toUInt16","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L186-L196"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toUInt8\"><span class=\"name\">Float</span>.<span class=\"name\">toUInt8</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#UInt8\">UInt8</a></span></div></div>","info":{"doc":"Converts a floating-point number to an 8-bit unsigned integer.\n\nIf the given `Float` is non-negative, truncates the value to a positive integer, rounding down and\nclamping to the range of `UInt8`. Returns `0` if the `Float` is negative or `NaN`, and returns the\nlargest `UInt8` value (i.e. `UInt8.size - 1`) if the float is larger than it.\n\nThis function has a logical model in terms of `Float.Model`.\n","docLink":"./Init/Data/Float/Float.html#Float.toUInt8","kind":"def","line":175,"name":"Float.toUInt8","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L175-L185"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">opaque</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toString\"><span class=\"name\">Float</span>.<span class=\"name\">toString</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#String\">String</a></span></div></div>","info":{"doc":"Converts a floating-point number to a string.\n\nThis function does not reduce in the kernel.\n","docLink":"./Init/Data/Float/Float.html#Float.toString","kind":"opaque","line":168,"name":"Float.toString","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L168-L173"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.decLe\"><span class=\"name\">Float</span>.<span class=\"name\">decLe</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Float/Float.html#Float\">Float</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> (<span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">b</span>)</span></div></div>","info":{"doc":"Compares two floating point numbers for non-strict inequality.\n\nThis function does not reduce in the kernel. It is compiled to the C inequality operator.\n","docLink":"./Init/Data/Float/Float.html#Float.decLe","kind":"instance","line":160,"name":"Float.decLe","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L160-L166"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.decLt\"><span class=\"name\">Float</span>.<span class=\"name\">decLt</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Float/Float.html#Float\">Float</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> (<span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">b</span>)</span></div></div>","info":{"doc":"Compares two floating point numbers for strict inequality.\n\nThis function does not reduce in the kernel. It is compiled to the C inequality operator.\n","docLink":"./Init/Data/Float/Float.html#Float.decLt","kind":"instance","line":152,"name":"Float.decLt","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L152-L158"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instBEqFloat\"><span class=\"name\">instBEqFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#BEq\">BEq</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instBEqFloat","kind":"instance","line":150,"name":"instBEqFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L150-L150"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.beq\"><span class=\"name\">Float</span>.<span class=\"name\">beq</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Float/Float.html#Float\">Float</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks whether two floating-point numbers are equal according to IEEE 754.\n\nFloating-point equality does not correspond with propositional equality. In particular, it is not\nreflexive since `NaN != NaN`, and it is not a congruence because `0.0 == -0.0`, but\n`1.0 / 0.0 != 1.0 / -0.0`.\n\nThis function does not reduce in the kernel. It is compiled to the C equality operator.\n","docLink":"./Init/Data/Float/Float.html#Float.beq","kind":"def","line":138,"name":"Float.beq","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L138-L148"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instLEFloat\"><span class=\"name\">instLEFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#LE\">LE</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instLEFloat","kind":"instance","line":136,"name":"instLEFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L136-L136"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instLTFloat\"><span class=\"name\">instLTFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#LT\">LT</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instLTFloat","kind":"instance","line":135,"name":"instLTFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L135-L135"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instNegFloat\"><span class=\"name\">instNegFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Neg\">Neg</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instNegFloat","kind":"instance","line":134,"name":"instNegFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L134-L134"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instDivFloat\"><span class=\"name\">instDivFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Div\">Div</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instDivFloat","kind":"instance","line":133,"name":"instDivFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L133-L133"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instMulFloat\"><span class=\"name\">instMulFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Mul\">Mul</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instMulFloat","kind":"instance","line":132,"name":"instMulFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L132-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instSubFloat\"><span class=\"name\">instSubFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Sub\">Sub</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instSubFloat","kind":"instance","line":131,"name":"instSubFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L131-L131"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instAddFloat\"><span class=\"name\">instAddFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Add\">Add</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instAddFloat","kind":"instance","line":130,"name":"instAddFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L130-L130"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toBits\"><span class=\"name\">Float</span>.<span class=\"name\">toBits</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#UInt64\">UInt64</a></span></div></div>","info":{"doc":"Bit-for-bit conversion to `UInt64`. Interprets a `Float` as a `UInt64`, ignoring the numeric value\nand treating the `Float`'s bit pattern as a `UInt64`.\n\n`Float`s and `UInt64`s have the same endianness on all supported platforms. IEEE 754 very precisely\nspecifies the bit layout of floats.\n\nThis function is distinct from `Float.toUInt64`, which attempts to preserve the numeric value rather\nthan reinterpreting the bit pattern.\n","docLink":"./Init/Data/Float/Float.html#Float.toBits","kind":"def","line":117,"name":"Float.toBits","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L117-L128"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.ofBits\"><span class=\"name\">Float</span>.<span class=\"name\">ofBits</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#UInt64\">UInt64</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Bit-for-bit conversion from `UInt64`. Interprets a `UInt64` as a `Float`, ignoring the numeric value\nand treating the `UInt64`'s bit pattern as a `Float`.\n\n`Float`s and `UInt64`s have the same endianness on all supported platforms. IEEE 754 very precisely\nspecifies the bit layout of floats.\n\nThis function has a logical model in terms of `Float.Model`.\n","docLink":"./Init/Data/Float/Float.html#Float.ofBits","kind":"def","line":105,"name":"Float.ofBits","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L105-L115"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.le\"><span class=\"name\">Float</span>.<span class=\"name\">le</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Non-strict inequality of floating-point numbers. Typically used via the `≤` operator.\n","docLink":"./Init/Data/Float/Float.html#Float.le","kind":"def","line":99,"name":"Float.le","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L99-L103"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.lt\"><span class=\"name\">Float</span>.<span class=\"name\">lt</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Strict inequality of floating-point numbers. Typically used via the `<` operator.\n","docLink":"./Init/Data/Float/Float.html#Float.lt","kind":"def","line":93,"name":"Float.lt","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L93-L97"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.neg\"><span class=\"name\">Float</span>.<span class=\"name\">neg</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Negates 64-bit floating-point numbers according to IEEE 754. Typically used via the `-` prefix\noperator.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C negation operator.\n","docLink":"./Init/Data/Float/Float.html#Float.neg","kind":"def","line":84,"name":"Float.neg","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L84-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.div\"><span class=\"name\">Float</span>.<span class=\"name\">div</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Divides 64-bit floating-point numbers according to IEEE 754. Typically used via the `/` operator.\n\nIn Lean, division by zero typically yields zero. For `Float`, it instead yields either `Inf`,\n`-Inf`, or `NaN`.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C division operator.\n","docLink":"./Init/Data/Float/Float.html#Float.div","kind":"def","line":73,"name":"Float.div","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L73-L82"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.mul\"><span class=\"name\">Float</span>.<span class=\"name\">mul</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Multiplies 64-bit floating-point numbers according to IEEE 754. Typically used via the `*` operator.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C multiplication operator.\n","docLink":"./Init/Data/Float/Float.html#Float.mul","kind":"def","line":66,"name":"Float.mul","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L66-L72"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.sub\"><span class=\"name\">Float</span>.<span class=\"name\">sub</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Subtracts 64-bit floating-point numbers according to IEEE 754. Typically used via the `-` operator.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C subtraction operator.\n","docLink":"./Init/Data/Float/Float.html#Float.sub","kind":"def","line":59,"name":"Float.sub","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L59-L65"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.add\"><span class=\"name\">Float</span>.<span class=\"name\">add</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Adds two 64-bit floating-point numbers according to IEEE 754. Typically used via the `+` operator.\n\nThis function has a logical model in terms of `Float.Model`. It is compiled to the C addition operator.\n","docLink":"./Init/Data/Float/Float.html#Float.add","kind":"def","line":51,"name":"Float.add","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L51-L57"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instNonemptyFloat\"><span class=\"name\">instNonemptyFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instNonemptyFloat","kind":"instance","line":48,"name":"instNonemptyFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L48-L49"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instDecidableEqFloat.decEq\"><span class=\"name\">instDecidableEqFloat</span>.<span class=\"name\">decEq</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x✝ </span><span class=\"fn\">x✝¹</span> : <a href=\"./Init/Data/Float/Float.html#Float\">Float</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> (<span class=\"fn\">x✝</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">x✝¹</span>)</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instDecidableEqFloat.decEq","kind":"def","line":46,"name":"instDecidableEqFloat.decEq","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L46-L46"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#instDecidableEqFloat\"><span class=\"name\">instDecidableEqFloat</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#DecidableEq\">DecidableEq</a> <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Float/Float.html#instDecidableEqFloat","kind":"instance","line":46,"name":"instDecidableEqFloat","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L46-L46"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.toModel\"><span class=\"name\">Float</span>.<span class=\"name\">toModel</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Init/Data/Float/Float.html#Float\">Float</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/Float/Model/Float.html#Float.Model\">Model</a></div></div>","info":{"doc":"Converts a `Float` into a `Float.Model`. ","docLink":"./Init/Data/Float/Float.html#Float.toModel","kind":"def","line":41,"name":"Float.toModel","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L41-L41"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float.ofModel\"><span class=\"name\">Float</span>.<span class=\"name\">ofModel</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Float/Model/Float.html#Float.Model\">Float.Model</a> → <a href=\"./Init/Data/Float/Float.html#Float\">Float</a></span></div></div>","info":{"doc":"Constructs a `Float` from a `Float.Model`. ","docLink":"./Init/Data/Float/Float.html#Float.ofModel","kind":"ctor","line":14,"name":"Float.ofModel","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L14-L41"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Float/Float.html#Float\"><span class=\"name\">Float</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"64-bit floating-point numbers.\n\n`Float` corresponds to the IEEE 754 *binary64* format (`double` in C or `f64` in Rust).\nFloating-point numbers are a finite representation of a subset of the real numbers, extended with\nextra “sentinel” values that represent undefined and infinite results as well as separate positive\nand negative zeroes. Arithmetic on floating-point numbers approximates the corresponding operations\non the real numbers by rounding the results to numbers that are representable, propagating error and\ninfinite values.\n\nFloating-point numbers include [subnormal numbers](https://en.wikipedia.org/wiki/Subnormal_number).\nTheir special values are:\n * `NaN`, which denotes a class of “not a number” values that result from operations such as\n   dividing zero by zero, and\n * `Inf` and `-Inf`, which represent positive and infinities that result from dividing non-zero\n   values by zero.\n\nLike other low-level types, `Float` is special-cased by the Lean compiler to correspond to the C\n`double` type. From the point of view of Lean's logic, `Float` is equivalent to `Float.Model` (via\nthe functions `Float.toModel` and `Float.ofModel`), which is itself a subtype of `UInt64`. Some of\nthe operations on `Float` are defined in terms of their `Float.Model` counterparts, while others\nare opaque to Lean's kernel.\n","docLink":"./Init/Data/Float/Float.html#Float","kind":"structure","line":14,"name":"Float","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/Float/Float.lean#L14-L41"}}],"imports":["Init.Data.Float.Model.Float","Init.Data.ToString.Basic"],"instances":[{"className":"Decidable","name":"instDecidableEqFloat","typeNames":["Eq"]},{"className":"Nonempty","name":"instNonemptyFloat","typeNames":["Float"]},{"className":"Add","name":"instAddFloat","typeNames":["Float"]},{"className":"Sub","name":"instSubFloat","typeNames":["Float"]},{"className":"Mul","name":"instMulFloat","typeNames":["Float"]},{"className":"Div","name":"instDivFloat","typeNames":["Float"]},{"className":"Neg","name":"instNegFloat","typeNames":["Float"]},{"className":"LT","name":"instLTFloat","typeNames":["Float"]},{"className":"LE","name":"instLEFloat","typeNames":["Float"]},{"className":"BEq","name":"instBEqFloat","typeNames":["Float"]},{"className":"Decidable","name":"Float.decLt","typeNames":["LT.lt"]},{"className":"Decidable","name":"Float.decLe","typeNames":["LE.le"]},{"className":"ToString","name":"instToStringFloat","typeNames":["Float"]},{"className":"Inhabited","name":"instInhabitedFloat","typeNames":["Float"]},{"className":"Repr","name":"instReprFloat","typeNames":["Float"]},{"className":"ReprAtom","name":"instReprAtomFloat","typeNames":["Float"]},{"className":"HomogeneousPow","name":"instHomogeneousPowFloat","typeNames":["Float"]},{"className":"Min","name":"instMinFloat","typeNames":["Float"]},{"className":"Max","name":"instMaxFloat","typeNames":["Float"]}],"name":"Init.Data.Float.Float"}