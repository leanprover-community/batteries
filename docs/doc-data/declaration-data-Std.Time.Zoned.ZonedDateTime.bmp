/Time/Unit/Millisecond.html#Std.Time.Millisecond.Ordinal\">Millisecond.Ordinal</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Std/Time/Zoned/ZonedDateTime.lean#L496-L502","name":"Std.Time.ZonedDateTime.withSeconds","line":496,"kind":"def","docLink":"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.withSeconds","doc":"Creates a new `ZonedDateTime` by adjusting the `second` component.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.withSeconds\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">ZonedDateTime</span>.<span class=\"name\">withSeconds</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dt</span> : <a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">second</span> : <span class=\"fn\"><a href=\"./Std/Time/Time/Unit/Second.html#Std.Time.Second.Ordinal\">Second.Ordinal</a> <a href=\"./Init/Prelude.html#Bool.true\">true</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a></div></div>"},{"info":{"sourceLink":"https://github.com/leanprover/lean4/blob/ad1a017949674a947f0d6794cbf7130d642c6530/src/Std/Time/Zoned/ZonedDateTime.lean#L488-L494","name":"Std.Time.ZonedDateTime.withMinutes","line":488,"kind":"def","docLink":"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.withMinutes","doc":"Creates a new `ZonedDateTime` by adjusting the `minute` component.\n