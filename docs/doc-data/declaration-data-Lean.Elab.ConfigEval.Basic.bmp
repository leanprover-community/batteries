class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">EvalConfigItem</span>.<span class=\"name\">setConfig</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">eval</span> : <span class=\"fn\"><a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.EvalConfigItem\">EvalConfigItem</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">init</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfg</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">onErr</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a> → <span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <span class=\"fn\">α</span></span></span></span> := <span class=\"fn\">fun (<span class=\"fn\">cfg</span> : <span class=\"fn\">α</span>) (<span class=\"fn\">cfgItem</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>) =&gt; <span class=\"fn\"><a href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.EvalConfigItem.defaultOnErr\">defaultOnErr</a> <span class=\"fn\">cfg</span> <span class=\"fn\">cfgItem</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">logExceptions</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a> := <a href=\"./Init/Prelude.html#Bool.false\">false</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Applies the configuration `cfg` to `init` using `eval.set`.\nIf `logExceptions` is true, then catches and logs exceptions.\n\nThe `onErr` callback is used for invalid configuration syntax.\n\nNote: this should be run from within `runConfigElab`.\n","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.EvalConfigItem.setConfig","kind":"def","line":280,"name":"Lean.Elab.ConfigEval.EvalConfigItem.setConfig","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L280-L292"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.EvalConfigItem.defaultOnErr\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">EvalConfigItem</span>.<span class=\"name\">defaultOnErr</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfg</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfgItem</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfgType?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span> := <a href=\"./Init/Prelude.html#Option.none\">none</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Default `onErr` handler. If the `cfgItem` contains `.missing`, we assume an error has already been\nreported by the parser and return `cfg`. Otherwise, we throw an unsupported syntax exception.\n\nIf `cfgType?` is present, then it adds completion info when the identifier is missing.\n","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.EvalConfigItem.defaultOnErr","kind":"def","line":258,"name":"Lean.Elab.ConfigEval.EvalConfigItem.defaultOnErr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L258-L278"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.EvalConfigItem.trySet\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">EvalConfigItem</span>.<span class=\"name\">trySet</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">eval</span> : <span class=\"fn\"><a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.EvalConfigItem\">EvalConfigItem</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">config</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">logExceptions</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.EvalConfigItem.trySet","kind":"def","line":242,"name":"Lean.Elab.ConfigEval.EvalConfigItem.trySet","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L242-L256"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.foldConfigsM\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">foldConfigsM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> → <a href=\"./foundational_types.html\">Type</a></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Monad\">Monad</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.MonadRef\">MonadRef</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">init</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfgs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\"><a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">onErr</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Like `foldConfigM` but takes an array of configurations or configuration items.\n","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.foldConfigsM","kind":"opaque","line":231,"name":"Lean.Elab.ConfigEval.foldConfigsM","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L231-L238"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.foldConfigM\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">foldConfigM</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> → <a href=\"./foundational_types.html\">Type</a></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Monad\">Monad</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.MonadRef\">MonadRef</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">init</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cfg</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\"><a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">onErr</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Interprets `cfg` as configuration item or list of configuration items.\n\nItems are interpreted in a way that allows user-defined configurations.\nNearly anything that looks like configuration items or lists of configuration items\nwill be interpreted. We're expecting an item that has one of the following formats:\n- `\"(\" ident/atom \":=\" syntax \")\"`\n- `\"+\" ident/atom`\n- `\"-\" ident/atom`\n\nThe specification:\n- A null node is a list of configurations\n- A one-argument node is considered to be a wrapper like `optConfig` or `configItem`.\n- A node with at two arguments starting with a \"+\"/\"-\" atom and whose second\n  argument is an ident or atom is a `posConfigItem`/`negConfigItem`\n- A node with at most five arguments starting with a \"(\" atom and whose second argument\n  is an ident or atom is a `valConfigItem`. The fourth argument is the value,\n  and it is allowed to have arbitary syntax (it does not need to be a `Term`).\n- A bare atom is considered to be a `\"+\"` option.\n\nWe trust that any atoms are valid as idents. The atom will be parsed using `String.toName`\nto form the name. (Small optimization: if the name doesn't contain `.`, we use `Name.mkSimple`\nto skip parsing. Atoms must not contain numerals or `«»` escapes.)\n\nOn interpretation error, `onErr` is called with the current configuration object and the offending\nsyntax item. It may process the item itself or otherwise throw an error. We leave it to `onErr`\nto decide what to do for items containing `Syntax.missing`.\n","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.foldConfigM","kind":"opaque","line":159,"name":"Lean.Elab.ConfigEval.foldConfigM","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L159-L229"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.addCompletionInfo\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">addCompletionInfo</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">structName</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.addCompletionInfo","kind":"def","line":152,"name":"Lean.Elab.ConfigEval.ConfigItem.addCompletionInfo","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L152-L155"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.addConstInfo\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">addConstInfo</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">projFn</span> : <a href=\"./Init/Prelude.html#Lean.Name\">Name</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.addConstInfo","kind":"def","line":147,"name":"Lean.Elab.ConfigEval.ConfigItem.addConstInfo","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L147-L150"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.throwCannotSetOption\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">throwCannotSetOption</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">structName?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#Lean.Name\">Name</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.throwCannotSetOption","kind":"def","line":141,"name":"Lean.Elab.ConfigEval.ConfigItem.throwCannotSetOption","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L141-L145"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.throwInvalidOption\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">throwInvalidOption</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">structName?</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#Lean.Name\">Name</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.throwInvalidOption","kind":"def","line":135,"name":"Lean.Elab.ConfigEval.ConfigItem.throwInvalidOption","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L135-L139"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.checkNotBool\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">checkNotBool</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">TermElabM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.checkNotBool","kind":"def","line":131,"name":"Lean.Elab.ConfigEval.ConfigItem.checkNotBool","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L131-L133"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.shift\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">shift</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a></div></div>","info":{"doc":"Drops the first component of the `optionName`, returning the new config item.\nThe first component is stored at the front of `prevOptionComps`.\n","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.shift","kind":"def","line":122,"name":"Lean.Elab.ConfigEval.ConfigItem.shift","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L122-L129"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.getCurrOptionName\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">getCurrOptionName</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.Name\">Name</a></div></div>","info":{"doc":"Gets the current name of the option after any shifting.\nFor example, if an option is named `a.b.c.d` and there is a handler\nfor `a.b.*`, then the handler receives a `ConfigItem` whose current option\nname is `c.d`.\n","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.getCurrOptionName","kind":"def","line":113,"name":"Lean.Elab.ConfigEval.ConfigItem.getCurrOptionName","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L113-L120"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.prevRoot\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">prevRoot</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.prevRoot","kind":"def","line":108,"name":"Lean.Elab.ConfigEval.ConfigItem.prevRoot","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L108-L111"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.prevRoot?\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">prevRoot?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#Lean.Syntax\">Syntax</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.prevRoot?","kind":"def","line":105,"name":"Lean.Elab.ConfigEval.ConfigItem.prevRoot?","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Elab/ConfigEval/Basic.lean#L105-L106"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.getRootStr\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">ConfigEval</span>.<span class=\"name\">ConfigItem</span>.<span class=\"name\">getRootStr</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">item</span> : <a href=\"./Lean/Elab/ConfigEval/Types.html#Lean.Elab.ConfigEval.ConfigItem\">ConfigItem</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Lean/Elab/ConfigEval/Basic.html#Lean.Elab.ConfigEval.ConfigItem.getRootStr","kind":"def","line":99,"name":"Lean.Elab.ConfigEval.ConfigItem.getRootStr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1