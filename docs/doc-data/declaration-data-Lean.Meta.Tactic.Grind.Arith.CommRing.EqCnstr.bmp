n/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Simplifies the basis using `c`. Every equation that `c` rewrites is removed from the basis\nand requeued in its rewritten form.\n\nSee **Note** at `EqCnstr.simplify` for why `checkCoeffDvd` must be enabled here.\n","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplifyBasis","kind":"def","line":304,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplifyBasis","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L304-L338"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.toMonic\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">toMonic</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a></span></div></div>","info":{"doc":"Tries to convert the leading monomial into a monic one.\n\nIt exploits the fact that given a polynomial with leading coefficient `k`,\nif the ring has a nonzero characteristic `p` and `gcd k p = 1`, then\n`k` has an inverse.\n\nIt also handles the easy case where `k` is `-1`.\n\nRemark: if the ring implements the class `NoNatZeroDivisors`, then\nthe coefficients are divided by the gcd of all coefficients.\n","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.toMonic","kind":"def","line":273,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.toMonic","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L273-L302"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.superposeWith\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">superposeWith</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.superposeWith","kind":"def","line":263,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.superposeWith","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L263-L271"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.addToQueue\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">addToQueue</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.addToQueue","kind":"def","line":251,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.addToQueue","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L251-L261"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.addToBasisCore\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">addToBasisCore</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.addToBasisCore","kind":"def","line":244,"name":"Lean.Meta.Grind.Arith.CommRing.addToBasisCore","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L244-L249"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplifyAndCheck\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">simplifyAndCheck</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span></div></div>","info":{"doc":"Simplifies and checks whether the resulting constraint is trivial (i.e., `0 = 0`),\nor inconsistent (i.e., `k = 0` where `k % c != 0` for a comm-ring with characteristic `c`),\nand returns `none`. Otherwise, returns the simplified constraint.\n","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplifyAndCheck","kind":"def","line":224,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplifyAndCheck","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L224-L234"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.checkConstant\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">checkConstant</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a></span></div></div>","info":{"doc":"Returns `true` if `c.p` is the constant polynomial. ","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.checkConstant","kind":"def","line":193,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.checkConstant","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L193-L222"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplify\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">simplify</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a></span></div></div>","info":{"doc":"Simplify the given equation constraint using the current basis.\n\n**Note**: This function (and `simplifyBasis`) runs with `checkCoeffDvd := true`. It rewrites a\nmonomial `k'*m'` using an equation with leading term `k*m` only if `k ∣ k'` (or the ring\nimplements `NoNatZeroDivisors`). Rewriting without this restriction requires multiplying the\nequation by `k/gcd k k' ≠ ±1` first, and *replacing* an equation with the result loses\ninformation: `p = 0` cannot be recovered from `(k/gcd k k') * p = 0` in an arbitrary\ncommutative ring. The consequences of the skipped rewrites are not lost: a skipped rewrite at\nthe leading monomial coincides with the S-polynomial computed by `superposeWith`, so it is\nderived non-destructively. The price is that the basis is not\nfully interreduced (e.g., `2*x = 0` and `3*x = 0` may coexist), and reduction is an incomplete\nideal-membership test in rings without `NoNatZeroDivisors` (e.g., `x = 0` is not derived from\n`2*x = 0` and `3*x = 0`). The complete alternative is a strong Gröbner basis over `Int`\n(Kandri-Rody & Kapur): replace multiply-through rewriting with Euclidean remainder reduction\non coefficients (`k' = q*k + r`, so the equation is never multiplied by a constant), and\nadditionally superpose gcd-polynomials (Bézout combinations producing `gcd k k'` times the lcm\nof the leading monomials). We should consider this option in the future.\n\n**Note**: If using `withCheckCoeffDvd` becomes too expensive when one does not have\n`NoNatZeroDivisors`, we will add a flag to perform the simplification anyway even if\ninformation is lost.\n","docLink":"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplify","kind":"def","line":159,"name":"Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplify","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.lean#L159-L191"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/EqCnstr.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr.simplifyUsingNumEq0\"><span class=\"name\">Lean</span>.<span class=\"name\">Meta</span>.<span class=\"name\">Grind</span>.<span class=\"name\">Arith</span>.<span class=\"name\">CommRing</span>.<span class=\"name\">EqCnstr</span>.<span class=\"name\">simplifyUsingNumEq0</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/RingM.html#Lean.Meta.Grind.Arith.CommRing.RingM\">RingM</a> <a href=\"./Lean/Meta/Tactic/Grind/Arith/CommRing/Types.html#Lean.Meta.Grind.Arith.CommRing.EqCnstr\">EqCnstr</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Meta/Tactic/Gr