n blue\" = true`\n","docLink":"./Init/Data/String/TakeDrop.html#String.isPrefixOf","kind":"def","line":307,"name":"String.isPrefixOf","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L307-L320"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.startsWith\"><span class=\"name\">String</span>.<span class=\"name\">startsWith</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks whether the first string \\(`s`\\) begins with the pattern \\(`pat`\\).\n\n`String.isPrefixOf` is a version that takes the\npotential prefix before the string.\n\nExamples:\n\n* `\"red green blue\".startsWith \"red\" = true`\n\n* `\"red green blue\".startsWith \"green\" = false`\n\n* `\"red green blue\".startsWith \"\" = true`\n\n* `\"red green blue\".startsWith 'r' = true`\n\n* `\"red green blue\".startsWith Char.isLower = true`\n","docLink":"./Init/Data/String/TakeDrop.html#String.startsWith","kind":"def","line":291,"name":"String.startsWith","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L291-L305"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Pos.skipWhile\"><span class=\"name\">String</span>.<span class=\"name\">Pos</span>.<span class=\"name\">skipWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pos</span> : <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></div></div>","info":{"doc":"Advances `pos` as long as `pat` matches.\n","docLink":"./Init/Data/String/TakeDrop.html#String.Pos.skipWhile","kind":"def","line":284,"name":"String.Pos.skipWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L284-L289"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Pos.skip?\"><span class=\"name\">String</span>.<span class=\"name\">Pos</span>.<span class=\"name\">skip?</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pos</span> : <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></span></div></div>","info":{"doc":"If `pat` matches at `pos`, returns the position after the end of the match.\nReturns `none` otherwise.\n\nThis function is generic over all currently supported patterns.\n","docLink":"./Init/Data/String/TakeDrop.html#String.Pos.skip?","kind":"def","line":274,"name":"String.Pos.skip?","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L274-L282"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.revAll\"><span class=\"name\">String</span>.<span class=\"name\">revAll</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks whether a string only consists of matches of the pattern `pat`, starting from the back\nof the string.\n\nShort-circuits at the first pattern mis-match.\n\nThis function is generic over all currently supported patterns.\n\nFor many types of patterns, this function can be expected to return the same result as\n`String.all`. If mismatches are expected to occur close to the end of the string, this function\nmight be more efficient.\n\nFor some types of patterns, this function will return a different result than `String.all`.\nConsider, for example, a pattern that matches the longest string at the given position that matches\nthe regular expression `\"a|aa|ab\"`. Then, given the input string `\"aab\"`, performing\n`String.all` will greedily match the prefix `\"aa\"` and then get stuck on the remainder\n`\"b\"`, causing it to return `false`. On the other hand, `String.revAll` will match\nthe suffix `\"ab\"` and then match the remainder `\"a\"`, so it will return `true`.\n\nExamples:\n\n* `\"brown\".revAll Char.isLower = true`\n\n* `\"brown and orange\".revAll Char.isLower = false`\n\n* `\"aaaaaa\".revAll 'a' = true`\n\n* `\"aaaaaa\".revAll \"aa\" = true`\n\n* `\"aaaaaaa\".revAll \"aa\" = false`\n","docLink":"./Init/Data/String/TakeDrop.html#String.revAll","kind":"def","line":244,"name":"String.revAll","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L244-L272"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.all\"><span class=\"name\">String</span>.<span class=\"name\">all</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks whether a string only consists of matches of the pattern `pat`.\n\nShort-circuits at the first pattern mis-match.\n\nThis function is generic over all currently supported patterns.\n\nExamples:\n\n* `\"brown\".all Char.isLower = true`\n\n* `\"brown and orange\".all Char.isLower = false`\n\n* `\"aaaaaa\".all 'a' = true`\n\n* `\"aaaaaa\".all \"aa\" = true`\n\n* `\"aaaaaaa\".all \"aa\" = false`\n","docLink":"./Init/Data/String/TakeDrop.html#String.all","kind":"def","line":227,"name":"String.all","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L227-L242"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.skipPrefixWhile\"><span class=\"name\">String</span>.<span class=\"name\">skipPrefixWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></div></div>","info":{"doc":"Returns the position after the longest prefix of `s` for which `pat` matches\n\\(potentially repeatedly\\).\n","docLink":"./Init/Data/String/TakeDrop.html#String.skipPrefixWhile","kind":"def","line":220,"name":"String.skipPrefixWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L220-L225"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.skipPrefix?\"><span class=\"name\">String</span>.<span class=\"name\">skipPrefix?</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></span></div></div>","info":{"doc":"If `pat` matches a prefix of `s`, returns the position at the start of the remainder.\nReturns `none` otherwise.\n\nThis function is generic over all currently supported patterns.\n","docLink":"./Init/Data/String/TakeDrop.html#String.skipPrefix?","kind":"def","line":211,"name":"String.skipPrefix?","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L211-L218"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Slice.dropRightWhile\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">dropRightWhile</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Char\">Char</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Slice.dropRightWhile","kind":"def","line":207,"name":"String.Slice.dropRightWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L207-L209"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.dropRightWhile\"><span class=\"name\">String</span>.<span class=\"name\">dropRightWhile</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Char\">Char</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.dropRightWhile","kind":"def","line":203,"name":"String.dropRightWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L203-L205"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.dropEndWhile\"><span class=\"name\">String</span>.<span class=\"name\">dropEndWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Creates a new string by removing the longest suffix from `s` in which `pat` matches\n\\(potentially repeatedly\\).\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nThis function is generic over all currently supported patterns.\n\nExamples:\n\n* `\"red green blue\".dropEndWhile Char.isLower == \"red green \".toSlice`\n\n* `\"red green blue\".dropEndWhile 'e' == \"red green blu\".toSlice`\n\n* `\"red green blue\".dropEndWhile (fun (_ : Char) => true) == \"\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.dropEndWhile","kind":"def","line":186,"name":"String.dropEndWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L186-L201"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Slice.takeRightWhile\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">takeRightWhile</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Char\">Char</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Slice.takeRightWhile","kind":"def","line":182,"name":"String.Slice.takeRightWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L182-L184"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.takeRightWhile\"><span class=\"name\">String</span>.<span class=\"name\">takeRightWhile</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Char\">Char</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.takeRightWhile","kind":"def","line":178,"name":"String.takeRightWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L178-L180"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.takeEndWhile\"><span class=\"name\">String</span>.<span class=\"name\">takeEndWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Creates a string slice that contains the longest suffix of `s` in which `pat` matched\n\\(potentially repeatedly\\).\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nThis function is generic over all currently supported patterns.\n\nExamples:\n\n* `\"red green blue\".takeEndWhile Char.isLower == \"blue\".toSlice`\n\n* `\"red green blue\".takeEndWhile 'e' == \"e\".toSlice`\n\n* `\"red green blue\".takeEndWhile (fun (_ : Char) => true) == \"red green blue\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.takeEndWhile","kind":"def","line":161,"name":"String.takeEndWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L161-L176"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.dropWhile\"><span class=\"name\">String</span>.<span class=\"name\">dropWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Creates a string slice by removing the longest prefix from `s` in which `pat` matched\n\\(potentially repeatedly\\).\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nThis function is generic over all currently supported patterns.\n\nExamples:\n\n* `\"red green blue\".dropWhile Char.isLower == \" green blue\".toSlice`\n\n* `\"red green blue\".dropWhile 'r' == \"ed green blue\".toSlice`\n\n* `\"red red green blue\".dropWhile \"red \" == \"green blue\".toSlice`\n\n* `\"red green blue\".dropWhile (fun (_ : Char) => true) == \"\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.dropWhile","kind":"def","line":143,"name":"String.dropWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L143-L159"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.takeWhile\"><span class=\"name\">String</span>.<span class=\"name\">takeWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.ForwardPattern\">Slice.Pattern.ForwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Creates a string slice that contains the longest prefix of `s` in which `pat` matched\n\\(potentially repeatedly\\).\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nThis function is generic over all currently supported patterns.\n\nExamples:\n\n* `\"red green blue\".takeWhile Char.isLower == \"red\".toSlice`\n\n* `\"red green blue\".takeWhile 'r' == \"r\".toSlice`\n\n* `\"red red green blue\".takeWhile \"red \" == \"red red \".toSlice`\n\n* `\"red green blue\".takeWhile (fun (_ : Char) => true) == \"red green blue\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.takeWhile","kind":"def","line":125,"name":"String.takeWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L125-L141"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Slice.takeRight\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">takeRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Slice.takeRight","kind":"def","line":121,"name":"String.Slice.takeRight","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L121-L123"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.takeRight\"><span class=\"name\">String</span>.<span class=\"name\">takeRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.takeRight","kind":"def","line":117,"name":"String.takeRight","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L117-L119"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.takeEnd\"><span class=\"name\">String</span>.<span class=\"name\">takeEnd</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Returns a `String.Slice` that contains the last `n` characters \\(Unicode code points\\) of\n`s`.\n\nIf `n` is greater than `s.toList.length`, returns `s.toSlice`.\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nExamples:\n\n* `\"red green blue\".takeEnd 4 == \"blue\".toSlice`\n\n* `\"red green blue\".takeEnd 1 == \"e\".toSlice`\n\n* `\"red green blue\".takeEnd 0 == \"\".toSlice`\n\n* `\"red green blue\".takeEnd 100 == \"red green blue\".toSlice`\n\n* `\"مرحبا بالعالم\".takeEnd 5 == \"لعالم\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.takeEnd","kind":"def","line":98,"name":"String.takeEnd","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L98-L115"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.take\"><span class=\"name\">String</span>.<span class=\"name\">take</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Returns a `String.Slice` that contains the first `n` characters \\(Unicode code points\\) of\n`s`.\n\nIf `n` is greater than `s.toList.length`, returns `s.toSlice`.\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nExamples:\n\n* `\"red green blue\".take 3 == \"red\".toSlice`\n\n* `\"red green blue\".take 1 == \"r\".toSlice`\n\n* `\"red green blue\".take 0 == \"\".toSlice`\n\n* `\"red green blue\".take 100 == \"red green blue\".toSlice`\n\n* `\"مرحبا بالعالم\".take 5 == \"مرحبا\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.take","kind":"def","line":79,"name":"String.take","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L79-L96"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Internal.dropRightImpl\"><span class=\"name\">String</span>.<span class=\"name\">Internal</span>.<span class=\"name\">dropRightImpl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Internal.dropRightImpl","kind":"def","line":75,"name":"String.Internal.dropRightImpl","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L75-L77"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Slice.dropRight\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">dropRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Slice.dropRight","kind":"def","line":71,"name":"String.Slice.dropRight","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L71-L73"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.dropRight\"><span class=\"name\">String</span>.<span class=\"name\">dropRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.dropRight","kind":"def","line":67,"name":"String.dropRight","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L67-L69"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.dropEnd\"><span class=\"name\">String</span>.<span class=\"name\">dropEnd</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Returns a `String.Slice` obtained by removing the specified number of characters \\(Unicode code\npoints\\) from the end of the string.\n\nIf `n` is greater than `s.toList.length`, returns an empty slice.\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nExamples:\n\n* `\"red green blue\".dropEnd 5 == \"red green\".toSlice`\n\n* `\"red green blue\".dropEnd 11 == \"red\".toSlice`\n\n* `\"red green blue\".dropEnd 50 == \"\".toSlice`\n\n* `\"مرحبا بالعالم\".dropEnd 3 == \"مرحبا بالع\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.dropEnd","kind":"def","line":49,"name":"String.dropEnd","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L49-L65"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Internal.dropImpl\"><span class=\"name\">String</span>.<span class=\"name\">Internal</span>.<span class=\"name\">dropImpl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Internal.dropImpl","kind":"def","line":45,"name":"String.Internal.dropImpl","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L45-L47"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.drop\"><span class=\"name\">String</span>.<span class=\"name\">drop</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Returns a `String.Slice` obtained by removing the specified number of characters \\(Unicode code\npoints\\) from the start of the string.\n\nIf `n` is greater than `s.toList.length`, returns an empty slice.\n\nThis is a cheap operation because it does not allocate a new string to hold the result.\nTo convert the result into a string, use `String.Slice.copy`.\n\nExamples:\n\n* `\"red green blue\".drop 4 == \"green blue\".toSlice`\n\n* `\"red green blue\".drop 10 == \"blue\".toSlice`\n\n* `\"red green blue\".drop 50 == \"\".toSlice`\n\n* `\"مرحبا بالعالم\".drop 3 == \"با بالعالم\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.drop","kind":"def","line":27,"name":"String.drop","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L27-L43"}}],"imports":["Init.Data.String.Substring"],"instances":[],"name":"Init.Data.String.TakeDrop"}