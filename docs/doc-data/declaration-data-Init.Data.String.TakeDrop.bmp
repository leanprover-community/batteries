tart","kind":"def","line":398,"name":"String.trimAsciiStart","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L398-L412"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Slice.trimRight\"><span class=\"name\">String</span>.<span class=\"name\">Slice</span>.<span class=\"name\">trimRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.Slice.trimRight","kind":"def","line":394,"name":"String.Slice.trimRight","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L394-L396"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.trimRight\"><span class=\"name\">String</span>.<span class=\"name\">trimRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"","docLink":"./Init/Data/String/TakeDrop.html#String.trimRight","kind":"def","line":390,"name":"String.trimRight","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L390-L392"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.trimAsciiEnd\"><span class=\"name\">String</span>.<span class=\"name\">trimAsciiEnd</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Data/String/Defs.html#String.Slice\">Slice</a></div></div>","info":{"doc":"Removes trailing whitespace from a string by returning a slice whose end position is the last\nnon-whitespace character, or the start position if there is no non-whitespace character.\n\n“Whitespace” is defined as characters for which `Char.isWhitespace` returns `true`.\n\nExamples:\n\n* `\"abc\".trimAsciiEnd == \"abc\".toSlice`\n\n* `\"   abc\".trimAsciiEnd == \"   abc\".toSlice`\n\n* `\"abc \\t  \".trimAsciiEnd == \"abc\".toSlice`\n\n* `\"  abc   \".trimAsciiEnd == \"  abc\".toSlice`\n\n* `\"abc\\ndef\\n\".trimAsciiEnd == \"abc\\ndef\".toSlice`\n","docLink":"./Init/Data/String/TakeDrop.html#String.trimAsciiEnd","kind":"def","line":374,"name":"String.trimAsciiEnd","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L374-L388"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Pos.revSkipWhile\"><span class=\"name\">String</span>.<span class=\"name\">Pos</span>.<span class=\"name\">revSkipWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pos</span> : <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></div></div>","info":{"doc":"Rewinds `pos` as long as `pat` matches.\n","docLink":"./Init/Data/String/TakeDrop.html#String.Pos.revSkipWhile","kind":"def","line":367,"name":"String.Pos.revSkipWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L367-L372"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.Pos.revSkip?\"><span class=\"name\">String</span>.<span class=\"name\">Pos</span>.<span class=\"name\">revSkip?</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pos</span> : <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></span></div></div>","info":{"doc":"If `pat` matches at `pos`, returns the position after the end of the match.\nReturns `none` otherwise.\n\nThis function is generic over all currently supported patterns.\n","docLink":"./Init/Data/String/TakeDrop.html#String.Pos.revSkip?","kind":"def","line":357,"name":"String.Pos.revSkip?","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L357-L365"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.skipSuffixWhile\"><span class=\"name\">String</span>.<span class=\"name\">skipSuffixWhile</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></div></div>","info":{"doc":"Returns the position at the start of the longest suffix of `s` for which `pat` matches\n\\(potentially repeatedly\\).\n","docLink":"./Init/Data/String/TakeDrop.html#String.skipSuffixWhile","kind":"def","line":350,"name":"String.skipSuffixWhile","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L350-L355"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.skipSuffix?\"><span class=\"name\">String</span>.<span class=\"name\">skipSuffix?</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Init/Data/String/Defs.html#String.Pos\">Pos</a></span></span></div></div>","info":{"doc":"If `pat` matches a suffix of `s`, returns the position at the beginning of the suffix.\nReturns `none` otherwise.\n\nThis function is generic over all currently supported patterns.\n","docLink":"./Init/Data/String/TakeDrop.html#String.skipSuffix?","kind":"def","line":341,"name":"String.skipSuffix?","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/TakeDrop.lean#L341-L348"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/TakeDrop.html#String.endsWith\"><span class=\"name\">String</span>.<span class=\"name\">endsWith</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ρ</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">pat</span> : <span class=\"fn\">ρ</span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/String/Pattern/Basic.html#String.Slice.Pattern.BackwardPattern\">Slice.Pattern.BackwardPattern</a> <span class=\"fn\">pat</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks whether the string \\(`s`\\) ends with the pattern \\(`pat`\\).\n\nThis function is generic over all currently supported patterns.\n\nExamples:\n\n* `\"red green blue\".endsWith \"blue\" = true`\n\n* `\"red green blue\".endsWith \"green\" = false`\n\n* `\"red green blue\".endsWith \"\" = true`\n\n* `\"red green blue\".endsWith 'e' = true`\n\n* `\"red green blue\".endsWith Char.isLower = true`\n","docLink":"./Init/Data/String/TakeDrop.html#String.endsWith","kind":"def","line":326,"name":"String.endsWith","sourceLink":"https: