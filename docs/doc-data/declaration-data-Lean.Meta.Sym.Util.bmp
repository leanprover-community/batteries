4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Meta/Sym/Util.lean#L23-L34"}}],"imports":["Init.Grind.Util","Lean.Meta.AppBuilder","Lean.Meta.Sym.SymM","Lean.Meta.Transform","Lean.Meta.WHNF","Lean.Util.ForEachExpr"],"instances":[],"name":"Lean.Meta.Sym.Util"}