tance","line":35,"name":"Lean.instInhabitedReducibilityStatus","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L35-L35"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/ReducibilityAttrs.html#Lean.instInhabitedReducibilityStatus.default\"><span class=\"name\">Lean</span>.<span class=\"name\">instInhabitedReducibilityStatus</span>.<span class=\"name\">default</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus\">ReducibilityStatus</a></div></div>","info":{"doc":"","docLink":"./Lean/ReducibilityAttrs.html#Lean.instInhabitedReducibilityStatus.default","kind":"def","line":35,"name":"Lean.instInhabitedReducibilityStatus.default","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L35-L35"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.implicitReducible\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityStatus</span>.<span class=\"name\">implicitReducible</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus\">ReducibilityStatus</a></div></div>","info":{"doc":"","docLink":"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.implicitReducible","kind":"ctor","line":34,"name":"Lean.ReducibilityStatus.implicitReducible","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L34-L34"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.irreducible\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityStatus</span>.<span class=\"name\">irreducible</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus\">ReducibilityStatus</a></div></div>","info":{"doc":"","docLink":"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.irreducible","kind":"ctor","line":34,"name":"Lean.ReducibilityStatus.irreducible","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L34-L34"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.semireducible\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityStatus</span>.<span class=\"name\">semireducible</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus\">ReducibilityStatus</a></div></div>","info":{"doc":"","docLink":"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.semireducible","kind":"ctor","line":34,"name":"Lean.ReducibilityStatus.semireducible","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L34-L34"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.reducible\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityStatus</span>.<span class=\"name\">reducible</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus\">ReducibilityStatus</a></div></div>","info":{"doc":"","docLink":"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus.reducible","kind":"ctor","line":34,"name":"Lean.ReducibilityStatus.reducible","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L34-L34"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus\"><span class=\"name\">Lean</span>.<span class=\"name\">ReducibilityStatus</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Reducibility status for a definition. Controls when `isDefEq` and `whnf` are allowed to unfold it.\nSee `TransparencyMode` for the full design rationale.\n\n- **`reducible`**: Unfolded at `TransparencyMode.reducible` or above. Reducible definitions still\n  appear in user-facing terms, but are eagerly unfolded when indexing terms into discrimination\n  trees (`simp`, type class resolution) and in `grind`. Think of it as `[inline]` for indexing.\n  Suitable for abbreviations and definitions that should be transparent to proof automation.\n- **`implicitReducible`**: Unfolded at `TransparencyMode.instances` or above. Used for type class\n  instances and definitions that appear in types matched during implicit argument resolution\n  (e.g., `Nat.add`, `Array.size`). These definitions cannot be eagerly reduced (instances expand\n  into large terms, recursive definitions are problematic), but must be unfoldable when checking\n  implicit arguments and resolving instance diamonds (e.g., `Add Nat` via direct instance vs via\n  `Semiring`). The attribute `[implicit_reducible]` (or its alias `[instance_reducible]`) marks\n  a definition with this status.\n- **`semireducible`**: The default. Unfolded at `TransparencyMode.default` or above. Used for\n  ordinary definitions. Suitable for user-written code where `isDefEq` should try hard during\n  type checking, but not during speculative proof automation.\n- **`irreducible`**: Only unfolded at `TransparencyMode.all`. The definition body is effectively\n  hidden from `isDefEq` in normal usage.\n","docLink":"./Lean/ReducibilityAttrs.html#Lean.ReducibilityStatus","kind":"inductive","line":12,"name":"Lean.ReducibilityStatus","sourceLink":"https://github.com/leanprover/lean4/blob/95583d74bd14ff8cc2b789347d15dfdad1259f97/src/Lean/ReducibilityAttrs.lean#L12-L35"}}],"imports":["Lean.ScopedEnvExtension"],"instances":[{"className":"Inhabited","name":"Lean.instInhabitedReducibilityStatus","typeNames":["Lean.ReducibilityStatus"]},{"className":"Repr","name":"Lean.instReprReducibilityStatus","typeNames":["Lean.ReducibilityStatus"]},{"className":"BEq","name":"Lean.instBEqReducibilityStatus","typeNames":["Lean.ReducibilityStatus"]}],"name":"Lean.ReducibilityAttrs"}