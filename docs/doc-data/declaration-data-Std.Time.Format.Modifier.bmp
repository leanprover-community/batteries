structor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.b\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">b</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`b`: Day period with noon/midnight distinction (e.g., AM, noon, midnight).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.b","kind":"ctor","line":575,"name":"Std.Time.Modifier.b","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L575-L578"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.a\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">a</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`a`: AM/PM of day (e.g., PM).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.a","kind":"ctor","line":570,"name":"Std.Time.Modifier.a","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L570-L573"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.F\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">F</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`F`: Day-of-week-in-month / occurrence of the weekday within the month (e.g., 2nd Sunday -> 2).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.F","kind":"ctor","line":565,"name":"Std.Time.Modifier.F","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L565-L568"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.c\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">c</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a> <a href=\"./Init/Core.html#Sum\">⊕</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`c`: Stand-alone day of week as number or text (e.g., 2, Tue, Tuesday, T).\nStand-alone means the day is used independently (e.g., a calendar column header) rather than as part of a full date.\nUnlike `e`, `cc` (count of 2) is not valid; the minimum is `c` (1 letter) or `ccc` (3 letters).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.c","kind":"ctor","line":558,"name":"Std.Time.Modifier.c","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L558-L563"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.e\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">e</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a> <a href=\"./Init/Core.html#Sum\">⊕</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`e`: Day of week as number or text (e.g., 1, 01, Mon, Monday, M).\nThe numeric value uses Monday=1 through Sunday=7 (ISO 8601 convention).\nText output is the same as `E`.\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.e","kind":"ctor","line":551,"name":"Std.Time.Modifier.e","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L551-L556"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.E\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">E</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`E`: Day of week as text (e.g., Tue, Tuesday, T).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.E","kind":"ctor","line":546,"name":"Std.Time.Modifier.E","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L546-L549"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.W\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">W</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`W`: Week of month (e.g., 4).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.W","kind":"ctor","line":541,"name":"Std.Time.Modifier.W","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L541-L544"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.w\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">w</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`w`: Week of week-based year (e.g., 27).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.w","kind":"ctor","line":536,"name":"Std.Time.Modifier.w","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L536-L539"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.Y\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">Y</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Year\">Year</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`Y`: ISO week-based year (e.g., 2004, 04, 0002, 2). This is the year that contains the ISO week (`w`), which can\ndiffer from the calendar year near year boundaries: e.g., Dec 31 may belong to week 1 of the following year.\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.Y","kind":"ctor","line":530,"name":"Std.Time.Modifier.Y","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L530-L534"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.q\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">q</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a> <a href=\"./Init/Core.html#Sum\">⊕</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`q`: Stand-alone quarter of year as number or text (e.g., 3, 03, Q3, 3rd quarter).\nStand-alone means the value is used independently (e.g., a calendar header) rather than as part of a full date phrase.\nIn practice the output is the same as `Q`; the distinction is meaningful only in locale-aware contexts.\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.q","kind":"ctor","line":523,"name":"Std.Time.Modifier.q","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L523-L528"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.Q\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">Q</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a> <a href=\"./Init/Core.html#Sum\">⊕</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`Q`: Quarter of year as number or text (e.g., 3, 03, Q3, 3rd quarter).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.Q","kind":"ctor","line":518,"name":"Std.Time.Modifier.Q","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L518-L521"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.d\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">d</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`d`: Day of month (e.g., 10).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.d","kind":"ctor","line":513,"name":"Std.Time.Modifier.d","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L513-L516"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.L\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">L</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a> <a href=\"./Init/Core.html#Sum\">⊕</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`L`: Stand-alone month of year as number or text (e.g., 7, 07, Jul, July, J).\nStand-alone means the month is used independently (e.g., a calendar header \"July\") rather than as part of a full date.\nIn practice the output is the same as `M`; the distinction is meaningful only in locale-aware contexts.\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.L","kind":"ctor","line":506,"name":"Std.Time.Modifier.L","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L506-L511"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.M\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">M</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a> <a href=\"./Init/Core.html#Sum\">⊕</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`M`: Month of year as number or text (e.g., 7, 07, Jul, July, J).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.M","kind":"ctor","line":501,"name":"Std.Time.Modifier.M","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L501-L504"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.D\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">D</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`D`: Day of year (e.g., 189).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.D","kind":"ctor","line":496,"name":"Std.Time.Modifier.D","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L496-L499"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.y\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">y</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Year\">Year</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`y`: Year of era (e.g., 2004, 04, 0002, 2). Never negative: year 1 BC is formatted as `1` paired with a BC era\ndesignator. Use `u` instead when you need the proleptic/astronomical year (which can be negative).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.y","kind":"ctor","line":490,"name":"Std.Time.Modifier.y","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L490-L494"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.u\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">u</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Year\">Year</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`u`: Proleptic/astronomical year (e.g., 2004, 04, -0001, -1). Can be negative: year 0 exists and -0001 = 2 BC.\nUse `y` + `G` instead when you want the era-based (always-positive) representation.\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.u","kind":"ctor","line":484,"name":"Std.Time.Modifier.u","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L484-L488"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.G\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">G</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Text\">Text</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`G`: Era (e.g., AD, Anno Domini, A).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.G","kind":"ctor","line":479,"name":"Std.Time.Modifier.G","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L479-L482"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"`Modifier` represents a single format pattern letter with its presentation style.\n\nThe table below lists every symbol, its `presentation` type, the `TypeFormat` value type produced\nwhen parsing or consumed when formatting, and representative output examples.\n\n```\nSymbol  Meaning                        Presentation      TypeFormat                Examples\n──────────────────────────────────────────────────────────────────────────────────────────────────\nG       era                            Text              Year.Era                  AD; Anno Domini; A\nu       year (proleptic/astronomical)  Year              Year.Offset               2004; 04; -0001; -1\ny       year-of-era                    Year              Year.Offset               2004; 04; 0002; 2\nD       day-of-year                    Number            Σ Day.Ordinal.OfYear      189\nM/L     month-of-year                  Number ⊕ Text     Month.Ordinal             7; 07; Jul; July; J\nd       day-of-month                   Number            Day.Ordinal               10\n──────────────────────────────────────────────────────────────────────────────────────────────────\nQ/q     quarter-of-year                Number ⊕ Text     Month.Quarter             3; 03; Q3; 3rd quarter\nY       week-based-year                Year              Year.Offset               1996; 96\nw       week-of-week-based-year        Number            Week.Ordinal              27\nW       week-of-month                  Number            Week.Ordinal.OfMonth      4\nE       day-of-week (text only)        Text              Weekday                   Tue; Tuesday; T\ne/c     localized day-of-week          Number ⊕ Text     Weekday                   2; 02; Tue; Tuesday; T\nF       day-of-week-in-month           Number            Bounded.LE 1 5            3\n──────────────────────────────────────────────────────────────────────────────────────────────────\na       am-pm-of-day                   Text              HourMarker                AM; PM\nb       day-period (noon/midnight)     Text              DayPeriod                 AM; noon; midnight\nB       extended day period            Text              ExtendedDayPeriod         in the morning; at night\nh       clock-hour-of-am-pm (1-12)    Number            Bounded.LE 1 12           12\nK       hour-of-am-pm (0-11)          Number            Bounded.LE 0 11           0\nk       clock-hour-of-day (1-24)      Number            Bounded.LE 1 24           24\n──────────────────────────────────────────────────────────────────────────────────────────────────\nH       hour-of-day (0-23)            Number            Hour.Ordinal              0\nm       minute-of-hour                Number            Minute.Ordinal            30\ns       second-of-minute              Number            Second.Ordinal true       55\nS       fraction-of-second            Fraction          Nanosecond.Ordinal        978\nA       milli-of-day                  Number            Millisecond.Offset        1234\nn       nano-of-second                Number            Nanosecond.Ordinal        987654321\nN       nano-of-day                   Number            Nanosecond.Offset         1234000000\n──────────────────────────────────────────────────────────────────────────────────────────────────\nV       time-zone ID                  ZoneId            String                    America/Los_Angeles; Z\nz       time-zone name                ZoneName          String                    Pacific Standard Time; PST\nv       generic zone name             ZoneName          String                    Pacific Time; PT\nO       localized zone-offset         OffsetO           Offset                    GMT+8; GMT+08:00\nX       zone-offset ('Z' for zero)    OffsetX           Offset                    Z; -08; -0830; -08:30\nx       zone-offset                   OffsetX           Offset                    +0000; -08; -0830; -08:30\nZ       zone-offset                   OffsetZ           Offset                    +0000; -0800; -08:00\n```\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier","kind":"inductive","line":430,"name":"Std.Time.Modifier","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L430-L674"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.instInhabitedExtendedDayPeriod\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">instInhabitedExtendedDayPeriod</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.ExtendedDayPeriod\">ExtendedDayPeriod</a></span></div></div>","info":{"doc":"","docLink":"./Std/Time/Format/Modifier.html#Std.Time.instInhabitedExtendedDayPeriod","kind":"instance","line":428,"name":"Std.Time.instInhabitedExtendedDayPeriod","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L428-L428"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.instReprExtendedDayPeriod.repr\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">instReprExtendedDayPeriod</span>.<span class=\"name\">repr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.ExtendedDayPeriod\">ExtendedDayPeriod</a> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Init/Data/Format/Basic.html#Std.Format\">Std.Format</a></span></span></div></div>","info":{"doc":"","docLink":"./Std/Time/Format/Modifier.html#Std.Time.instReprExtendedDayPeriod.repr","kind":"def","line":428,"name":"Std.Time.instReprExtendedDayPeriod.repr","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L428-L428"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.instReprExtendedDayPeriod\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">instReprExtendedDayPeriod</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Repr.html#Repr\">Repr</a> <a href=\"./Std/Time/Format/Modifier.html#Std.Time.ExtendedDayPeriod\">ExtendedDayPeriod</a></span></div></div>","info":{"doc":"","docLink":"./Std/Time/Format/Modifier.html#Std.Time.instReprExtendedDayPeriod","kind":"instance","line":428,"name":"Std.Time.instReprExtendedDayPeriod","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L428-L428"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.ExtendedDayPeriod.evening\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">ExtendedDayPeriod</span>.<span class=\"name\">evening</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.ExtendedDayPeriod\">ExtendedDayPeriod</a></div></div>","info":{"doc":"18:00–21:00\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.ExtendedDayPeriod.evening","kind":"ctor","line":424,"nam