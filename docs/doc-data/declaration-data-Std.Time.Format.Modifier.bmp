"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.X\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">X</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.OffsetX\">OffsetX</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`X`: Zone offset with 'Z' for zero (e.g., Z, -08, -0830, -08:30).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.X","kind":"ctor","line":657,"name":"Std.Time.Modifier.X","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L657-L660"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.O\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">O</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.OffsetO\">OffsetO</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`O`: Localized zone offset using the `GMT` prefix (e.g., `GMT+8`, `GMT+08:00`).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.O","kind":"ctor","line":652,"name":"Std.Time.Modifier.O","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L652-L655"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructo