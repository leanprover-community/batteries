an class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.k\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">k</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`k`: Clock hour of day (1-24) (e.g., 24).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.k","kind":"ctor","line":595,"name":"Std.Time.Modifier.k","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L595-L598"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier.K\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">Modifier</span>.<span class=\"name\">K</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">presentation</span> : <a href=\"./Std/Time/Format/Modifier.html#Std.Time.Number\">Number</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Format/Modifier.html#Std.Time.Modifier\">Modifier</a></div></div>","info":{"doc":"`K`: Hour of AM/PM (0-11) (e.g., 0).\n","docLink":"./Std/Time/Format/Modifier.html#Std.Time.Modifier.K","kind":"ctor","line":590,"name":"Std.Time.Modifier.K","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Time/Format/Modifier.lean#L590-L593"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</s