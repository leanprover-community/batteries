Array` are allowed in an encoded URI component. This is a fast check\nthat only verifies the character set, not full encoding validity.\n","docLink":"./Std/Http/Data/URI/Encoding.html#Std.Http.URI.IsAllowedEncodedChars","kind":"def","line":50,"name":"Std.Http.URI.IsAllowedEncodedChars","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Encoding.lean#L50-L56"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Encoding.html#Std.Http.URI.isEncodedQueryChar\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">isEncodedQueryChar</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">rule</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#UInt8\">UInt8</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Init/Prelude.html#UInt8\">UInt8</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks if a byte is valid in a percent-encoded query string component. Extends `isEncodedChar` to also\nallow '+' which represents space in application/x-www-form-urlencoded format.\n","docLink":"./Std/Http/Data/URI/Encoding.html#Std.Http.URI.isEncodedQueryChar","kind":"def","line":43,"name":"Std.Http.URI.isEncodedQueryChar","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Encoding.lean#L43-L48"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Http/Data/URI/Encoding.html#Std.Http.URI.isEncodedChar\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">isEncodedChar</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">rule</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#UInt8\">UInt8</a> → <a href=\"./Init/Prelude.html#Bool\">Bool</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Init/Prelude.html#UInt8\">UInt8</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks if a byte is a valid character in a percent-encoded URI component. Valid characters are\nunreserved characters or the percent sign (for escape sequences).\n","docLink":"./Std/Http/Data/URI/Encoding.html#Std.Http.URI.isEncodedChar","kind":"def","line":36,"name":"Std.Http.URI.isEncodedChar","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Std/Http/Data/URI/Encoding.lean#L36-L41"}}],"imports":["Init.Data.Array.Lemmas","Init.Data.SInt.Lemmas","Init.Data.String.Basic","Init.Data.UInt.Bitwise","Init.Data.UInt.Lemmas","Init.Grind","Init.While","Std.Http.Internal.Char"],"instances":[{"className":"Decidable","name":"Std.Http.URI.instDecidableIsAllowedEncodedChars","typeNames":["Std.Http.URI.IsAllowedEncodedChars"]},{"className":"Decidable","name":"Std.Http.URI.instDecidableIsAllowedEncodedQueryChars","typeNames":["Std.Http.URI.IsAllowedEncodedQueryChars"]},{"className":"Inhabited","name":"Std.Http.URI.EncodedString.instInhabited","typeNames":["Std.Http.URI.EncodedString"]},{"className":"ToString","name":"Std.Http.URI.EncodedString.instToString","typeNames":["Std.Http.URI.EncodedString"]},{"className":"Repr","name":"Std.Http.URI.EncodedString.instRepr","typeNames":["Std.Http.URI.EncodedString"]},{"className":"BEq","name":"Std.Http.URI.EncodedString.instBEq","typeNames":["Std.Http.URI.EncodedString"]},{"className":"Hashable","name":"Std.Http.URI.EncodedString.instHashable","typeNames":["Std.Http.URI.EncodedString"]},{"className":"Inhabited","name":"Std.Http.URI.EncodedQueryString.instInhabited","typeNames":["Std.Http.URI.EncodedQueryString"]},{"className":"ToString","name":"Std.Http.URI.instToStringEncodedQueryString","typeNames":["Std.Http.URI.EncodedQueryString"]},{"className":"Repr","name":"Std.Http.URI.instReprEncodedQueryString","typeNames":["Std.Http.URI.EncodedQueryString"]},{"className":"BEq","name":"Std.Http.URI.instBEqEncodedQueryString","typeNames":["Std.Http.URI.EncodedQueryString"]},{"className":"Hashable","name":"Std.Http.URI.instHashableEncodedQueryString","typeNames":["Std.Http.URI.EncodedQueryString"]},{"className":"Hashable","name":"Std.Http.URI.instHashableOptionEncodedQueryString","typeNames":["Option"]}],"name":"Std.Http.Data.URI.Encoding"}