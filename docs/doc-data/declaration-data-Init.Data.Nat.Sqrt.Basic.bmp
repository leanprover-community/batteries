{"declarations":[{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Nat/Sqrt/Basic.html#Nat.sqrt.iter\"><span class=\"name\">Nat</span>.<span class=\"name\">sqrt</span>.<span class=\"name\">iter</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n </span><span class=\"fn\">guess</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Auxiliary for `sqrt`. If `guess` is greater than the integer square root of `n`,\nreturns the integer square root of `n`. ","docLink":"./Init/Data/Nat/Sqrt/Basic.html#Nat.sqrt.iter","kind":"def","line":28,"name":"Nat.sqrt.iter","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Nat/Sqrt/Basic.lean#L28-L33"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Nat/Sqrt/Basic.html#Nat.sqrt\"><span class=\"name\">Nat</span>.<span class=\"name\">sqrt</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>","info":{"doc":"Integer square root function. Implemented via Newton's method.\n","docLink":"./Init/Data/Nat/Sqrt/Basic.html#Nat.sqrt","kind":"def","line":18,"name":"Nat.sqrt","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Init/Data/Nat/Sqrt/Basic.lean#L18-L34"}}],"imports":["Init.Data.Nat.Bitwise.Basic","Init.Data.Nat.Log2","Init.Prelude","Init.WFTactics"],"instances":[],"name":"Init.Data.Nat.Sqrt.Basic"}