om/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/Bootstrap.lean#L60-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/Bootstrap.html#String.singleton\"><span class=\"name\">String</span>.<span class=\"name\">singleton</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>","info":{"doc":"Returns a new string that contains only the character `c`.\n\nBecause strings are encoded in UTF-8, the resulting string may take multiple bytes.\n\nExamples:\n* `String.singleton 'L' = \"L\"`\n* `String.singleton ' ' = \" \"`\n* `String.singleton '\"' = \"\\\"\"`\n* `String.singleton '𝒫' = \"𝒫\"`\n","docLink":"./Init/Data/String/Bootstrap.html#String.singleton","kind":"def","line":41,"name":"String.singleton","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/Bootstrap.lean#L41-L53"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/Bootstrap.html#String.push\"><span class=\"name\">String</span>.<span class=\"name\">push</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#String\">String</a> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Char\">Char</a> → <a href=\"./Init/Prelude.html#String\">String</a></span></span></div></div>","info":{"doc":"Adds a character to the end of a string.\n\nThe internal implementation uses dynamic arrays and will perform destructive updates\nif the string is not shared.\n\nExamples:\n* `\"abc\".push 'd' = \"abcd\"`\n* `\"\".push 'a' = \"a\"`\n","docLink":"./Init/Data/String/Bootstrap.html#String.push","kind":"def","line":23,"name":"String.push","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/Bootstrap.lean#L23-L39"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/Bootstrap.html#String.instInhabited\"><span class=\"name\">String</span>.<span class=\"name\">instInhabited</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Init/Prelude.html#String\">String</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/String/Bootstrap.html#String.instInhabited","kind":"instance","line":20,"name":"String.instInhabited","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/Bootstrap.lean#L20-L21"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/String/Bootstrap.html#String.instOfNatRaw\"><span class=\"name\">String</span>.<span class=\"name\">instOfNatRaw</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#OfNat\">OfNat</a> <a href=\"./Init/Prelude.html#String.Pos.Raw\">Pos.Raw</a> <span class=\"fn\">0</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/String/Bootstrap.html#String.instOfNatRaw","kind":"instance","line":17,"name":"String.instOfNatRaw","sourceLink":"https://github.com/leanprover/lean4/blob/62eed1db4d67327ec8120be05f1a1b0847d74561/src/Init/Data/String/Bootstrap.lean#L17-L18"}}],"imports":["Init.Data.ByteArray.Bootstrap","Init.Data.Char.Basic","Init.Data.UInt.BasicAux"],"instances":[{"className":"OfNat","name":"String.instOfNatRaw","typeNames":["String