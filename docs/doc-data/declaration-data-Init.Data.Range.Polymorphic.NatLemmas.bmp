type\"><span class=\"fn\">0</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>&lt;...<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Roo.toArray\">toArray</a></span><a href=\"./Init/GetElem.html#GetElem?.getElem!\">[</a><span class=\"fn\">i</span><a href=\"./Init/GetElem.html#GetElem?.getElem!\">]</a><a href=\"./Init/GetElem.html#GetElem?.getElem!\">!</a> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">i</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HSub.hSub\">-</a> (<span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.zero_lt_getElem!_toArray_roo_iff","kind":"theorem","line":1338,"name":"Nat.zero_lt_getElem!_toArray_roo_iff","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/NatLemmas.lean#L1338-L1341"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.getElem!_toArray_roo_eq_zero_iff\"><span class=\"name\">Nat</span>.<span class=\"name\">getElem!_toArray_roo_eq_zero_iff</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n </span><span class=\"fn\">i</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>&lt;...<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Roo.toArray\">toArray</a></span><a href=\"./Init/GetElem.html#GetElem?.getElem!\">[</a><span