=\"fn\">m </span><span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>&lt;...<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Roo.toList\">toList</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">((<span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)...<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rco.toList\">toList</a></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.toList_roo_eq_toList_rco","kind":"theorem","line":1026,"name":"Nat.toList_roo_eq_toList_rco","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/NatLemmas.lean#L1026-L1028"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.induct_rcc_right\"><span class=\"name\">Nat</span>.<span class=\"name\">induct_rcc_right</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">motive</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">base</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>), <span class=\"fn\"><span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">a</span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>), <span class=\"fn\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">b</span> → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> (<span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"Induction principle for proving properties of `Nat`\\-based ranges of the form `a...=b` by\nvarying the upper bound\\.\n\nIn the `base` case, one proves that for any `a : Nat` and `b : Nat` with\n`b ≤ a`, the statement holds for the subsingleton range `a...=b`\\.\n\nIn the `step` case, one proves that for any `a : Nat` and `b : Nat`, if the\nstatement holds for `a...=b`, it also holds for the larger range `a...=(b + 1)`\\.\n\nThe following is an example reproving `length_toList_rcc`\\.\n\n```\nexample (a b : Nat) : (a...=b).toList.length = b + 1 - a := by\n  induction a, b using Nat.induct_rcc_right\n  case base a b hge =>\n    by_cases h : b < a\n    · simp only [Nat.toList_rcc_eq_nil, List.length_nil, *]\n      omega\n    · have : b = a := by omega\n      simp only [Nat.toList_rcc_eq_singleton, List.length_singleton,\n        Nat.add_sub_cancel_left, *]\n  case step a b hle ih =>\n    rw [Nat.toList_rcc_succ_right_eq_append (by omega), List.length_append,\n      List.length_singleton, ih] <;> omega\n```\n","docLink":"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.induct_rcc_right","kind":"theorem","line":984,"name":"Nat.induct_rcc_right","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/NatLemmas.lean#L984-L1024"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.induct_rcc_left\"><span class=\"name\">Nat</span>.<span class=\"name\">induct_rcc_left</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">motive</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">base</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>), <span class=\"fn\"><span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">a</span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">step</span> : <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>), <span class=\"fn\"><span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">b</span> → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">motive</span> (<span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>) <span class=\"fn\">b</span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\">a</span> <span class=\"fn\">b</span></span></div></div>","info":{"doc":"Induction principle for proving properties of `Nat`\\-based ranges of the form `a...=b` by\nvarying the lower bound\\.\n\nIn the `base` case, one proves that for any `a : Nat` and `b : Nat` with\n`b < a`, the statement holds for the empty range `a...=b`\\.\n\nIn the `step` case, one proves that for any `a : Nat` and `b : Nat`, the\nstatement holds for nonempty ranges `a...b` if it holds for the smaller range\n`(a + 1)...=b`\\.\n\nThe following is an example reproving `length_toList_rcc`\\.\n\n```\nexample (a b : Nat) : (a...=b).toList.length = b + 1 - a := by\n  induction a, b using Nat.induct_rcc_left\n  case base =>\n    simp only [Nat.toList_rcc_eq_nil, List.length_nil, *]; omega\n  case step =>\n    simp only [Nat.toList_rcc_eq_cons, List.length_cons, *]; omega\n```\n","docLink":"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.induct_rcc_left","kind":"theorem","line":951,"name":"Nat.induct_rcc_left","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/NatLemmas.lean#L951-L982"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.getD_toArray_rcc_eq_fallback\"><span class=\"name\">Nat</span>.<span class=\"name\">getD_toArray_rcc_eq_fallback</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n </span><span class=\"fn\">i </span><span class=\"fn\">fallback</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">i</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">m</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toArray\">toArray</a></span>.<a href=\"./Init/Prelude.html#Array.getD\">getD</a></span> <span class=\"fn\">i</span> <span class=\"fn\">fallback</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">fallback</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.getD_toArray_rcc_eq_fallback","kind":"theorem","line":946,"name":"Nat.getD_toArray_rcc_eq_fallback","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/NatLemmas.lean#L946-L949"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.getD_toArray_rcc_eq_add\"><span class=\"name\">Nat</span>.<span class=\"name\">getD_toArray_rcc_eq_add</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n </span><span class=\"fn\">i </span><span class=\"fn\">fallback</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\">i</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span> <a href=\"./Init/Prelude.html#HSub.hSub\">-</a> <span class=\"fn\">m</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorphic/Iterators.html#Std.Rcc.toArray\">toArray</a></span>.<a href=\"./Init/Prelude.html#Array.getD\">getD</a></span> <span class=\"fn\">i</span> <span class=\"fn\">fallback</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">i</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.getD_toArray_rcc_eq_add","kind":"theorem","line":941,"name":"Nat.getD_toArray_rcc_eq_add","sourceLink":"https://github.com/leanprover/lean4/blob/3b0f2862196c6a8af9eb0025ee650252694013dd/src/Init/Data/Range/Polymorphic/NatLemmas.lean#L941-L944"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Range/Polymorphic/NatLemmas.html#Nat.getD_toArray_rcc\"><span class=\"name\">Nat</span>.<span class=\"name\">getD_toArray_rcc</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m </span><span class=\"fn\">n </span><span class=\"fn\">i </span><span class=\"fn\">fallback</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">m</span>...=<span class=\"fn\">n</span>)</span>.<a href=\"./Init/Data/Range/Polymorph