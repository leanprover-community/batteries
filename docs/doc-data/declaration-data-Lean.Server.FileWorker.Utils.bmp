bleDocument\"><span class=\"name\">Lean</span>.<span class=\"name\">Server</span>.<span class=\"name\">FileWorker</span>.<span class=\"name\">EditableDocument</span></a></span><span class=\"decl_extends\">extends</span> <span id=\"Lean.Server.FileWorker.EditableDocument.toEditableDocumentCore\"><a href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore\">Lean.Server.FileWorker.EditableDocumentCore</a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"`EditableDocumentCore` with reporter task. ","docLink":"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocument","kind":"structure","line":163,"name":"Lean.Server.FileWorker.EditableDocument","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Server/FileWorker/Utils.lean#L163-L168"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore.publishDiagnostics\"><span class=\"name\">Lean</span>.<span class=\"name\">Server</span>.<span class=\"name\">FileWorker</span>.<span class=\"name\">EditableDocumentCore</span>.<span class=\"name\">publishDiagnostics</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">doc</span> : <a href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore\">EditableDocumentCore</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">incrementalDiagnosticSupport</span> : <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">writeDiagnostics</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Lean/Data/JsonRpc.html#Lean.JsonRpc.Notification\">JsonRpc.Notification</a> <a href=\"./Lean/Data/Lsp/Diagnostics.html#Lean.Lsp.PublishDiagnosticsParams\">Lsp.PublishDiagnosticsParams</a></span> → <span class=\"fn\"><a href=\"./Init/System/IO.html#BaseIO\">BaseIO</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#BaseIO\">BaseIO</a> <a href=\"./Init/Prelude.html#Unit\">Unit</a></span></div></div>","info":{"doc":"Collects diagnostics for a `textDocument/publishDiagnostics` notification, updates\nthe incremental tracking fields and writes the notification to the client.\n\nWhen `incrementalDiagnosticSupport` is `true` and the state allows it, sends only\nthe newly added diagnostics with `isIncremental? := some true`. Otherwise, sends\nall sticky and non-sticky diagnostics non-incrementally.\n\nThe state update and the write are performed atomically under the diagnostics mutex\nto prevent reordering between concurrent publishers (the reporter task and the main thread).\n","docLink":"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore.publishDiagnostics","kind":"def","line":119,"name":"Lean.Server.FileWorker.EditableDocumentCore.publishDiagnostics","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Server/FileWorker/Utils.lean#L119-L159"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore.update\"><span class=\"name\">Lean</span>.<span class=\"name\">Server</span>.<span class=\"name\">FileWorker</span>.<span class=\"name\">EditableDocumentCore</span>.<span class=\"name\">update</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">doc</span> : <a href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore\">EditableDocumentCore</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">newMeta</span> : <a href=\"./Lean/Server/Utils.html#Lean.Server.DocumentMeta\">DocumentMeta</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">newInitSnap</span> : <a href=\"./Lean/Language/Lean/Types.html#Lean.Language.Lean.InitialSnapshot\">Language.Lean.InitialSnapshot</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#BaseIO\">BaseIO</a> <a href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore\">EditableDocumentCore</a></span></div></div>","info":{"doc":"Creates a new `EditableDocumentCore` for a new document version, sharing the same sticky\ndiagnostics with the previous version.\n","docLink":"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore.update","kind":"def","line":108,"name":"Lean.Server.FileWorker.EditableDocumentCore.update","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Server/FileWorker/Utils.lean#L108-L117"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore.collectCurrentDiagnostics\"><span class=\"name\">Lean</span>.<span class=\"name\">Server</span>.<span class=\"name\">FileWorker</span>.<span class=\"name\">EditableDocumentCore</span>.<span class=\"name\">collectCurrentDiagnostics</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">doc</span> : <a href=\"./Lean/Server/FileWorker/Utils.html#Lean.Server.FileWorker.EditableDocumentCore\">EditableDocumentCore</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/System/IO.html#BaseIO\">BaseIO</a> <span class=\"fn\">(<a href=