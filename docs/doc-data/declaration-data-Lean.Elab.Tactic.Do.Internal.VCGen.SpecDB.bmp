,"sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L59-L59"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.proof\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremNew</span>.<span class=\"name\">proof</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\">SpecTheoremNew</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/Tactic/Do/Attr.html#Lean.Elab.Tactic.Do.SpecAttr.SpecProof\">SpecProof</a></div></div>","info":{"doc":"The proof for the theorem. ","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.proof","kind":"def","line":57,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.proof","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L57-L57"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.pattern\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremNew</span>.<span class=\"name\">pattern</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\">SpecTheoremNew</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Meta/Sym/Pattern.html#Lean.Meta.Sym.Pattern\">Meta.Sym.Pattern</a></div></div>","info":{"doc":"Pattern for the program expression.\nThis is the key used in the discrimination tree.\nIf the proof has type `∀ a b c, Triple prog P Q`, then the pattern is `prog[a:=#2, b:=#1, c:=#0]`.\nFor simp specs with type `∀ a b c, lhs = rhs`, the pattern is `lhs[a:=#2, b:=#1, c:=#0]`.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.pattern","kind":"def","line":55,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.pattern","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L55-L55"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.mk\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremNew</span>.<span class=\"name\">mk</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Sym/Pattern.html#Lean.Meta.Sym.Pattern\">Lean.Meta.Sym.Pattern</a> →\n  <span class=\"fn\"><a href=\"./Lean/Elab/Tactic/Do/Attr.html#Lean.Elab.Tactic.Do.SpecAttr.SpecProof\">Lean.Elab.Tactic.Do.SpecAttr.SpecProof</a> →\n    <span class=\"fn\"><a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind\">Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind</a> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Nat\">Nat</a> → <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\">Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew</a></span></span></span></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.mk","kind":"ctor","line":48,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.mk","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L48-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremNew</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew","kind":"structure","line":48,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L48-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremKind\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">instInhabitedSpecTheoremKind</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind\">SpecTheoremKind</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremKind","kind":"instance","line":46,"name":"Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremKind","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L46-L46"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind.simp\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremKind</span>.<span class=\"name\">simp</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">etaArgs</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a> := <span class=\"fn\">0</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind\">SpecTheoremKind</a></div></div>","info":{"doc":"A simp/equational spec: `lhs = rhs`.\nThe pattern is the LHS.\nWhen matched, the VCGen rewrites the program from `lhs` to `rhs` and continues.\n`etaArgs` is the number of extra arguments introduced by eta-expanding function-level equations\n(e.g., class projection unfold lemmas). These args need `congrFun` at instantiation time.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind.simp","kind":"ctor","line":38,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind.simp","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L38-L45"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind.triple\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremKind</span>.<span class=\"name\">triple</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">etaPotential</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a> := <span class=\"fn\">0</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind\">SpecTheoremKind</a></div></div>","info":{"doc":"A Hoare triple spec: `⦃P⦄ prog ⦃Q⦄`.\nIf `etaPotential` is non-zero, then the precondition contains meta variables that can be\ninstantiated after applying `mintro ∀s` `etaPotential` many times.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind.triple","kind":"ctor","line":32,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind.triple","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L32-L37"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremKind</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The kind of a spec theorem.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind","kind":"inductive","line":28,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L28-L46"}}],"imports":["Lean.Elab.Tactic.Do.Attr","Lean.Meta.DiscrTree.Util","Lean.Meta.Sym.Pattern","Lean.Meta.Sym.Simp.DiscrTree","Lean.Meta.Sym.Util"],"instances":[{"className":"Inhabited","name":"Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremKind","typeNames":["Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremKind"]},{"className":"Inhabited","name":"Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremNew","typeNames":["Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew"]},{"className":"BEq","name":"Lean.Elab.Tactic.Do.SpecAttr.instBEqSpecTheoremNew","typeNames":["Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew"]},{"className":"Inhabited","name":"Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremsNew","typeNames":["Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremsNew"]}],"name":"Lean.Elab.Tactic.Do.Internal.VCGen.SpecDB"}