812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L88-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremsNew\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremsNew</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremsNew","kind":"structure","line":88,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremsNew","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L88-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.instantiate\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">SpecTheoremNew</span>.<span class=\"name\">instantiate</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">specThm</span> : <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\">SpecTheoremNew</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Meta/Basic.html#Lean.Meta.MetaM\">MetaM</a> (<span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a></span> <a href=\"./Init/Prelude.html#Prod\">×</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Lean/Expr.html#Lean.BinderInfo\">BinderInfo</a></span> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Lean/Expr.html#Lean.Expr\">Expr</a>)</span></div></div>","info":{"doc":"Like `SpecProof.instantiate`, but for simp specs also eta-expands function-level equations.\n\nFor unfold equations of class projections (e.g., `MonadState.modifyGet.eq_1`), the equation\nafter `forallMetaTelescope` may be between functions rather than values:\n  `@modifyGet σ m self = self.3 : {α} → (σ → α × σ) → m α`\nThis method applies `congrFun` for each leading forall to reduce the equation to one between\nvalues of type `m α`, introducing fresh metavariables for the extra arguments.\nThe number of extra args is stored in `SpecTheoremKind.simp etaArgs`.\n","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.instantiate","kind":"def","line":66,"name":"Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.instantiate","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L66-L86"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.instBEqSpecTheoremNew\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">instBEqSpecTheoremNew</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#BEq\">BEq</a> <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\">SpecTheoremNew</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.instBEqSpecTheoremNew","kind":"instance","line":63,"name":"Lean.Elab.Tactic.Do.SpecAttr.instBEqSpecTheoremNew","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L63-L64"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremNew\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<span class=\"name\">SpecAttr</span>.<span class=\"name\">instInhabitedSpecTheoremNew</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew\">SpecTheoremNew</a></span></div></div>","info":{"doc":"","docLink":"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremNew","kind":"instance","line":61,"name":"Lean.Elab.Tactic.Do.SpecAttr.instInhabitedSpecTheoremNew","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.lean#L61-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Lean/Elab/Tactic/Do/Internal/VCGen/SpecDB.html#Lean.Elab.Tactic.Do.SpecAttr.SpecTheoremNew.priority\"><span class=\"name\">Lean</span>.<span class=\"name\">Elab</span>.<span class=\"name\">Tactic</span>.<span class=\"name\">Do</span>.<