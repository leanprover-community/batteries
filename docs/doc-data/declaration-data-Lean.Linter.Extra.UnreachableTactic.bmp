e","line":23,"name":"Lean.Linter.Extra.linter.extra.unreachableTactic","sourceLink":"https://github.com/leanprover/lean4/blob/b4812ae53eea93439ad5dce5a5c26591c31cb697/src/Lean/Linter/Extra/UnreachableTactic.lean#L23-L35"}}],"imports":["Init.Try","Lean.Elab.Command","Lean.Linter.Basic","Lean.Parser.Syntax"],"instances":[],"name":"Lean.Linter.Extra.UnreachableTactic"}